start_sawmill_processing_loop :: proc(player: Player, sawmill_entity: Entity, timeout: float) {
    if player == null || !player.is_local() return;
    if player.sawmill_processing_loop_active return;
    player.sawmill_processing_loop_active = true;

    asset := get_asset(SFX_Asset, SAWMILL_PROCESS_LOOP_SFX);
    desc := SFX.default_sfx_desc();
    desc.specific_to_player = player;
    if #alive(sawmill_entity) {
        desc.entity_to_follow = sawmill_entity.id;
    }
    desc.loop = true;
    desc.loop_timeout = max(0.25, timeout);
    desc.volume = SAWMILL_PROCESS_LOOP_VOLUME;
    desc.range_multiplier = SAWMILL_PROCESS_LOOP_RANGE_MULTIPLIER;
    player.sawmill_processing_sound_id = SFX.play(asset, desc);
}

stop_sawmill_processing_loop :: proc(player: Player) {
    if player == null || !player.is_local() return;
    if !player.sawmill_processing_loop_active && player.sawmill_processing_sound_id == 0 return;
    if player.sawmill_processing_sound_id != 0 {
        SFX.stop(player.sawmill_processing_sound_id);
    }
    player.sawmill_processing_sound_id = 0;
    player.sawmill_processing_loop_active = false;
}

start_polishing_processing_loop :: proc(player: Player, polisher_entity: Entity, timeout: float) {
