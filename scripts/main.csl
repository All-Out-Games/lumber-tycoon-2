apply_axe_cleave :: proc(player: Player, primary: Lumber_Tree) {
    cleaves := axe_cleave_targets(player.axe_tier);
    if cleaves <= 0 return;
    radius := 2.45 + max(0, player.axe_tier - 4).(float) * 0.35;
    radius_d2 := radius * radius;
    frame := get_frame_number();
    damage := axe_cleave_damage(player.axe_tier);
    primary_pos := tree_axe_collision_position(primary);
    query_trees_near(primary_pos, radius, ref player.nearby_tree_cache);

    for i: 0..cleaves - 1 {
        best: Lumber_Tree = null;
        best_d2 := radius_d2;
        for tree: player.nearby_tree_cache {
            if tree == primary continue;
            if tree.is_cut || tree.is_falling continue;
            if tree.target_frame == frame continue;
            d2 := length_squared(tree_axe_collision_position(tree) - primary_pos);
            if d2 <= best_d2 {
                best = tree;
                best_d2 = d2;
            }
        }

        if best == null return;
        best.target_frame = frame;
        best.start_chop_damage(player, 0.08 + i.(float) * 0.05, damage);
    }
}

make_tree_shimmer_material :: proc(shimmer: Shader_Asset, noise_tex: Texture_Asset, shadow: v3, mid: v3, hi: v3, black_point: float, white_point: float, gamma: float, shadow_boost: float) -> Material {
    if shimmer == null return null;
    m := Material.create(shimmer);
    if m == null return null;
    if noise_tex != null m.set_texture("noise_texture", noise_tex);
    m.set_float3("paletteShadow", shadow);
    m.set_float3("paletteMid", mid);
    m.set_float3("paletteHi", hi);
    m.set_float("paletteBlackPoint", black_point);
    m.set_float("paletteWhitePoint", white_point);
    m.set_float("paletteGamma", gamma);
    m.set_float("tintStrength", 1.00);
    m.set_float("shadowBoost", shadow_boost);
    m.set_float("outlineLow", 0.06);
    m.set_float("outlineHigh", 0.12);
    m.set_float("outlineDarken", 0.65);
    m.set_float("outlineLumaMin", 0.00);
    m.set_float("outlineLumaMax", 0.20);
    return m;
}

register_tree_level_materials :: proc() {
    noise_tex := get_asset(Texture_Asset, "noise.png");
    shimmer := get_asset(Shader_Asset, "shaders/color_shimmer.aosl");

    tree_gold_material = make_tree_shimmer_material(shimmer, noise_tex, v3{0.32, 0.21, 0.05}, v3{0.937, 0.749, 0.016}, v3{1.00, 0.92, 0.25}, 0.10, 0.90, 0.90, 0.40);
    tree_diamond_material = make_tree_shimmer_material(shimmer, noise_tex, v3{0.03, 0.09, 0.45}, v3{0.30, 0.82, 1.00}, v3{0.75, 0.98, 1.00}, 0.08, 0.95, 0.80, 0.70);
    tree_candy_material = make_tree_shimmer_material(shimmer, noise_tex, v3{0.55, 0.10, 0.30}, v3{1.00, 0.55, 0.80}, v3{1.00, 0.90, 0.95}, 0.10, 0.92, 0.85, 0.55);

    rainbow := get_asset(Shader_Asset, "shaders/rainbow.aosl");
    if rainbow != null {
        m := Material.create(rainbow);
        if m != null {
            m.set_float("rainbowScale", 1.20);
            m.set_float("hueSpeed", 0.20);
            m.set_float("hueSaturation", 1.00);
            m.set_float("hueValue", 1.00);
            m.set_float("tintStrength", 0.65);
            m.set_float("outlineLow", 0.04);
            m.set_float("outlineHigh", 0.16);
            tree_rainbow_material = m;
        }
    }
}

tree_level_health_multiplier :: proc(tree_level: s64) -> s64 {
    switch clamp(tree_level, 1, MAX_TREE_LEVEL) {
        case 1: return 1;
        case 2: return 4;
        case 3: return 16;
        case 4: return 64;
        default: return 256;
    }
}

tree_level_log_reward :: proc(tree_level: s64) -> s64 {
    switch clamp(tree_level, 1, MAX_TREE_LEVEL) {
        case 1: return 1;
        case 2: return 3;
        case 3: return 4;
        case 4: return 10;
        default: return 25;
    }
}

tree_level_material :: proc(tree_level: s64) -> Material {
    switch clamp(tree_level, 1, MAX_TREE_LEVEL) {
        case 2: return tree_gold_material;
        case 3: return tree_diamond_material;
        case 4: return tree_rainbow_material;
        case 5: return tree_candy_material;
        default: return null;
    }
}

axe_visual_shader_level :: proc(tier: s64) -> s64 {
    tier = clamp(tier, 1, MAX_AXE_TIER);
    if tier >= 11 return 5;
    if tier >= 9 return 4;
    if tier >= 6 return 3;
    if tier >= 3 return 2;
    return 0;
}

axe_visual_material :: proc(tier: s64) -> Material {
    level := axe_visual_shader_level(tier);
    if level <= 0 return null;
    return tree_level_material(level);
}

tree_level_fallback_tint :: proc(tree_level: s64) -> v4 {
    switch clamp(tree_level, 1, MAX_TREE_LEVEL) {
        case 2: return {1.45, 1.18, 0.34, 1};
        case 3: return {0.55, 1.08, 1.45, 1};
        case 4: return {1.25, 0.55, 1.45, 1};
        case 5: return {1.45, 0.72, 1.05, 1};
        default: return {1, 1, 1, 1};
    }
}

try_start_chop :: proc(player: Player) -> bool {
    if count_item(player, log_defn) >= effective_backpack_capacity(player) {
        spawn_float_text_for_player(player, player.entity.world_position + v2{0, 1.55}, "Backpack full", {1.0, 0.12, 0.08, 1}, true);
        if player_local_feedback(player) {
            play_backpack_full_dud_sfx(player.entity.world_position);
        }
        return false;
    }

    radius := axe_chop_radius(player.axe_tier);
    frame := get_frame_number();
    best: Lumber_Tree = null;
    best_d2 := radius * radius;
    query_trees_near(player.entity.world_position, radius, ref player.nearby_tree_cache);
    for tree: player.nearby_tree_cache {
        if tree.is_cut || tree.is_falling continue;
        if tree.target_frame == frame continue;
        d2 := length_squared(tree_axe_collision_position(tree) - player.entity.world_position);
        if d2 <= best_d2 {
            best = tree;
            best_d2 = d2;
        }
    }

    if best != null {
        best.target_frame = frame;
        best.start_chop(player, 0);
        apply_axe_cleave(player, best);
        g_chop_successes += 1;
        player.swing_timer = 0.42;
        player.camera_shake = max(player.camera_shake, axe_screen_shake(player.axe_tier));
        player.last_chop_time = get_time();
        spawn_juice_particles(player.entity.world_position + v2{0, 0.65}, player.axe_tier, 2 + player.axe_tier, axe_tier_color(player.axe_tier), true);
        return true;
    }
    return false;
}

nearest_tree_count :: proc(player: Player) -> s64 {
    radius := axe_chop_radius(player.axe_tier);
    radius_d2 := radius * radius;
    count: s64 = 0;
    query_trees_near(player.entity.world_position, radius, ref player.nearby_tree_cache);
    for tree: player.nearby_tree_cache {
        if tree.is_cut || tree.is_falling continue;
        if length_squared(tree_axe_collision_position(tree) - player.entity.world_position) <= radius_d2 {
            count += 1;
        }
    }
    return count;
}

find_nearest_unchopped_tree :: proc(pos: v2) -> Lumber_Tree {
    best: Lumber_Tree = null;
    best_d2 := 999999999.0;
    tree_grid_ensure();
    if !g_tree_grid_ready return null;
    for i: 0..TREE_GRID_CELL_COUNT - 1 {
        for tree: g_tree_grid[i].trees {
            if tree == null continue;
            if tree.is_cut || tree.is_falling continue;
            if !#alive(tree.entity) continue;
            d2 := length_squared(tree_axe_collision_position(tree) - pos);
            if d2 < best_d2 {
                best = tree;
                best_d2 = d2;
            }
        }
    }
    return best;
}

update_helicopter_auto_fly :: proc(player: Player, dt: float) {
    if player == null return;
    if !player.helicopter_auto_fly return;
    if !player_helicopter_rented(player) {
        player.helicopter_auto_fly = false;
        return;
    }
    if !#alive(player.entity) return;

    tree := find_nearest_unchopped_tree(player.entity.world_position);
    if tree == null {
        player.helicopter_auto_fly = false;
        player.dialogue_text = "No trees found.";
        player.dialogue_timer = 1.1;
        return;
    }

    to_target := tree_axe_collision_position(tree) - player.entity.world_position;
    distance := length(to_target);
    if distance <= HELICOPTER_AUTO_FLY_STOP_RADIUS return;

    direction := normalize(to_target);
    step := min(HELICOPTER_AUTO_FLY_SPEED * dt, distance - HELICOPTER_AUTO_FLY_STOP_RADIUS);
    player.entity.set_local_position(player.entity.local_position + direction * step);
}

create_player_axe_visual :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    if player.axe_visual_entity != null && #alive(player.axe_visual_entity) return;

    e := Scene.create_entity();
    e.set_name("Held_Axe_Visual");
    e.set_parent(player.entity, false);
    e.set_local_position(v2{0.34, 0.42});
    e.set_local_rotation(-35.0);
    e.set_local_scale(v2{0.40, 0.40});

    sprite := e.add_component(Sprite_Renderer);
    sprite.set_texture(held_axe_texture);
    sprite.layer = 6;
    sprite.depth_offset = -0.42;
    sprite.color = {1, 1, 1, 1};
    sprite.flip_x = true;

    player.axe_visual_entity = e;
    player.axe_visual_sprite = sprite;
    player.axe_visual_material_level = 0;
}

update_player_axe_visual :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    create_player_axe_visual(player);
    if player.axe_visual_entity == null || !#alive(player.axe_visual_entity) return;

    hidden := player_helicopter_rented(player) || player_tree_monster_rented(player) || player_bacteria_takeover_active(player);
    player.axe_visual_entity.set_local_enabled(!hidden);
    if hidden return;

    if spinning_axe_mode_enabled() {
        radius := spinning_axe_orbit_radius(player.axe_tier);
        angle := player.spinning_axe_angle;
        dir := v2{cos(angle), sin(angle)};
        visual_scale := spinning_axe_visual_scale(player.axe_tier);
        parent_flip_x := player.entity.local_scale.x < 0.0;
        local_dir := dir;
        local_scale_x := visual_scale;
        local_rotation := angle * RADIANS_TO_DEGREES + 90.0;
        if parent_flip_x {
            local_dir.x = -local_dir.x;
            local_scale_x = -local_scale_x;
            local_rotation = -local_rotation;
        }
        player.axe_visual_entity.set_local_position(local_dir * radius + v2{0, 0.35});
        player.axe_visual_entity.set_local_rotation(local_rotation);
        player.axe_visual_entity.set_local_scale(v2{local_scale_x, visual_scale});
        if player.axe_visual_sprite != null && #alive(player.axe_visual_sprite) {
            player.axe_visual_sprite.flip_x = true;
            shader_level := axe_visual_shader_level(player.axe_tier);
            if shader_level > 0 && player.axe_visual_material_level != shader_level {
                mat := axe_visual_material(player.axe_tier);
                if mat != null {
                    player.axe_visual_sprite.set_material(mat, false);
                    player.axe_visual_material_level = shader_level;
                }
            }
            color := axe_tier_color(player.axe_tier);
            color.w = axe_visual_opacity(player);
            player.axe_visual_sprite.color = color;
        }
        return;
    }

    bone_pos := v2{0.24, 0.30};
    if player.animator != null && #alive(player.animator) {
        // Use the streamed-character held item hand/aim bone. Fall back to Hand_R if needed.
        bone_pos = player.animator.get_bone_local_position("held_item");
        if length_squared(bone_pos) < 0.0001 {
            bone_pos = player.animator.get_bone_local_position("Hand_R") + v2{0.05, -0.02};
        }
        if length_squared(bone_pos) < 0.0001 {
            bone_pos = v2{0.24, 0.30};
        }
    }

    facing_left := false;
    if player.agent != null && #alive(player.agent) {
        if player.agent.velocity.x < -0.05 {
            facing_left = true;
        } else if player.agent.velocity.x > 0.05 {
            facing_left = false;
        } else if player.last_aim_direction.x < -0.05 {
            facing_left = true;
        }
    }

    offset := v2{0.16, 0.08};
    rotation := -35.0;
    if facing_left {
        offset.x = -0.16;
        rotation = 35.0;
    }

    player.axe_visual_entity.set_local_position(bone_pos + offset);
    player.axe_visual_entity.set_local_rotation(rotation);
    player.axe_visual_entity.set_local_scale(v2{0.40, 0.40});
    if player.axe_visual_sprite != null && #alive(player.axe_visual_sprite) {
        player.axe_visual_sprite.flip_x = !facing_left;
        player.axe_visual_sprite.color = {1, 1, 1, axe_visual_opacity(player)};
    }
}

spinning_axe_tree_in_hit_zone :: proc(player: Player, tree: Lumber_Tree, axe_pos: v2, axe_dir: v2, radius: float, contact_radius: float) -> bool {
    if player == null || tree == null return false;
    player_center := player.entity.world_position + v2{0, 0.35};
    tree_center := tree_axe_collision_position(tree) + v2{0, 0.25};
    tree_radius := spinning_axe_tree_collision_radius(tree);
    combined_radius := contact_radius + tree_radius;

    to_tree := tree_center - player_center;
    dist := length(to_tree);
    if dist > radius + combined_radius return false;

    if dist > 0.05 {
        tree_dir := normalize(to_tree);
        quadrant_dot := tree_dir.x * axe_dir.x + tree_dir.y * axe_dir.y;
        if quadrant_dot < SPINNING_AXE_QUADRANT_DOT return false;
    }

    if length(tree_center - axe_pos) <= combined_radius return true;
    if length(tree_axe_collision_position(tree) - axe_pos) <= combined_radius * 0.78 return true;
    if dist <= combined_radius return true;
    if abs(dist - radius) > combined_radius return false;

    tree_dir := normalize(to_tree);
    dot := tree_dir.x * axe_dir.x + tree_dir.y * axe_dir.y;
    return dot >= 0.70;
}

update_spinning_axe :: proc(player: Player, dt: float) {
    if !spinning_axe_mode_enabled() return;
    if !player_ready_for_ui(player) return;
    if player_helicopter_rented(player) || player_tree_monster_rented(player) return;
    if player_bacteria_takeover_active(player) return;

    player.spinning_axe_angle -= SPINNING_AXE_SPEED * dt;
    if player.spinning_axe_angle < 0.0 {
        player.spinning_axe_angle += PI * 2.0;
    }

    radius := spinning_axe_orbit_radius(player.axe_tier);
    contact_radius := spinning_axe_contact_radius(player.axe_tier);
    dir := v2{cos(player.spinning_axe_angle), sin(player.spinning_axe_angle)};
    axe_pos := player.entity.world_position + dir * radius + v2{0, 0.35};
    now := get_time();
    frame := get_frame_number();

    backpack_full := count_item(player, log_defn) >= effective_backpack_capacity(player);
    hit_count: s64 = 0;
    found_blocked_tree := false;

    query_trees_near(player.entity.world_position, radius + contact_radius + 1.35, ref player.nearby_tree_cache);
    for tree: player.nearby_tree_cache {
        if tree == null continue;
        if tree.is_cut || tree.is_falling continue;
        if tree.target_frame == frame continue;
        if now - tree.last_spinning_axe_hit_at < spinning_axe_hit_cooldown(player.axe_tier) continue;
        if !spinning_axe_tree_in_hit_zone(player, tree, axe_pos, dir, radius, contact_radius) continue;

        if backpack_full {
            found_blocked_tree = true;
            continue;
        }

        tree.target_frame = frame;
        tree.last_spinning_axe_hit_at = now;
        tree.health_bar_until = now + 1.65;
        tree.health_bar_player = player;
        tree.start_chop(player, 0);
        hit_count += 1;
    }

    if backpack_full && found_blocked_tree && now >= player.spinning_axe_full_feedback_at {
        player.spinning_axe_full_feedback_at = now + 1.0;
        spawn_float_text_for_player(player, player.entity.world_position + v2{0, 1.55}, "Backpack full", {1.0, 0.12, 0.08, 1}, true);
        if player_local_feedback(player) {
            play_backpack_full_dud_sfx(player.entity.world_position);
        }
    }

    if hit_count > 0 {
        g_chop_successes += hit_count;
        g_observed_spinning_axe_hits += hit_count;
        player.swing_timer = 0.32;
        player.last_chop_time = now;
        player.camera_shake = max(player.camera_shake, axe_screen_shake(player.axe_tier));
        spawn_juice_particles(player.entity.world_position + v2{0, 0.65}, player.axe_tier, 1 + player.axe_tier, axe_tier_color(player.axe_tier), true);
    }
}

sawmill_feedback_position :: proc(from_pos: v2) -> v2 {
    best_pos := from_pos;
    best_d2 := 999999999.0;
    found := false;
    for sawmill: component_iterator(Lumber_Sawmill) {
        if sawmill == null continue;
        d2 := length_squared(sawmill.entity.world_position - from_pos);
        if !found || d2 < best_d2 {
            found = true;
            best_d2 = d2;
            best_pos = sawmill.entity.world_position;
        }
    }
    return best_pos;
}

polishing_feedback_position :: proc(from_pos: v2) -> v2 {
    best_pos := from_pos;
    best_d2 := 999999999.0;
    found := false;
    for polisher: component_iterator(Polishing_Machine) {
        if polisher == null continue;
        d2 := length_squared(polisher.entity.world_position - from_pos);
        if !found || d2 < best_d2 {
            found = true;
            best_d2 = d2;
            best_pos = polisher.entity.world_position;
        }
    }
    return best_pos;
}

queue_logs_at_sawmill :: proc(player: Player, sawmill: Lumber_Sawmill) -> bool {
    if player == null return false;
    if sawmill == null || !#alive(sawmill.entity) return false;
    sawmill_pos := sawmill.entity.world_position;
    queued := remove_item_count(player, log_defn, count_item(player, log_defn));
    if queued <= 0 return false;

    was_refining := player.refining;
    player.refining = true;
    if !was_refining {
        player.refine_timer = 0;
    }
    player.refine_logs_remaining += queued;
    player.refine_logs_total += queued;
    if !was_refining {
        start_sawmill_processing_loop(player, sawmill.entity, sawmill_process_time(player.sawmill_tier) * queued.(float) + 0.35);
    }
    if was_refining {
        player.dialogue_text = format_string("Queued +% logs", {queued});
    } else {
        player.dialogue_text = format_string("Sawing % logs...", {player.refine_logs_remaining});
    }
    player.dialogue_timer = 1.4;
    player.ui_pop_timer = 0.2;
    spawn_float_text_for_player(player, sawmill_pos + v2{0, 1.55}, format_string("+% logs", {queued}), {0.95, 0.82, 0.36, 1}, false);
    spawn_juice_particles_for_player(player, sawmill_pos + v2{0, 0.75}, 1, 5, {1.0, 0.75, 0.25, 0.50}, true);
    play_sawmill_log_queue_sfx(sawmill_pos);
    return true;
}

queue_planks_at_polishing_machine :: proc(player: Player, polisher: Polishing_Machine) -> bool {
    if player == null return false;
    if polisher == null || !#alive(polisher.entity) return false;
    if !player_has_alien_refiner(player) return false;
    polisher_pos := polisher.entity.world_position;
    queued := remove_item_count(player, plank_defn, count_item(player, plank_defn));
    if queued <= 0 return false;

    was_polishing := player.polishing;
    player.polishing = true;
    player.alien_refiner_flame_working = true;
    if !was_polishing {
        player.polish_timer = 0;
    }
    player.polish_planks_remaining += queued;
    player.polish_planks_total += queued;
    if !was_polishing {
        start_polishing_processing_loop(player, polisher.entity, polishing_process_time(player.sawmill_tier) * queued.(float) + 0.35);
    }
    if was_polishing {
        player.dialogue_text = format_string("Queued +% planks", {queued});
    } else {
        player.dialogue_text = format_string("Polishing % planks...", {player.polish_planks_remaining});
    }
    player.dialogue_timer = 1.4;
    player.ui_pop_timer = 0.2;
    spawn_float_text_for_player(player, polisher_pos + v2{0, 1.55}, format_string("+% planks", {queued}), {0.55, 1.0, 0.92, 1}, false);
    spawn_juice_particles_for_player(player, polisher_pos + v2{0, 0.75}, 2, 6, {0.42, 1.0, 0.88, 0.55}, true);
    play_polishing_start_sfx(polisher_pos);
    return true;
}

sell_planks_at_seller :: proc(player: Player, seller_pos: v2) -> bool {
    if player == null return false;
    if get_time() - player.last_sell_time < 0.8 return false;

    planks := count_item(player, plank_defn);
    alien_planks := count_item(player, alien_plank_defn);
    if planks <= 0 && alien_planks <= 0 return false;

    player.last_sell_time = get_time();
    removed := remove_item_count(player, plank_defn, planks);
    alien_removed := remove_item_count(player, alien_plank_defn, alien_planks);
    if removed <= 0 && alien_removed <= 0 return false;

    base_payout := removed * 12 + alien_removed * 24;
    payout := apply_rebirth_money_multiplier(player, base_payout);
    g_last_sell_payout = payout;
    Economy.deposit_currency(player, GOLD_CURRENCY, payout);
    player.has_sold_planks = true;
    save_player_progress(player);
    spawn_float_text_scaled_feedback_for_player(player, player.entity.world_position + v2{0, 1.5}, format_string("+% gold", {payout}), {0.35, 1.0, 0.25, 1}, true, 2.5);
    spawn_juice_particles_for_player(player, seller_pos + v2{0, 0.75}, 2, 10, {1.0, 0.84, 0.18, 0.70}, true);
    player.dialogue_text = "Best boards in town!";
    player.dialogue_timer = 2.0;
    player.ui_pop_timer = 0.25;
    play_sell_planks_sfx_for_player(player, seller_pos);
    return true;
}

update_auto_vendor_zones :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    now := get_time();
    if now < player.last_auto_zone_check_at + AUTO_ZONE_CHECK_SECONDS return;
    player.last_auto_zone_check_at = now;

    player_pos := player.entity.world_position;
    near_sawmill := false;
    near_seller := false;

    for sawmill: component_iterator(Lumber_Sawmill) {
        if sawmill == null continue;
        if length(sawmill.entity.world_position - player_pos) <= SAWMILL_AUTO_ZONE_RADIUS {
            near_sawmill = true;
            if count_item(player, log_defn) > 0 {
                queue_logs_at_sawmill(player, sawmill);
            }
            break;
        }
    }

    for polisher: component_iterator(Polishing_Machine) {
        if polisher == null continue;
        if length(polisher.entity.world_position - player_pos) <= POLISHING_MACHINE_AUTO_ZONE_RADIUS {
            if player_has_alien_refiner(player) && count_item(player, plank_defn) > 0 {
                queue_planks_at_polishing_machine(player, polisher);
            }
            break;
        }
    }

    for seller: component_iterator(Plank_Seller) {
        if seller == null continue;
        if length(seller.entity.world_position - player_pos) <= SELL_AUTO_ZONE_RADIUS {
            near_seller = true;
            if count_item(player, plank_defn) > 0 || count_item(player, alien_plank_defn) > 0 {
                sell_planks_at_seller(player, seller.entity.world_position);
            }
            break;
        }
    }

    g_observed_near_auto_sawmill_zone = near_sawmill;
    g_observed_near_auto_sell_zone = near_seller;
}

forest_cover_score_at :: proc(pos: v2, tree_cache: ref [..]Lumber_Tree) -> float {
    score := 0.0;
    query_radius_d2 := FOREST_CANOPY_QUERY_RADIUS * FOREST_CANOPY_QUERY_RADIUS;
    query_trees_near(pos, FOREST_CANOPY_QUERY_RADIUS, ref tree_cache);
    for tree: tree_cache {
        if tree == null continue;
        if tree.is_cut continue;
        if !#alive(tree.entity) continue;

        d2 := length_squared(tree.entity.world_position - pos);
        if d2 > query_radius_d2 continue;

        scale := max(abs(tree.entity.local_scale.x), abs(tree.entity.local_scale.y));
        canopy_radius := FOREST_CANOPY_BASE_RADIUS + scale * FOREST_CANOPY_SCALE_RADIUS;
        canopy_radius_d2 := canopy_radius * canopy_radius;
        if d2 <= canopy_radius_d2 {
            score += 1.0;
        } else {
            distance := sqrt(d2);
            falloff_span := max(0.1, FOREST_CANOPY_QUERY_RADIUS - canopy_radius);
            edge_t := clamp((FOREST_CANOPY_QUERY_RADIUS - distance) / falloff_span, 0.0, 1.0);
            score += edge_t * FOREST_CANOPY_EDGE_WEIGHT;
        }
    }
    return score;
}

forest_distance_slow_factor :: proc(pos: v2) -> float {
    span := max(1.0, FOREST_DISTANCE_SLOW_FULL - FOREST_DISTANCE_SLOW_START);
    linear := clamp((length(pos) - FOREST_DISTANCE_SLOW_START) / span, 0.0, 1.0);
    return pow(linear, 1.35);
}

forest_density_slow_factor :: proc(cover_score: float) -> float {
    span := max(1.0, FOREST_DENSE_COVER_SCORE - FOREST_SURROUNDED_COVER_SCORE);
    linear := clamp((cover_score - FOREST_SURROUNDED_COVER_SCORE) / span, 0.0, 1.0);
    return pow(linear, 1.55);
}

forest_axe_slow_reduction_scale :: proc(axe_tier: s64) -> float {
    tier_t := 0.0;
    if MAX_AXE_TIER > 1 {
        tier_t = clamp((clamp(axe_tier, 1, MAX_AXE_TIER) - 1).(float) / (MAX_AXE_TIER - 1).(float), 0.0, 1.0);
    }
    return lerp(1.0, 1.0 - FOREST_AXE_TIER_MAX_SLOW_RELIEF, tier_t);
}

forest_speed_multiplier :: proc(pos: v2, cover_score: float, axe_tier: s64) -> float {
    density_factor := forest_density_slow_factor(cover_score);
    if density_factor <= 0.0 return 1.0;

    distance_factor := forest_distance_slow_factor(pos);
    max_slow := lerp(FOREST_NEAR_MAX_SLOW, FOREST_FAR_MAX_SLOW, distance_factor);
    density_multiplier := clamp(1.0 - density_factor * max_slow, FOREST_MIN_SPEED_MULTIPLIER, 1.0);
    distance_cap := lerp(FOREST_NEAR_COVER_SPEED_CAP, FOREST_MIN_SPEED_MULTIPLIER, distance_factor);
    base_multiplier := min(density_multiplier, distance_cap);
    reduction := 1.0 - base_multiplier;
    reduction *= forest_axe_slow_reduction_scale(axe_tier);
    return clamp(1.0 - reduction, FOREST_MIN_SPEED_MULTIPLIER, 1.0);
}

apply_forest_density_slowdown :: proc(player: Player, dt: float) {
    if player == null return;
    if !#alive(player.entity) return;

    pos := player.entity.local_position;
    if player_tree_monster_rented(player) {
        speed_multiplier := 1.08;
        if player.agent != null {
            player.agent.movement_speed = PLAYER_DEFAULT_MOVEMENT_SPEED * speed_multiplier;
        }
        g_observed_forest_tree_count = 0;
        g_observed_forest_cover_score = 0.0;
        g_observed_forest_slowed = false;
        g_observed_forest_distance_factor = 0.0;
        g_observed_forest_speed_multiplier = speed_multiplier;
        return;
    }

    if player_helicopter_rented(player) {
        speed_multiplier := 1.0;
        if player_has_unlimited_move_speed(player) {
            speed_multiplier = 1.2;
        }
        if player.agent != null {
            player.agent.movement_speed = PLAYER_DEFAULT_MOVEMENT_SPEED * speed_multiplier;
        }
        g_observed_forest_tree_count = 0;
        g_observed_forest_cover_score = 0.0;
        g_observed_forest_slowed = false;
        g_observed_forest_distance_factor = 0.0;
        g_observed_forest_speed_multiplier = speed_multiplier;
        return;
    }

    cover_score := forest_cover_score_at(pos, ref player.nearby_tree_cache);
    speed_multiplier := forest_speed_multiplier(pos, cover_score, player.axe_tier);
    if player_has_unlimited_move_speed(player) {
        speed_multiplier = 1.2;
    }

    if player.agent != null {
        player.agent.movement_speed = PLAYER_DEFAULT_MOVEMENT_SPEED * speed_multiplier;
    }

    g_observed_forest_tree_count = cover_score.(s64);
    g_observed_forest_cover_score = cover_score;
    g_observed_forest_slowed = speed_multiplier < 0.999;
    g_observed_forest_distance_factor = forest_distance_slow_factor(pos);
    g_observed_forest_speed_multiplier = speed_multiplier;

    if get_time() >= player.forest_brush_feedback_at {
        if speed_multiplier < 0.75 {
            player.forest_brush_feedback_at = get_time() + 1.6;
            player.dialogue_text = "Thick brush";
            player.dialogue_timer = 0.9;
            play_positional_sfx("$AO/sfx/Footsteps/footstep_08.wav", pos, 0.18, 0.08);
        }
    }
}

tutorial_text_for_step :: proc(step: s64) -> string {
    switch step {
        case ONBOARDING_STEP_CUT_TREES: return "Walk into the forest to cut trees";
        case ONBOARDING_STEP_REFINE_LOGS: return "Refine your logs";
        case ONBOARDING_STEP_SELL_PLANKS: return "Sell your planks";
        case ONBOARDING_STEP_UPGRADE_AXE: return "Upgrade your axe";
        default: return "";
    }
}

tutorial_target_kind_for_step :: proc(player: Player, step: s64) -> string {
    switch step {
        case ONBOARDING_STEP_CUT_TREES: {
            if player != null && player.tutorial_tree_target != null && #alive(player.tutorial_tree_target.entity) return "tree";
            return "none";
        }
        case ONBOARDING_STEP_REFINE_LOGS: return "refiner";
        case ONBOARDING_STEP_SELL_PLANKS: return "seller";
        case ONBOARDING_STEP_UPGRADE_AXE: return "upgrades_ui";
        default: return "done";
    }
}

find_available_spawn_tree :: proc(player: Player) -> Lumber_Tree, bool {
    if player == null return null, false;

    spawn_pos := v2{0, 0};
    query_trees_near(spawn_pos, ONBOARDING_TREE_SEARCH_RADIUS, ref player.nearby_tree_cache);

    best: Lumber_Tree;
    best_d2 := 0.0;
    found := false;
    for tree: player.nearby_tree_cache {
        if tree == null continue;
        if !#alive(tree.entity) continue;
        if tree.is_cut || tree.is_falling continue;

        pos := tree_axe_collision_position(tree);
        d2 := length_squared(pos - spawn_pos);
        if !found || d2 < best_d2 {
            best = tree;
            best_d2 = d2;
            found = true;
        }
    }

    return best, found;
}

refresh_onboarding_tree_target :: proc(player: Player) {
    if player == null return;

    needs_target := player.tutorial_tree_target == null;
    if !needs_target {
        if !#alive(player.tutorial_tree_target.entity) {
            needs_target = true;
        } else if player.tutorial_tree_target.is_cut {
            needs_target = true;
        }
    }
    if !needs_target return;

    now := get_time();
    if now < player.tutorial_next_tree_search_at return;
    player.tutorial_next_tree_search_at = now + ONBOARDING_TREE_SEARCH_INTERVAL;

    tree, found := find_available_spawn_tree(player);
    if found {
        player.tutorial_tree_target = tree;
    } else {
        player.tutorial_tree_target = null;
    }
}

find_closest_sawmill_position :: proc(from_pos: v2) -> v2, bool {
    best_pos := v2{0, 0};
    best_d2 := 0.0;
    found := false;
    for sawmill: component_iterator(Lumber_Sawmill) {
        if sawmill == null continue;
        if !#alive(sawmill.entity) continue;
        d2 := length_squared(sawmill.entity.world_position - from_pos);
        if !found || d2 < best_d2 {
            best_pos = sawmill.entity.world_position;
            best_d2 = d2;
            found = true;
        }
    }
    return best_pos, found;
}

find_closest_seller_position :: proc(from_pos: v2) -> v2, bool {
    best_pos := v2{0, 0};
    best_d2 := 0.0;
    found := false;
    for seller: component_iterator(Plank_Seller) {
        if seller == null continue;
        if !#alive(seller.entity) continue;
        d2 := length_squared(seller.entity.world_position - from_pos);
        if !found || d2 < best_d2 {
            best_pos = seller.entity.world_position;
            best_d2 = d2;
            found = true;
        }
    }
    return best_pos, found;
}

onboarding_logs_needed_to_refine :: proc(player: Player) -> s64 {
    if player == null return ONBOARDING_FIRST_LOGS_TO_REFINE;
    if !player.has_sold_planks {
        return ONBOARDING_FIRST_LOGS_TO_REFINE;
    }

    remaining_gold := axe_upgrade_cost(1) - Economy.get_balance(player, GOLD_CURRENCY);
    if remaining_gold <= 0 return 0;

    needed := (remaining_gold + ONBOARDING_PLANK_SELL_VALUE - 1) / ONBOARDING_PLANK_SELL_VALUE;
    return max(1, needed);
}

determine_onboarding_step :: proc(player: Player) -> s64 {
    if player == null return ONBOARDING_STEP_DONE;
    if player.axe_tier > 1 return ONBOARDING_STEP_DONE;
    if Economy.get_balance(player, GOLD_CURRENCY) >= axe_upgrade_cost(1) return ONBOARDING_STEP_UPGRADE_AXE;

    planks := count_item(player, plank_defn);
    alien_planks := count_item(player, alien_plank_defn);
    if !player.refining && (planks > 0 || alien_planks > 0) return ONBOARDING_STEP_SELL_PLANKS;

    logs := count_item(player, log_defn);
    if player.refining || logs >= onboarding_logs_needed_to_refine(player) return ONBOARDING_STEP_REFINE_LOGS;

    return ONBOARDING_STEP_CUT_TREES;
}

tutorial_completion_celebrate :: proc(player: Player) {
    if player == null return;
    if player.tutorial_completion_celebrated return;

    player.tutorial_completion_celebrated = true;
    player.dialogue_text = "Good luck out there, it gets dangerous!";
    player.dialogue_timer = 4.0;
    player.ui_pop_timer = 0.35;
    spawn_float_text_for_player(player, player.entity.world_position + v2{0, 1.75}, "Good luck!", {1.0, 0.86, 0.18, 1}, true);
    spawn_juice_particles_for_player(player, player.entity.world_position + v2{0, 0.9}, 3, 22, {1.0, 0.82, 0.18, 0.82}, true);
    play_purchase_item_sfx(player);
    save_player_progress(player);
}

update_onboarding_tutorial :: proc(player: Player) {
    if player == null return;

    previous_step := player.onboarding_step;
    player.onboarding_step = determine_onboarding_step(player);

    if player.onboarding_step == ONBOARDING_STEP_CUT_TREES {
        refresh_onboarding_tree_target(player);
    } else {
        player.tutorial_tree_target = null;
    }

    if player.onboarding_step != previous_step {
        save_player_progress(player);
    }
    if player.onboarding_step == ONBOARDING_STEP_DONE {
        tutorial_completion_celebrate(player);
    }

    g_observed_tutorial_step = player.onboarding_step;
    g_observed_tutorial_text = tutorial_text_for_step(player.onboarding_step);
    g_observed_tutorial_target_kind = tutorial_target_kind_for_step(player, player.onboarding_step);
}

set_axe_level :: proc(player: Player, level: s64 = MAX_AXE_TIER) {
    if player == null return;
    player.axe_tier = clamp(level, 1, MAX_AXE_TIER);
    save_player_progress(player);
    player.dialogue_text = format_string("Axe level %", {player.axe_tier});
    player.dialogue_timer = 1.5;
    player.ui_pop_timer = 0.25;
    spawn_float_text(player.entity.world_position + v2{0, 1.5}, format_string("Axe: %", {player.axe_tier}), axe_tier_color(player.axe_tier), true);
} @chat_command

set_infinite_backpack_state :: proc(player: Player, enabled: bool) {
    if player == null return;
    player.infinite_backpack = enabled;
    save_player_progress(player);
    if enabled {
        player.dialogue_text = "Infinite backpack";
        spawn_float_text(player.entity.world_position + v2{0, 1.5}, "Infinite backpack", {0.62, 0.88, 1.0, 1}, true);
    } else {
        player.dialogue_text = "Backpack normal";
        spawn_float_text(player.entity.world_position + v2{0, 1.5}, "Backpack normal", {0.62, 0.88, 1.0, 1}, true);
    }
    player.dialogue_timer = 1.5;
    player.ui_pop_timer = 0.25;
}

infinite_backpack :: proc(player: Player, enabled: bool = true) {
    set_infinite_backpack_state(player, enabled);
} @chat_command

infinite_bag :: proc(player: Player, enabled: bool = true) {
    set_infinite_backpack_state(player, enabled);
} @chat_command

set_coins :: proc(player: Player, amount: s64 = 10000) {
    if player == null return;
    amount = max(0, amount);
    current := Economy.get_balance(player, GOLD_CURRENCY);
    if current < amount {
        Economy.deposit_currency(player, GOLD_CURRENCY, amount - current);
    } else if current > amount {
        Economy.withdraw_currency(player, GOLD_CURRENCY, current - amount);
    }
    player.dialogue_text = format_string("Gold: %", {amount});
    player.dialogue_timer = 1.5;
    spawn_float_text(player.entity.world_position + v2{0, 1.5}, format_string("Gold: %", {amount}), {1.0, 0.86, 0.18, 1}, true);
} @chat_command

give_coins :: proc(player: Player, amount: s64 = 1000) {
    if player == null return;
    if amount <= 0 return;
    Economy.deposit_currency(player, GOLD_CURRENCY, amount);
    player.dialogue_text = format_string("+% gold", {amount});
    player.dialogue_timer = 1.5;
    spawn_float_text(player.entity.world_position + v2{0, 1.5}, format_string("+% gold", {amount}), {1.0, 0.86, 0.18, 1}, true);
} @chat_command

clear_player_gold :: proc(player: Player) {
    if player == null return;
    current_gold := Economy.get_balance(player, GOLD_CURRENCY);
    if current_gold > 0 {
        Economy.withdraw_currency(player, GOLD_CURRENCY, current_gold);
    }
}

reset_core_progress_for_rebirth :: proc(player: Player) {
    if player == null return;

    if player.default_inventory != null {
        Items.destroy_all_items(player.default_inventory);
    }
    clear_player_gold(player);

    player.axe_tier = 1;
    player.sawmill_tier = 1;
    player.backpack_tier = 1;
    player.infinite_backpack = false;
    player.alien_refiner_unlocked = player_has_alien_refiner(player);
    player.has_sold_planks = false;
    player.onboarding_step = 0;
    player.tutorial_completion_celebrated = false;
    player.tutorial_tree_target = null;
    player.tutorial_next_tree_search_at = 0;
    player.refining = false;
    player.polishing = false;
    player.alien_refiner_flame_working = false;
    player.refine_timer = 0;
    player.refine_logs_remaining = 0;
    player.refine_logs_total = 0;
    player.polish_timer = 0;
    player.polish_planks_remaining = 0;
    player.polish_planks_total = 0;
    player.auto_refine_timer = 0;
    player.show_upgrade_shop = false;
    player.show_rebirth_confirm = false;
    player.show_exit_helicopter_confirm = false;
    player.helicopter_auto_fly = false;
    stop_sawmill_processing_loop(player);
    stop_polishing_processing_loop(player);
}

perform_rebirth :: proc(player: Player) -> bool {
    if player == null return false;
    next_level := next_rebirth_level(player);
    if next_level <= 0 return false;

    cost := rebirth_cost(next_level);
    if !Economy.can_withdraw_currency(player, GOLD_CURRENCY, cost) {
        player.dialogue_text = format_string("Need % gold", {cost});
        player.dialogue_timer = 1.4;
        play_backpack_full_dud_sfx(player.entity.world_position);
        return false;
    }

    if player_helicopter_rented(player) {
        player.helicopter_rental.finish_rental(false);
    }
    if player_tree_monster_rented(player) {
        player.tree_monster_rental.finish_rental(false);
    }
    finish_player_bacteria_takeover(player, false);

    player.rebirth_level = next_level;
    reset_core_progress_for_rebirth(player);
    save_player_progress(player);

    player.dialogue_text = format_string("Rebirth %", {player.rebirth_level});
    player.dialogue_timer = 1.8;
    player.ui_pop_timer = 0.35;
    spawn_float_text(player.entity.world_position + v2{0, 1.55}, format_string("Rebirth %", {player.rebirth_level}), {0.55, 1.0, 0.92, 1}, true);
    spawn_juice_particles(player.entity.world_position + v2{0, 0.8}, 4 + player.rebirth_level, 24, {0.55, 1.0, 0.92, 0.85}, true);
    play_purchase_item_sfx(player);
    return true;
}

reset :: proc(player: Player) {
    if player == null return;

    if player_helicopter_rented(player) {
        player.helicopter_rental.finish_rental(false);
    }
    if player_tree_monster_rented(player) {
        player.tree_monster_rental.finish_rental(false);
    }
    finish_player_bacteria_takeover(player, false);

    if player.default_inventory != null {
        Items.destroy_all_items(player.default_inventory);
    }
    Economy.delete_save_data(player);
    clear_player_gold(player);
    Save.delete_all_keys(player);

    player.rebirth_level = 0;
    player.axe_tier = 1;
    player.sawmill_tier = 1;
    player.backpack_tier = 1;
    player.infinite_backpack = false;
    player.owns_auto_sawmill = false;
    player.owns_unlimited_backpack_product = false;
    player.owns_unlimited_move_speed_product = false;
    player.alien_refiner_unlocked = false;
    player.has_sold_planks = false;
    player.onboarding_step = 0;
    player.tutorial_completion_celebrated = false;
    player.tutorial_tree_target = null;
    player.tutorial_next_tree_search_at = 0;
    player.refining = false;
    player.polishing = false;
    player.alien_refiner_flame_working = false;
    player.refine_timer = 0;
    player.refine_logs_remaining = 0;
    player.refine_logs_total = 0;
    player.auto_refine_timer = 0;
    player.show_upgrade_shop = false;
    player.show_upgrades_menu = false;
    player.show_rebirth_confirm = false;
    player.show_exit_helicopter_confirm = false;
    player.helicopter_auto_fly = false;
    save_player_progress(player);

    player.dialogue_text = "Progress reset";
    player.dialogue_timer = 1.8;
    player.ui_pop_timer = 0.25;
    spawn_float_text(player.entity.world_position + v2{0, 1.5}, "Progress reset", {1.0, 0.35, 0.25, 1}, true);
} @chat_command

set_spinning_axe_mode :: proc(player: Player, enabled: bool = true) {
    g_spinning_axe_mode = enabled;
    if player != null {
        if enabled {
            player.dialogue_text = "Spinning axe on";
            spawn_float_text(player.entity.world_position + v2{0, 1.5}, "Spin axe", axe_tier_color(player.axe_tier), true);
        } else {
            player.dialogue_text = "Chop mode on";
            spawn_float_text(player.entity.world_position + v2{0, 1.5}, "Chop axe", axe_tier_color(player.axe_tier), true);
        }
        player.dialogue_timer = 1.4;
        play_positional_sfx("$AO/sfx/FUI Holo Mechanism Activate.wav", player.entity.world_position, 0.18, 0.04);
    }
} @chat_command

toggle_spinning_axe_mode :: proc(player: Player) {
    set_spinning_axe_mode(player, !g_spinning_axe_mode);
} @chat_command

tam :: proc(player: Player) {
    set_spinning_axe_mode(player, !g_spinning_axe_mode);
} @chat_command

set_game_message :: proc(player: Player, message: string = "") {
    Save.set_game_string(GLOBAL_TOP_MESSAGE_SAVE_KEY, message);
    if player == null return;

    if message.count > 0 {
        player.dialogue_text = "Message set";
    } else {
        player.dialogue_text = "Message cleared";
    }
    player.dialogue_timer = 1.4;
} @chat_command

Chop_Ability :: class : Ability_Base {
    on_init :: method() {
        name = "Chop";
        icon = get_asset(Texture_Asset, "Axe Icon_2c9119.png");
        keybind_override = chop_keybind;
    }

    can_use :: method() -> bool {
        if spinning_axe_mode_enabled() return false;
        if player_helicopter_rented(player) return false;
        if player_bacteria_takeover_active(player) return false;
        return true;
    }

    on_update :: method(params: ref Ability_Update_Params) {
        if params.clicked {
            player.chop_request += 1;
        }
    }

    on_draw_button :: method(rect: Rect) {
        p := player;
        if p == null return;
        ts := UI.default_text_settings();
        ts.size = 24;
        ts.halign = .RIGHT;
        ts.valign = .BOTTOM;
        ts.color = {1.0, 0.94, 0.72, 1};
        UI.text(rect.inset(7), ts, "Tier: %", {max(1, p.axe_tier)});
        ring_color := axe_tier_color(p.axe_tier);
        UI.wire_box(rect.min + v2{6, 6}, rect.max - v2{6, 6}, 0.05 + p.axe_tier.(float) * 0.008, ring_color);
    }
}

Exit_Helicopter_Ability :: class : Ability_Base {
    on_init :: method() {
        name = "Exit Heli";
        icon = get_asset(Texture_Asset, "Axe Icon_2c9119.png");
    }

    can_use :: method() -> bool {
        return player_helicopter_rented(player);
    }

    on_update :: method(params: ref Ability_Update_Params) {
        if params.clicked && params.can_use {
            player.show_exit_helicopter_confirm = true;
            current_cooldown = 0.25;
        }
    }

    on_draw_button :: method(rect: Rect) {
        ts := UI.default_text_settings();
        ts.size = 26;
        ts.halign = .CENTER;
        ts.valign = .CENTER;
        ts.color = {1.0, 0.94, 0.72, 1};
        UI.text(rect.inset(5), ts, "Exit");
    }
}

Auto_Fly_Helicopter_Ability :: class : Ability_Base {
    on_init :: method() {
        name = "Auto Fly";
        icon = get_asset(Texture_Asset, "Axe Icon_2c9119.png");
    }

    can_use :: method() -> bool {
        return player_helicopter_rented(player);
    }

    on_update :: method(params: ref Ability_Update_Params) {
        if params.clicked && params.can_use {
            player.helicopter_auto_fly = !player.helicopter_auto_fly;
            if player.helicopter_auto_fly {
                player.dialogue_text = "Auto fly on.";
            } else {
                player.dialogue_text = "Auto fly off.";
            }
            player.dialogue_timer = 1.0;
            if player.is_local() play_ui_sfx("click_6d65ee.wav", 0.16, 0.02);
            current_cooldown = 0.25;
        }
    }

    on_draw_button :: method(rect: Rect) {
        p := player;
        ts := UI.default_text_settings();
        ts.size = 22;
        ts.halign = .CENTER;
        ts.valign = .CENTER;
        ts.color = {1.0, 0.94, 0.72, 1};
        label := "Auto";
        if p != null && p.helicopter_auto_fly label = "Auto On";
        UI.text(rect.inset(5), ts, label);
    }
}

// Per player state
Player :: class : Player_Base {
    rebirth_level: s64 @ao_serialize;
    axe_tier: s64 @ao_serialize;
    show_upgrade_shop: bool @ao_serialize;
    show_upgrades_menu: bool @ao_serialize;
    show_rebirth_confirm: bool @ao_serialize;
    sawmill_tier: s64 @ao_serialize;
    backpack_tier: s64 @ao_serialize;
    infinite_backpack: bool @ao_serialize;
    owns_auto_sawmill: bool @ao_serialize;
    owns_unlimited_backpack_product: bool @ao_serialize;
    owns_unlimited_move_speed_product: bool @ao_serialize;
    alien_refiner_unlocked: bool @ao_serialize;
    refine_timer: float;
    auto_refine_timer: float;
    polish_timer: float;
    refining: bool;
    polishing: bool;
    alien_refiner_flame_working: bool @ao_serialize;
    refine_logs_remaining: s64;
    refine_logs_total: s64;
    polish_planks_remaining: s64;
    polish_planks_total: s64;
    swing_timer: float;
    camera_shake: float;
    last_chop_time: float;
    onboarding_step: s64;
    dialogue_timer: float;
    dialogue_text: string;
    ui_pop_timer: float;
    last_sell_time: float;
    last_auto_zone_check_at: float;
    has_sold_planks: bool @ao_serialize;
    tutorial_completion_celebrated: bool @ao_serialize;
    chop_request: s64;
    processed_chop_request: s64;
    forest_brush_feedback_at: float;
    navmesh_lock_applied: bool;
    helicopter_rental: Rentable_Helicopter;
    tree_monster_rental: Rentable_Tree_Monster;
    bacteria_takeover: Bacteria_Monster;
    axe_visual_entity: Entity;
    axe_visual_sprite: Sprite_Renderer;
    axe_visual_material_level: s64;
    show_exit_helicopter_confirm: bool @ao_serialize;
    helicopter_auto_fly: bool @ao_serialize;
    spinning_axe_angle: float;
    spinning_axe_full_feedback_at: float;
    sawmill_processing_sound_id: u64;
    sawmill_processing_loop_active: bool;
    polishing_processing_sound_id: u64;
    polishing_processing_loop_active: bool;
    bacteria_tag_flash_until: float;
    nearby_tree_cache: [..]Lumber_Tree;
    tutorial_tree_target: Lumber_Tree;
    tutorial_next_tree_search_at: float;

    ao_start :: method() {
        if axe_tier <= 0 axe_tier = 1;
        if sawmill_tier <= 0 sawmill_tier = 1;
        if backpack_tier <= 0 backpack_tier = 1;
        if backpack_tier > MAX_BACKPACK_TIER backpack_tier = MAX_BACKPACK_TIER;
        onboarding_step = 0;
        load_player_progress(this);
        navmesh_lock_applied = lock_player_to_world_navmesh(this);
        create_player_axe_visual(this);

        if (is_local()) {
            asset := get_asset(SFX_Asset, GAME_START_MUSIC);
            desc := SFX.default_sfx_desc();
            desc.specific_to_player = this;
            desc.loop = true;
            desc.volume = GAME_START_MUSIC_VOLUME;
            desc.channel = .MUSIC;
            g_game_start_music_sound_id = SFX.play(asset, desc);
        }
    }

    ao_update :: method(dt: float) {
        if !navmesh_lock_applied {
            navmesh_lock_applied = lock_player_to_world_navmesh(this);
        }
        update_helicopter_auto_fly(this, dt);
        update_spinning_axe(this, dt);
        update_player_axe_visual(this);
        apply_forest_density_slowdown(this, dt);

        if swing_timer > 0 swing_timer -= dt;
        if camera_shake > 0 camera_shake = max(0.0, camera_shake - dt * 1.6);
        if dialogue_timer > 0 dialogue_timer -= dt;
        if ui_pop_timer > 0 ui_pop_timer -= dt;
        g_observed_logs = count_item(this, log_defn);
        g_observed_planks = count_item(this, plank_defn);
        g_observed_alien_planks = count_item(this, alien_plank_defn);
        g_observed_axe_tier = axe_tier;
        g_observed_sawmill_tier = sawmill_tier;
        g_observed_backpack_tier = backpack_tier;
        g_observed_backpack_capacity = effective_backpack_capacity(this);
        g_observed_show_upgrades_menu = show_upgrades_menu;
        g_observed_show_rebirth_menu = show_rebirth_confirm;
        g_observed_refining = refining;
        g_observed_near_tree_count = nearest_tree_count(this);
        g_observed_rebirth_level = player_rebirth_level(this);
        g_observed_next_rebirth_cost = next_rebirth_cost(this);
        g_observed_rebirth_money_multiplier = rebirth_money_multiplier(this);
        g_observed_polisher_unlocked = player_has_alien_refiner(this);
        g_observed_helicopter_unlocked = player_can_use_helicopter(this);
        g_observed_tree_monster_unlocked = player_can_use_tree_monster(this);
        g_observed_haunts_forest = player_haunts_forest(this);
        g_observed_bacteria_takeover_active = player_bacteria_takeover_active(this);
        g_observed_axe_damage = axe_damage(axe_tier);
        g_observed_axe_hits_to_chop = axe_hits_to_chop(axe_tier);
        g_observed_axe_radius = axe_chop_radius(axe_tier);
        g_observed_spinning_axe_mode = spinning_axe_mode_enabled();
        g_observed_spinning_axe_radius = spinning_axe_orbit_radius(axe_tier);
        g_observed_spinning_axe_damage = axe_damage(axe_tier);
        g_observed_spinning_axe_visual_scale = spinning_axe_visual_scale(axe_tier);
        g_observed_sawmill_auto_time = sawmill_auto_process_time(sawmill_tier);
        g_observed_auto_product_id = AUTO_SAWMILL_PRODUCT_ID;
        g_observed_bottom_left_hud_height = stats_hud_rect().height();
        g_observed_sawmill_progress = 0.0;
        if refining {
            g_observed_sawmill_progress = clamp(refine_timer / sawmill_process_time(sawmill_tier), 0.0, 1.0);
        } else if player_has_auto_sawmill(this) && count_item(this, log_defn) > 0 {
            g_observed_sawmill_progress = clamp(auto_refine_timer / sawmill_auto_process_time(sawmill_tier), 0.0, 1.0);
        }

        if chop_request > processed_chop_request {
            processed_chop_request = chop_request;
            if !spinning_axe_mode_enabled() && get_time() - last_chop_time > 0.15 {
                try_start_chop(this);
            }
        }

        if show_upgrade_shop {
            near_shop := false;
            for shop: component_iterator(Axe_Shop_NPC) {
                if length(shop.entity.world_position - entity.world_position) <= 4.0 near_shop = true;
            }
            if !near_shop show_upgrade_shop = false;
        }

        update_auto_vendor_zones(this);

        if refining {
            refine_timer += dt;
            process_time := sawmill_process_time(sawmill_tier);
            if refine_timer >= process_time {
                refine_timer = 0;
                if refine_logs_remaining > 0 {
                    refine_logs_remaining -= 1;
                    give_item(this, plank_defn, 1);
                    feedback_pos := sawmill_feedback_position(entity.world_position);
                    spawn_float_text_for_player(this, feedback_pos + v2{0, 1.6}, "+1 plank", {0.95, 0.72, 0.32, 1}, true);
                    spawn_juice_particles_for_player(this, feedback_pos + v2{0, 0.9}, 1, 5, {1.0, 0.75, 0.25, 0.65}, true);
                    if refine_logs_remaining <= 0 {
                        refining = false;
                        refine_logs_remaining = 0;
                        refine_logs_total = 0;
                        stop_sawmill_processing_loop(this);
                        dialogue_text = "Fresh planks! Sell them.";
                        dialogue_timer = 1.8;
                    }
                    ui_pop_timer = 0.25;
                } else {
                    refining = false;
                    refine_logs_remaining = 0;
                    refine_logs_total = 0;
                    stop_sawmill_processing_loop(this);
                }
            }
        }

        if polishing {
            polish_timer += dt;
            process_time := polishing_process_time(sawmill_tier);
            if polish_timer >= process_time {
                polish_timer = 0;
                if polish_planks_remaining > 0 {
                    polish_planks_remaining -= 1;
                    give_item(this, alien_plank_defn, 1);
                    feedback_pos := polishing_feedback_position(entity.world_position);
                    spawn_float_text_for_player(this, feedback_pos + v2{0, 1.6}, "+1 alien plank", {0.42, 1.0, 0.88, 1}, true);
                    spawn_juice_particles_for_player(this, feedback_pos + v2{0, 0.9}, 2, 6, {0.42, 1.0, 0.88, 0.70}, true);
                    play_polishing_finish_sfx(feedback_pos);
                    if polish_planks_remaining <= 0 {
                        polishing = false;
                        alien_refiner_flame_working = false;
                        polish_planks_remaining = 0;
                        polish_planks_total = 0;
                        stop_polishing_processing_loop(this);
                        dialogue_text = "Alien planks ready.";
                        dialogue_timer = 1.8;
                    }
                    ui_pop_timer = 0.25;
                } else {
                    polishing = false;
                    alien_refiner_flame_working = false;
                    polish_planks_remaining = 0;
                    polish_planks_total = 0;
                    stop_polishing_processing_loop(this);
                }
            }
        }

        if !refining && player_has_auto_sawmill(this) && count_item(this, log_defn) > 0 {
            auto_refine_timer += dt;
            process_time := sawmill_auto_process_time(sawmill_tier);
            if auto_refine_timer >= process_time {
                auto_refine_timer = 0;
                removed := remove_item_count(this, log_defn, 1);
                if removed > 0 {
                    give_item(this, plank_defn, 1);
                    ui_pop_timer = 0.2;
                    feedback_pos := sawmill_feedback_position(entity.world_position);
                    spawn_float_text_for_player(this, feedback_pos + v2{0, 1.45}, "+1 plank", {0.95, 0.72, 0.32, 1}, false);
                    spawn_juice_particles_for_player(this, feedback_pos + v2{0, 0.9}, 1, 3, {1.0, 0.75, 0.25, 0.45}, true);
                }
            }
        } else {
            auto_refine_timer = 0;
        }

        update_onboarding_tutorial(this);
    }

    ao_late_update :: method(dt: float) {
        if !#alive(entity) return;
        if is_local() && camera_shake > 0 {
            rng := rng_root_seed() + get_frame_number();
            camera.position.x += rng_range_float(ref rng, -camera_shake, camera_shake);
            camera.position.y += rng_range_float(ref rng, -camera_shake, camera_shake);
        }
        if is_local() && bacteria_tag_flash_until > get_time() {
            draw_bacteria_tag_post_fx(this);
        }

        if is_local_or_server() {
            if !spinning_axe_mode_enabled() && !player_bacteria_takeover_active(this) {
                draw_ability_button(this, Chop_Ability, 0);
            }
            if player_helicopter_rented(this) {
                draw_ability_button(this, Exit_Helicopter_Ability, 1);
                draw_ability_button(this, Auto_Fly_Helicopter_Ability, 2);
            }
            draw_lumber_inventory(this);
            draw_lumber_topbar(this);
            draw_rebirth_hud_button(this);
            draw_global_top_message(this);
            draw_lumber_world_overlays(this);
            if show_upgrades_menu {
                draw_upgrades_menu(this);
            }
            if show_exit_helicopter_confirm {
                draw_exit_helicopter_confirm(this);
            }
            if show_rebirth_confirm {
                draw_rebirth_confirm(this);
            }
        }
    }

    ao_end :: method() {
        finish_player_bacteria_takeover(this, false);
        stop_sawmill_processing_loop(this);
        stop_polishing_processing_loop(this);
        if axe_visual_entity != null && #alive(axe_visual_entity) {
            axe_visual_entity.destroy();
        }
    }

    ao_can_use_ability :: method(ability: Ability_Base) -> bool {
        return true;
    }

    ao_can_use_interactable :: method(interactable: Interactable) -> bool {
        return true;
    }
}

Lumber_Tree :: class : Component {
    tree_level: s64 @ao_serialize;
    original_pos: v2;
    original_scale: v2;
    is_cut: bool;
    is_falling: bool;
    target_frame: u64;
    regrow_at: float;
    fall_age: float;
    fall_delay: float;
    fall_dir: float;
    reward_tier: s64;
    health: s64;
    will_fall: bool;
    chopping_player: Player;
    thumped: bool;
    impact_spawned: bool;
    fall_anim_started: bool;
    sprite: Sprite_Renderer;
    spine_entity: Entity;
    animator: Spine_Animator;
    last_spinning_axe_hit_at: float;
    health_bar_until: float;
    health_bar_flash_until: float;
    health_bar_player: Player;

    ao_start :: method() {
        if tree_level <= 0 tree_level = 1;
        if tree_level > MAX_TREE_LEVEL tree_level = MAX_TREE_LEVEL;
        original_pos = entity.local_position;
        original_scale = v2{TREE_SPINE_ENTITY_SCALE, TREE_SPINE_ENTITY_SCALE};
        health = max_health();
        last_spinning_axe_hit_at = -SPINNING_AXE_TREE_HIT_COOLDOWN;
        setup_tree_idle_sprite();
        show_tree_idle_sprite();
        tree_grid_mark_dirty();
    }

    max_health :: method() -> s64 {
        if tree_level <= 0 tree_level = 1;
        return TREE_HEALTH * tree_level_health_multiplier(tree_level);
    }

    setup_tree_idle_sprite :: method() {
        sprite = entity.get_component(Sprite_Renderer);
        if sprite == null {
            sprite = entity.add_component(Sprite_Renderer);
        }
        if tree_idle_texture != null {
            sprite.set_texture(tree_idle_texture);
        }
        sprite.depth_offset = TREE_IDLE_DEPTH_OFFSET;
        sprite.layer = 0;
        sprite.scale = v2{1, 1};
        mat := tree_level_material(tree_level);
        if mat != null {
            sprite.set_material(mat, false);
            sprite.color = {1, 1, 1, 1};
        } else {
            sprite.color = tree_level_fallback_tint(tree_level);
        }
    }

    show_tree_idle_sprite :: method() {
        if sprite == null setup_tree_idle_sprite();
        if sprite != null {
            sprite.set_enabled(true);
        }
        destroy_tree_spine_visual();
        entity.set_local_position(original_pos + TREE_IDLE_SPRITE_POSITION_OFFSET);
        entity.set_local_scale(v2{TREE_IDLE_ENTITY_SCALE, TREE_IDLE_ENTITY_SCALE});
    }

    show_tree_spine :: method() {
        if sprite != null {
            sprite.set_enabled(false);
        }
        if animator != null {
            animator.set_enabled(true);
        }
        entity.set_local_position(original_pos);
        entity.set_local_scale(original_scale);
        update_tree_spine_depth_offset();
    }

    hide_tree_visuals :: method() {
        if sprite != null {
            sprite.set_enabled(false);
        }
        destroy_tree_spine_visual();
    }

    destroy_tree_spine_visual :: method() {
        if #alive(spine_entity) {
            spine_entity.destroy();
        }
        spine_entity = null;
        animator = null;
    }

    update_tree_spine_depth_offset :: method() {
        if animator == null return;
        animator.depth_offset = tree_spine_depth_offset_for_scale(entity.local_scale);
    }

    setup_tree_spine :: method() {
        setup_tree_idle_sprite();
        if !#alive(spine_entity) {
            spine_entity = Scene.create_entity();
            spine_entity.set_name("Tree_Temporary_Spine_Visual");
            spine_entity.set_parent(entity, false);
            spine_entity.set_local_position(v2{0, 0});
            spine_entity.set_local_rotation(0);
            spine_entity.set_local_scale(v2{1, 1});
            animator = spine_entity.add_component(Spine_Animator);
        } else {
            animator = spine_entity.get_component(Spine_Animator);
            if animator == null {
                animator = spine_entity.add_component(Spine_Animator);
            }
        }
        animator.set_enabled(true);
        animator.awaken();
        animator.set_skeleton(tree_spine_asset);
        update_tree_spine_depth_offset();
        animator.set_skin("default");
        animator.refresh_skins();
        animator.layer = 0;
        animator.scale = v2{1, 1};
        mat := tree_level_material(tree_level);
        if mat != null {
            animator.set_material(mat, false);
            animator.color_multiplier = {1, 1, 1, 1};
        } else {
            animator.color_multiplier = tree_level_fallback_tint(tree_level);
        }
        animator.set_animation("idle", true, 0);
    }

    force_respawn :: method() {
        is_cut = false;
        is_falling = false;
        thumped = false;
        impact_spawned = false;
        fall_anim_started = false;
        will_fall = false;
        fall_age = 0;
        health = max_health();
        chopping_player = null;
        health_bar_player = null;
        health_bar_until = 0;
        health_bar_flash_until = 0;
        last_spinning_axe_hit_at = -SPINNING_AXE_TREE_HIT_COOLDOWN;
        entity.set_local_position(original_pos);
        entity.set_local_rotation(0);
        entity.set_local_scale(original_scale * 0.2);
        setup_tree_idle_sprite();
        show_tree_idle_sprite();
    }

    start_chop :: method(player: Player, start_delay: float) {
        damage := axe_damage(player.axe_tier);
        is_crit := roll_axe_crit(player, this);
        if is_crit {
            damage *= 4;
        }
        start_chop_damage(player, start_delay, damage, is_crit);
    }

    start_chop_damage :: method(player: Player, start_delay: float, damage: s64, is_crit: bool = false) {
        if is_cut || is_falling return;
        if animator == null setup_tree_spine();
        show_tree_spine();
        tree_health := max_health();
        if health <= 0 health = tree_health;
        health = max(0, health - damage);
        will_fall = health <= 0;
        is_falling = true;
        fall_age = -start_delay;
        fall_delay = start_delay;
        thumped = false;
        impact_spawned = false;
        fall_anim_started = false;
        reward_tier = max(1, player.axe_tier);
        chopping_player = player;
        fall_dir = 1.0;
        if player != null && player.entity.world_position.x > entity.world_position.x fall_dir = -1.0;
        if player != null player.camera_shake = max(player.camera_shake, axe_screen_shake(player.axe_tier));
        animator.set_animation("chop", false, 0);
        animator.scale = v2{fall_dir, 1};
        spawn_juice_particles_for_player(player, entity.world_position + v2{0, 0.8}, reward_tier, 4 + reward_tier, {0.35, 0.95, 0.22, 0.55}, false);
        if is_crit {
            spawn_float_text_scaled_feedback_for_player(player, entity.world_position + v2{0, 1.45}, "CRIT!", {0.18, 0.72, 1.0, 1}, true, 1.45);
            spawn_juice_particles_for_player(player, entity.world_position + v2{0, 0.95}, reward_tier, 5 + reward_tier, {0.18, 0.72, 1.0, 0.65}, true);
        }
        if player_local_feedback(player) {
            play_positional_sfx("cm_shake_tree_e69bfc.wav", entity.world_position, 0.24, 0.18);
            if will_fall {
                play_positional_sfx_speed("wood_chop_1c256a.wav", entity.world_position, 0.20, 0.70, 0.03);
            }
        }
        if !will_fall || damage < tree_health {
            health_bar_until = get_time() + 1.65;
            health_bar_flash_until = get_time() + 0.12;
            health_bar_player = player;
            if !spinning_axe_mode_enabled() {
                hit_numerator := tree_health - health;
                hit_progress := clamp(hit_numerator.(float) / max(1, tree_health).(float), 0.0, 1.0);
                hit_text_scale := lerp(1.0, 2.0, hit_progress);
                spawn_float_text_scaled_feedback_for_player(player, entity.world_position + v2{0, 1.0}, format_string("%/%", {hit_numerator, tree_health}), {0.9, 0.68, 0.36, 1}, false, hit_text_scale);
            }
        }
    }

    ao_update :: method(dt: float) {
        if is_falling {
            fall_age += dt;
            if fall_age < 0 return;

            // Tactile sequence: wind-up shake, axe impact chips, wobble, fall, ground thump.
            if fall_age < 0.16 {
                wobble := sin(fall_age * 58.0) * 2.5;
                entity.set_local_rotation(wobble);
                entity.set_local_scale(original_scale * (1.0 + fall_age * 0.35));
                update_tree_spine_depth_offset();
                return;
            }

            if fall_age >= 0.16 && !impact_spawned {
                impact_spawned = true;
                spawn_chip_for_player(chopping_player, entity.world_position + v2{0, 0.35}, reward_tier);
                spawn_juice_particles_for_player(chopping_player, entity.world_position + v2{0, 0.75}, reward_tier, 5 + reward_tier, axe_tier_color(reward_tier), true);
                if player_local_feedback(chopping_player) {
                    play_positional_sfx("wood_chop_1c256a.wav", entity.world_position, 0.62, 0.12);
                }
            }

            if !will_fall && fall_age >= 0.18 {
                is_falling = false;
                entity.set_local_position(original_pos);
                entity.set_local_rotation(0);
                entity.set_local_scale(original_scale);
                update_tree_spine_depth_offset();
                if animator != null {
                    show_tree_spine();
                    animator.scale = v2{1, 1};
                    animator.set_animation("idle", true, 0);
                }
                show_tree_idle_sprite();
                return;
            }

            if !fall_anim_started {
                fall_anim_started = true;
                if animator != null {
                    animator.set_animation("fall", false, 0);
                }
            }

            fall_t := min(1.0, max(0.0, (fall_age - 0.2) / 0.62));
            ease := fall_t * fall_t * (3.0 - 2.0 * fall_t);
            entity.set_local_rotation(sin(fall_age * 34.0) * (1.0 - ease) * 2.5);
            entity.set_local_position(original_pos);
            entity.set_local_scale(original_scale * (1.06 - ease * 0.16));
            update_tree_spine_depth_offset();

            if fall_t >= 1.0 && !thumped {
                thumped = true;
                is_falling = false;
                is_cut = true;
                health = max_health();
                rng := rng_root_seed() + entity.id * 113 + get_frame_number() * 17;
                regrow_at = get_time() + tree_regrow_seconds_for_axe(reward_tier, ref rng);
                spawn_juice_particles_for_player(chopping_player, original_pos + v2{fall_dir * 0.8, 0.1}, reward_tier, 8 + reward_tier, {0.58, 0.43, 0.25, 0.6}, false);
                spawn_log_pickup(original_pos, chopping_player, tree_level_log_reward(tree_level), reward_tier);
                if player_local_feedback(chopping_player) {
                    play_positional_sfx("cm_pick_up_item_f8d7c9.wav", original_pos, 0.42, 0.04);
                }
                if animator != null {
                    animator.set_animation("fallen_idle", true, 0);
                }
                // Keep the entity enabled so this Lumber_Tree component keeps
                // receiving ao_update and can fire the regrow timer.
                entity.set_local_position(original_pos);
                entity.set_local_rotation(0);
                entity.set_local_scale(original_scale * 0.01);
                hide_tree_visuals();
            }
            return;
        }

        if is_cut && get_time() >= regrow_at {
            is_cut = false;
            health = max_health();
            last_spinning_axe_hit_at = -SPINNING_AXE_TREE_HIT_COOLDOWN;
            will_fall = false;
            entity.set_local_position(original_pos);
            entity.set_local_rotation(0);
            entity.set_local_scale(original_scale * 0.2);
            setup_tree_idle_sprite();
            show_tree_idle_sprite();
            spawn_float_text_for_player(chopping_player, original_pos + v2{0, 1.1}, "regrown", {0.35, 1.0, 0.35, 1}, false);
        }
        if !is_cut && !is_falling && entity.get_local_enabled() {
            if sprite != null && sprite.get_enabled() {
                entity.set_local_position(original_pos + TREE_IDLE_SPRITE_POSITION_OFFSET);
                entity.set_local_scale(v2{TREE_IDLE_ENTITY_SCALE, TREE_IDLE_ENTITY_SCALE});
            } else if animator != null && animator.get_enabled() {
                entity.set_local_position(original_pos);
                entity.set_local_scale(original_scale);
                update_tree_spine_depth_offset();
            }
        }
    }
}

Tree_Level_Ring :: class : Component {
    tree_level: s64 @ao_serialize;
    configured: bool;

    ao_start :: method() {
        if tree_level <= 0 tree_level = 2;
        configure_tree_level_children();
    }

    ao_update :: method(dt: float) {
        if !configured {
            configure_tree_level_children();
        }
    }

    configure_tree_level_children :: method() {
        current := entity.get_first_child();
        while current != null {
            tree := current.get_component(Lumber_Tree);
            if tree == null {
                tree = current.add_component(Lumber_Tree);
            }
            tree.tree_level = tree_level;
            tree.health = tree.max_health();
            tree.setup_tree_idle_sprite();
            tree.show_tree_idle_sprite();
            current = current.get_next_sibling();
        }
        configured = true;
    }
}

spawn_log_pickup :: proc(pos: v2, player: Player, amount: s64, tier: s64) {
    moved: s64 = 0;
    if player == null || !#alive(player) || !#alive(player.entity) return;

    moved = give_logs_to_backpack(player, amount);
    if moved > 0 {
        player.ui_pop_timer = 0.18;
    } else {
        feedback_pos := player.entity.world_position;
        spawn_float_text_for_player(player, feedback_pos + v2{0, 1.55}, "Backpack full", {1.0, 0.12, 0.08, 1}, true);
        if player_local_feedback(player) {
            play_backpack_full_dud_sfx(feedback_pos);
        }
        return;
    }

    if g_log_pickup_lerps.count >= 40 {
        g_log_pickup_lerps.unordered_remove_by_index(0);
    }
    p: Log_Pickup_Lerp;
    p.owner = player;
    p.delay = 0.38;
    p.duration = max(0.22, 0.62 - tier.(float) * 0.045);
    p.start_pos = pos + v2{0, 0.15};
    p.prev_age = p.age;
    p.base_scale = 0.55 + tier.(float) * 0.03;
    p.amount = 0;
    p.display_amount = moved;
    g_log_pickup_lerps.append(p);
}

Log_Pickup_Lerp :: struct {
    owner: Player;
    age: float;
    prev_age: float;
    delay: float;
    duration: float;
    start_pos: v2;
    amount: s64;
    display_amount: s64;
    collected: bool;
    base_scale: float;
}

log_pickup_lerp_position_at_age :: proc(p: Log_Pickup_Lerp, age: float, owner_pos: v2) -> v2 {
    if age < p.delay {
        bob := sin(age * 14.0) * 0.12;
        return p.start_pos + v2{0, bob};
    }
    t := min(1.0, (age - p.delay) / p.duration);
    ease := t * t * (3.0 - 2.0 * t);
    target := owner_pos + v2{0, 0.75};
    arc := sin(t * PI) * 1.1;
    return p.start_pos + (target - p.start_pos) * ease + v2{0, arc};
}

log_pickup_lerp_position :: proc(p: Log_Pickup_Lerp) -> v2 {
    if p.owner == null || !#alive(p.owner) || !#alive(p.owner.entity) return p.start_pos;
    return log_pickup_lerp_position_at_age(p, p.age, p.owner.entity.world_position);
}

Chip_VFX :: struct {
    owner: Player;
    pos: v2;
    prev_pos: v2;
    velocity: v2;
    age: float;
    duration: float;
    spin: float;
    scale: float;
    rotation: float;
}

Juice_Particle_VFX :: struct {
    owner: Player;
    pos: v2;
    prev_pos: v2;
    velocity: v2;
    age: float;
    duration: float;
    spin: float;
    gravity: float;
    start_color: v4;
    scale: float;
    rotation: float;
}

Floating_Feedback :: struct {
    owner: Player;
    text: string;
    color: v4;
    age: float;
    prev_age: float;
    duration: float;
    drift_x: float;
    big: bool;
    text_scale: float;
    start_pos: v2;
}

update_world_space_feedback :: proc(dt: float) {
    i: int = g_log_pickup_lerps.count - 1;
    while i >= 0 {
        p := g_log_pickup_lerps[i];
        p.prev_age = p.age;
        p.age += dt;
        if p.owner == null || !#alive(p.owner) || !#alive(p.owner.entity) {
            g_log_pickup_lerps.unordered_remove_by_index(i);
            i -= 1;
            continue;
        }
        t := 0.0;
        if p.age >= p.delay {
            t = min(1.0, (p.age - p.delay) / p.duration);
        }
        if t >= 1.0 && !p.collected {
            p.collected = true;
            moved: s64 = 0;
            if p.amount > 0 {
                moved = give_item(p.owner, log_defn, p.amount);
            } else {
                moved = 1;
            }
            if moved > 0 {
                text := "+1 log";
                if p.display_amount > 1 {
                    text = format_string("+% logs", {p.display_amount});
                }
                spawn_float_text_for_player(p.owner, p.owner.entity.world_position + v2{0, 1.35}, text, {0.35, 1.0, 0.35, 1}, true);
                p.owner.ui_pop_timer = 0.18;
                if player_local_feedback(p.owner) {
                    play_positional_sfx("pickup_032239.wav", p.owner.entity.world_position, 0.36, 0.08);
                }
            }
            g_log_pickup_lerps.unordered_remove_by_index(i);
            i -= 1;
            continue;
        }
        g_log_pickup_lerps[i] = p;
        i -= 1;
    }

    i = g_chip_vfx.count - 1;
    while i >= 0 {
        c := g_chip_vfx[i];
        c.prev_pos = c.pos;
        c.age += dt;
        c.velocity.y -= 5.0 * dt;
        c.pos += c.velocity * dt;
        c.rotation += c.spin * dt;
        if c.age >= c.duration {
            g_chip_vfx.unordered_remove_by_index(i);
            i -= 1;
            continue;
        }
        g_chip_vfx[i] = c;
        i -= 1;
    }

    i = g_juice_particle_vfx.count - 1;
    while i >= 0 {
        j := g_juice_particle_vfx[i];
        j.prev_pos = j.pos;
        j.age += dt;
        j.velocity.y -= j.gravity * dt;
        j.pos += j.velocity * dt;
        j.rotation += j.spin * dt;
        if j.age >= j.duration {
            g_juice_particle_vfx.unordered_remove_by_index(i);
            i -= 1;
            continue;
        }
        g_juice_particle_vfx[i] = j;
        i -= 1;
    }

    i = g_floating_feedback.count - 1;
    while i >= 0 {
        f := g_floating_feedback[i];
        f.prev_age = f.age;
        f.age += dt;
        if f.age >= f.duration {
            g_floating_feedback.unordered_remove_by_index(i);
            i -= 1;
            continue;
        }
        g_floating_feedback[i] = f;
        i -= 1;
    }
}

Sawmill_Blade :: class : Component {
    ao_update :: method(dt: float) {
        active := false;
        for p: component_iterator(Player) {
            if p.refining active = true;
        }
        if active {
            entity.add_local_rotation(-900.0 * dt);
        } else {
            entity.add_local_rotation(-90.0 * dt);
        }
    }
}

Lumber_Sawmill :: class : Component {
    ao_start :: method() {
    }
}

Polishing_Machine :: class : Interactable {
    ao_start :: method() {
        this.set_listener(this);
        this.set_text("Requires rebirth 1");
        this.set_hold_text("Locked");
        required_hold_time = 0.35;
        radius = 2.4;
        priority = 24;
        apply_locked_visual(false);
        ensure_flame_visual();
        update_local_flame_visual();
    }

    apply_locked_visual :: method(unlocked: bool) {
        sprite := entity.get_component(Sprite_Renderer);
        if sprite == null return;
        if unlocked {
            sprite.color = {1.0, 1.0, 1.0, 1.0};
        } else {
            sprite.color = {1.0, 1.0, 1.0, 0.32};
        }
    }

    refresh_local_locked_visual :: method() {
        local_player, ok := Game.get_local_player();
        if ok {
            apply_locked_visual(player_has_alien_refiner(local_player));
        }
    }

    ao_update :: method(dt: float) {
        refresh_local_locked_visual();
        update_local_flame_visual();
    }

    ao_on_state_sync :: method() {
        refresh_local_locked_visual();
        update_local_flame_visual();
    }

    ensure_flame_visual :: method() {
        if g_alien_refiner_flame_entity != null && #alive(g_alien_refiner_flame_entity) return;

        g_alien_refiner_flame_ensure_count += 1;
        log_info("Alien refiner flame ensure/create count=% time=%", {g_alien_refiner_flame_ensure_count, format_float(get_time(), decimals=2)});

        g_alien_refiner_flame_entity = Scene.create_entity();
        g_alien_refiner_flame_entity.set_name("Alien_Refiner_Local_Flame");
        g_alien_refiner_flame_entity.set_parent(entity, false);
        g_alien_refiner_flame_entity.set_local_position(v2{0.35, 0.25});
        g_alien_refiner_flame_entity.set_local_scale(v2{0.0, 0.0});
        g_alien_refiner_flame_entity.set_local_rotation(0);

        g_alien_refiner_flame_animator = g_alien_refiner_flame_entity.add_component(Spine_Animator);
        g_alien_refiner_flame_animator.awaken();
        g_alien_refiner_flame_animator.set_skeleton(alien_refiner_flame_spine_asset);
        g_alien_refiner_flame_animator.set_skin("default");
        g_alien_refiner_flame_animator.refresh_skins();
        g_alien_refiner_flame_animator.layer = 5;
        g_alien_refiner_flame_animator.depth_offset = -0.55;
        g_alien_refiner_flame_animator.color_multiplier = {1.0, 1.0, 1.0, 0.0};
        g_alien_refiner_flame_animator.set_animation(ALIEN_REFINER_FLAME_ANIM, true, 0);
        g_alien_refiner_flame_entity.set_local_enabled(true);
        g_alien_refiner_flame_active = false;
    }

    update_local_flame_visual :: method() {
        local_player, ok := Game.get_local_player();
        if !ok return;

        working := local_player.alien_refiner_flame_working && player_has_alien_refiner(local_player);
        if !working {
            if g_alien_refiner_flame_active {
                g_alien_refiner_flame_stop_count += 1;
                log_info("Alien refiner flame STOP count=% time=% remaining=% total=% polishing=%", {g_alien_refiner_flame_stop_count, format_float(get_time(), decimals=2), local_player.polish_planks_remaining, local_player.polish_planks_total, local_player.polishing});
                if g_alien_refiner_flame_animator != null {
                    g_alien_refiner_flame_animator.color_multiplier = {1.0, 1.0, 1.0, 0.0};
                }
                if g_alien_refiner_flame_entity != null && #alive(g_alien_refiner_flame_entity) {
                    g_alien_refiner_flame_entity.set_local_scale(v2{0.0, 0.0});
                }
                g_alien_refiner_flame_active = false;
            }
            return;
        }

        ensure_flame_visual();
        if g_alien_refiner_flame_animator == null return;

        if !g_alien_refiner_flame_active {
            g_alien_refiner_flame_start_count += 1;
            log_info("Alien refiner flame SHOW count=% time=% remaining=% total=% polishing=%", {g_alien_refiner_flame_start_count, format_float(get_time(), decimals=2), local_player.polish_planks_remaining, local_player.polish_planks_total, local_player.polishing});
            if g_alien_refiner_flame_entity != null && #alive(g_alien_refiner_flame_entity) {
                g_alien_refiner_flame_entity.set_local_position(v2{0.35, 0.25});
                g_alien_refiner_flame_entity.set_local_scale(v2{1.40, 1.40});
            }
            g_alien_refiner_flame_animator.color_multiplier = {1.0, 1.0, 1.0, 1.0};
            g_alien_refiner_flame_active = true;
        }
    }

    can_use :: method(player: Player) -> bool {
        return false;
    }

    on_interact :: method(player: Player) {
        if player == null return;
        if player_has_alien_refiner(player) return;
        player.dialogue_text = "Requires rebirth 1";
        player.dialogue_timer = 1.4;
        play_backpack_full_dud_sfx(player.entity.world_position);
    }

    ao_end :: method() {
        if g_alien_refiner_flame_entity != null && #alive(g_alien_refiner_flame_entity) {
            g_alien_refiner_flame_entity.destroy();
        }
        g_alien_refiner_flame_entity = null;
        g_alien_refiner_flame_animator = null;
        g_alien_refiner_flame_active = false;
    }
}

Coin_Chest :: class : Interactable {
    min_gold: s64 @ao_serialize;
    max_gold: s64 @ao_serialize;
    respawn_seconds: float @ao_serialize;
    opened: bool;
    respawn_at: float;
    open_count: s64;
    sprite: Sprite_Renderer;

    ao_start :: method() {
        this.set_listener(this);
        this.set_text("Open");
        required_hold_time = 0.12;
        radius = 2.25;
        priority = 22;
        if min_gold <= 0 min_gold = 35;
        if max_gold < min_gold max_gold = 1400;
        if respawn_seconds <= 0 respawn_seconds = CHEST_RESPAWN_SECONDS;
        sprite = entity.get_component(Sprite_Renderer);
        refresh_visual();
    }

    can_use :: method(player: Player) -> bool {
        return !opened;
    }

    on_interact :: method(player: Player) {
        if opened return;
        opened = true;
        open_count += 1;
        respawn_at = get_time() + respawn_seconds;
        rng := rng_root_seed() + entity.id + open_count.(u64) * 7919;
        base_payout := rng_range_int(ref rng, min_gold, max_gold).(s64);
        payout := apply_rebirth_money_multiplier(player, base_payout);
        Economy.deposit_currency(player, GOLD_CURRENCY, payout);
        spawn_float_text(entity.world_position + v2{0, 1.2}, format_string("+% gold", {payout}), {1.0, 0.86, 0.18, 1}, true);
        spawn_juice_particles(entity.world_position + v2{0, 0.35}, 4, 18, {1.0, 0.82, 0.18, 0.85}, true);
        play_coin_chest_sfx(entity.world_position);
        refresh_visual();
    }

    ao_update :: method(dt: float) {
        if opened && get_time() >= respawn_at {
            opened = false;
            spawn_juice_particles(entity.world_position + v2{0, 0.35}, 2, 8, {1.0, 0.88, 0.22, 0.55}, true);
            refresh_visual();
        }
    }

    refresh_visual :: method() {
        if sprite == null {
            sprite = entity.get_component(Sprite_Renderer);
        }
        if sprite == null return;
        if opened {
            sprite.color = {0.55, 0.55, 0.55, 0.38};
        } else {
            sprite.color = {1, 1, 1, 1};
        }
    }
}

create_tree_monster_state_machine :: proc(animator: Spine_Animator) -> State_Machine {
    sm := State_Machine.create();

    is_moving := sm.create_variable("is_moving", .BOOL);
    punch_trigger := sm.create_variable("punch", .TRIGGER);
    terrify_trigger := sm.create_variable("terrify", .TRIGGER);
    throw_trigger := sm.create_variable("throw", .TRIGGER);
    trip_trigger := sm.create_variable("trip", .TRIGGER);

    main := sm.create_layer("main", 0);
    idle := main.create_state("idle", true);
    run := main.create_state("run", true);
    main.set_initial_state(idle);
    idle_to_run := main.create_transition(idle, run, false);
    idle_to_run.create_bool_condition(is_moving, true);
    run_to_idle := main.create_transition(run, idle, false);
    run_to_idle.create_bool_condition(is_moving, false);

    action := sm.create_layer("action", 1);
    clear := action.create_state("__CLEAR_TRACK__", false, 0.05);
    punch := action.create_state("punch", false);
    terrify := action.create_state("terrify", false);
    throw := action.create_state("throw", false);
    trip := action.create_state("trip", false);
    action.set_initial_state(clear);

    to_punch := action.create_global_transition(punch, true);
    to_punch.create_trigger_condition(punch_trigger);
    to_terrify := action.create_global_transition(terrify, true);
    to_terrify.create_trigger_condition(terrify_trigger);
    to_throw := action.create_global_transition(throw, true);
    to_throw.create_trigger_condition(throw_trigger);
    to_trip := action.create_global_transition(trip, true);
    to_trip.create_trigger_condition(trip_trigger);

    action.create_transition(punch, clear, true);
    action.create_transition(terrify, clear, true);
    action.create_transition(throw, clear, true);
    action.create_transition(trip, clear, true);

    if animator != null {
        animator.set_state_machine(sm, true);
    }
    return sm;
}

Tree_Monster_Ride_Effect :: class : Effect_Base {
    monster: Rentable_Tree_Monster;
    visual_entity: Entity;
    visual_animator: Spine_Animator;
    state_machine: State_Machine;
    visual_scale: v2;
    last_player_pos: v2;
    facing_left: bool;
    bob_timer: float;
    last_action_seen: s64;

    effect_start :: method() {
        if player == null || monster == null {
            remove_effect(true);
            return;
        }

        player.add_invisibility_reason(TREE_MONSTER_INVISIBILITY_REASON);

        visual_entity = Scene.create_entity();
        visual_entity.set_name("Player_Tree_Monster_Visual");
        visual_entity.set_local_position(player.entity.world_position + TREE_MONSTER_RIDE_OFFSET);
        visual_scale = monster.entity.local_scale;
        if visual_scale.x == 0.0 && visual_scale.y == 0.0 {
            visual_scale = v2{0.85, 0.85};
        }
        visual_entity.set_local_scale(visual_scale);

        visual_animator = visual_entity.add_component(Spine_Animator);
        visual_animator.awaken();
        visual_animator.set_skeleton(tree_monster_spine_asset);
        visual_animator.set_skin("Normal");
        visual_animator.refresh_skins();
        visual_animator.layer = 8;
        visual_animator.depth_offset = -0.48;
        state_machine = create_tree_monster_state_machine(visual_animator);
        last_player_pos = player.entity.world_position;
        last_action_seen = 0;
    }

    effect_update :: method(dt: float) {
        if player == null || monster == null || !monster.is_rented() || monster.renter != player {
            remove_effect(false);
            return;
        }

        bob_timer += dt;
        player_pos := player.entity.world_position;
        delta := player_pos - last_player_pos;
        moving := length_squared(delta) > 0.0004;
        if delta.x < -0.02 {
            facing_left = true;
        } else if delta.x > 0.02 {
            facing_left = false;
        }
        last_player_pos = player_pos;

        if visual_entity != null && #alive(visual_entity) {
            stomp_bob := 0.0;
            if moving stomp_bob = abs(sin(bob_timer * 8.0)) * 0.05;
            visual_entity.set_local_position(player_pos + TREE_MONSTER_RIDE_OFFSET + v2{0, stomp_bob});
            sx := abs(visual_scale.x);
            if facing_left sx = -sx;
            visual_entity.set_local_scale(v2{sx, visual_scale.y});
        }

        if state_machine != null {
            state_machine.set_bool("is_moving", moving);
            if monster.action_stamp != last_action_seen {
                last_action_seen = monster.action_stamp;
                if monster.action_kind == 1 {
                    state_machine.set_trigger("punch");
                } else if monster.action_kind == 2 {
                    state_machine.set_trigger("terrify");
                } else if monster.action_kind == 3 {
                    state_machine.set_trigger("throw");
                } else if monster.action_kind == 4 {
                    state_machine.set_trigger("trip");
                }
            }
        }

        if visual_animator != null {
            glow := 1.0 + sin(bob_timer * 6.5) * 0.10;
            visual_animator.color_multiplier = {glow, glow, 1.0, 1.0};
        }
    }

    effect_end :: method(interrupt: bool) {
        if player != null {
            player.remove_invisibility_reason(TREE_MONSTER_INVISIBILITY_REASON);
        }
        if visual_entity != null && #alive(visual_entity) {
            visual_entity.destroy();
        }
    }
}

start_tree_monster_effect :: proc(player: Player, monster: Rentable_Tree_Monster) {
    if player == null || monster == null return;
    remove_effect(player.entity, Tree_Monster_Ride_Effect, true);
    effect := new(Tree_Monster_Ride_Effect);
    effect.monster = monster;
    add_passive_effect(player.entity, effect);
}

Rentable_Tree_Monster :: class : Interactable {
    rent_cost: s64 @ao_serialize;
    rent_seconds: float @ao_serialize;
    smash_radius: float @ao_serialize;
    rented_until: float;
    next_smash_at: float;
    renter: Player;
    animator: Spine_Animator;
    pad_position: v2;
    pad_scale: v2;
    pad_rotation: float;
    visual_hidden: bool;
    active_pulse: float;
    last_renter_pos: v2;
    facing_left: bool;
    action_kind: s64;
    action_stamp: s64;
    nearby_tree_cache: [..]Lumber_Tree;

    ao_start :: method() {
        this.set_listener(this);
        this.set_text("Rent");
        required_hold_time = 0.25;
        radius = 3.0;
        priority = 34;
        if rent_cost <= 0 rent_cost = TREE_MONSTER_RENT_COST;
        rent_seconds = TREE_MONSTER_RENT_SECONDS;
        if smash_radius <= 0 smash_radius = TREE_MONSTER_SMASH_RADIUS;
        animator = entity.get_component(Spine_Animator);
        if animator != null {
            animator.awaken();
            animator.set_skin("Normal");
            animator.refresh_skins();
            animator.set_animation("idle", true, 0);
        }
        pad_position = entity.local_position;
        pad_scale = entity.local_scale;
        pad_rotation = entity.local_rotation;
    }

    is_rented :: method() -> bool {
        return get_time() < rented_until;
    }

    fuel_progress :: method() -> float {
        if !is_rented() return 0.0;
        return clamp((rented_until - get_time()) / rent_seconds, 0.0, 1.0);
    }

    can_use :: method(player: Player) -> bool {
        if !player_can_use_tree_monster(player) return false;
        return !is_rented();
    }

    on_interact :: method(player: Player) {
        if !player_can_use_tree_monster(player) {
            player.dialogue_text = "Requires rebirth 3";
            player.dialogue_timer = 1.4;
            play_backpack_full_dud_sfx(player.entity.world_position);
            return;
        }
        if is_rented() return;
        if player.helicopter_rental != null && player.helicopter_rental.is_rented() {
            player.dialogue_text = "Land first.";
            player.dialogue_timer = 1.2;
            play_backpack_full_dud_sfx(player.entity.world_position);
            return;
        }
        if !Economy.can_withdraw_currency(player, GOLD_CURRENCY, rent_cost) {
            player.dialogue_text = format_string("Need % gold", {rent_cost});
            player.dialogue_timer = 1.4;
            play_backpack_full_dud_sfx(player.entity.world_position);
            return;
        }

        Economy.withdraw_currency(player, GOLD_CURRENCY, rent_cost);
        renter = player;
        player.tree_monster_rental = this;
        rented_until = get_time() + rent_seconds;
        next_smash_at = 0.0;
        visual_hidden = true;
        action_kind = 2;
        action_stamp += 1;
        last_renter_pos = player.entity.world_position;
        start_tree_monster_effect(player, this);
        player.dialogue_text = "Tree Monster!";
        player.dialogue_timer = 1.4;
        spawn_float_text(entity.world_position + v2{0, 1.5}, "Tree Monster!", {0.38, 1.0, 0.24, 1}, true);
        spawn_juice_particles(entity.world_position + v2{0, 0.55}, 6, 24, {0.38, 1.0, 0.24, 0.85}, true);
        play_tree_monster_rent_sfx(entity.world_position);
    }

    ao_update :: method(dt: float) {
        if !is_rented() {
            finish_rental(false);
            renter = null;
            return;
        }
        if renter == null || !#alive(renter.entity) {
            finish_rental(false);
            return;
        }

        renter_pos := renter.entity.world_position;
        delta := renter_pos - last_renter_pos;
        if delta.x < -0.02 {
            facing_left = true;
        } else if delta.x > 0.02 {
            facing_left = false;
        }
        last_renter_pos = renter_pos;
        entity.set_local_position(renter_pos + TREE_MONSTER_RIDE_OFFSET);
        sx := abs(pad_scale.x);
        if sx == 0.0 sx = 0.85;
        if facing_left sx = -sx;
        sy := pad_scale.y;
        if sy == 0.0 sy = 0.85;
        entity.set_local_scale(v2{sx, sy});

        active_pulse += dt;
        if animator == null {
            animator = entity.get_component(Spine_Animator);
        }
        if animator != null {
            glow := 1.0 + sin(active_pulse * 6.0) * 0.12;
            if visual_hidden {
                animator.color_multiplier = {glow, glow, 1.0, 0.0};
            } else {
                animator.color_multiplier = {glow, glow, 1.0, 1.0};
            }
        }

        if get_time() < next_smash_at return;
        next_smash_at = get_time() + TREE_MONSTER_SMASH_TICK;
        smash_nearby_trees();
    }

    smash_nearby_trees :: method() {
        if renter == null || !#alive(renter.entity) return;
        query_trees_near(renter.entity.world_position, smash_radius, ref nearby_tree_cache);
        chopped_count: s64 = 0;
        for tree: nearby_tree_cache {
            if tree == null continue;
            if tree.is_cut || tree.is_falling continue;
            if !#alive(tree.entity) continue;
            if length_squared(tree_axe_collision_position(tree) - renter.entity.world_position) > smash_radius * smash_radius continue;
            chopped_count += 1;
            tree.start_chop_damage(renter, 0.0, tree.max_health());
        }
        if chopped_count > 0 {
            if chopped_count >= 4 {
                action_kind = 2;
            } else if chopped_count >= 2 {
                action_kind = 3;
            } else {
                action_kind = 1;
            }
            action_stamp += 1;
            spawn_juice_particles(renter.entity.world_position + v2{0, 0.65}, 5, 5 + chopped_count * 2, {0.38, 1.0, 0.24, 0.62}, true);
            if player_local_feedback(renter) {
                play_tree_monster_smash_sfx(renter.entity.world_position, chopped_count >= 4);
            }
        } else if length_squared(renter.entity.world_position - pad_position) > 36.0 {
            action_kind = 4;
            action_stamp += 1;
        }
    }

    finish_rental :: method(by_player_exit: bool) {
        if renter != null {
            remove_effect(renter.entity, Tree_Monster_Ride_Effect, false);
            renter.remove_invisibility_reason(TREE_MONSTER_INVISIBILITY_REASON);
            if renter.tree_monster_rental == this renter.tree_monster_rental = null;
            if by_player_exit {
                renter.dialogue_text = "Monster gone.";
                renter.dialogue_timer = 1.2;
            }
        }
        rented_until = 0.0;
        visual_hidden = false;
        entity.set_local_position(pad_position);
        entity.set_local_scale(pad_scale);
        entity.set_local_rotation(pad_rotation);
        action_kind = 0;
        if animator != null {
            animator.color_multiplier = {1, 1, 1, 1};
            animator.set_animation("idle", true, 0);
        }
        renter = null;
    }
}

Bacteria_Monster :: class : Interactable {
    patrol_index: s64 @ao_serialize;
    animator: Spine_Animator;
    navmesh: Navmesh;
    triangle_hint: s64;
    chase_target: Player;
    chase_until: float;
    chase_cooldown_until: float;
    hit_cooldown_until: float;
    current_target: v2;
    using_run_anim: bool;
    facing_left: bool;
    ambient_sound_id: u64;
    controller: Player;
    takeover_until: float;
    last_controller_pos: v2;
    takeover_pulse: float;

    ao_start :: method() {
        this.set_listener(this);
        this.set_text("Take Over");
        this.set_hold_text("Take Over");
        required_hold_time = 0.25;
        radius = 2.65;
        priority = 37;

        animator = entity.get_component(Spine_Animator);
        if animator == null {
            animator = entity.add_component(Spine_Animator);
            animator.set_skeleton(get_asset(Spine_Asset, "impostor_b44bea/impostor.spine"));
        }
        if animator != null {
            animator.awaken();
            animator.set_skin("default");
            animator.refresh_skins();
            animator.set_animation("idle", true, 0);
            animator.layer = 5;
            animator.depth_offset = -0.35;
        }

        navmesh = get_world_lumber_navmesh();
        if patrol_index <= 0 {
            patrol_index = (entity.id % BACTERIA_PATROL_POINT_COUNT).(s64) + 1;
        }
        current_target = bacteria_patrol_point(patrol_index);
        current_target = closest_navmesh_point(navmesh, current_target, ref triangle_hint);
        ensure_ambient_loop();
    }

    is_taken_over :: method() -> bool {
        if controller == null return false;
        if !#alive(controller) return false;
        if !#alive(controller.entity) return false;
        return get_time() < takeover_until;
    }

    is_taken_over_by :: method(player: Player) -> bool {
        if player == null return false;
        if controller != player return false;
        return is_taken_over();
    }

    can_use :: method(player: Player) -> bool {
        if !player_haunts_forest(player) return false;
        if is_taken_over() return false;
        if player_bacteria_takeover_active(player) return false;
        return true;
    }

    on_interact :: method(player: Player) {
        if !player_haunts_forest(player) {
            player.dialogue_text = "Requires rebirth 4";
            player.dialogue_timer = 1.4;
            play_backpack_full_dud_sfx(player.entity.world_position);
            return;
        }
        if is_taken_over() || player_bacteria_takeover_active(player) return;
        start_takeover(player);
    }

    start_takeover :: method(player: Player) {
        if player == null || !#alive(player.entity) return;

        finish_player_bacteria_takeover(player, false);
        controller = player;
        player.bacteria_takeover = this;
        player.add_invisibility_reason(BACTERIA_TAKEOVER_INVISIBILITY_REASON);
        takeover_until = get_time() + BACTERIA_TAKEOVER_SECONDS;
        last_controller_pos = player.entity.world_position;
        chase_target = null;
        chase_until = 0.0;
        chase_cooldown_until = takeover_until;
        hit_cooldown_until = takeover_until;
        current_target = player.entity.world_position;
        entity.set_local_position(player.entity.world_position);
        player.dialogue_text = "Haunting";
        player.dialogue_timer = 1.3;
        spawn_float_text_for_player(player, entity.world_position + v2{0, 1.55}, "Take Over", {0.55, 1.0, 0.35, 1}, true);
        spawn_juice_particles_for_player(player, entity.world_position + v2{0, 0.65}, 4, 22, {0.35, 1.0, 0.35, 0.82}, true);
        play_bacteria_tag_sfx(player);
    }

    finish_takeover :: method(by_timeout: bool) {
        old_controller := controller;
        if old_controller != null && #alive(old_controller) {
            old_controller.remove_invisibility_reason(BACTERIA_TAKEOVER_INVISIBILITY_REASON);
            if old_controller.bacteria_takeover == this old_controller.bacteria_takeover = null;
            if by_timeout && #alive(old_controller.entity) {
                old_controller.dialogue_text = "Haunt faded";
                old_controller.dialogue_timer = 1.2;
            }
        }
        controller = null;
        takeover_until = 0.0;
        chase_target = null;
        choose_next_patrol_target();
        if animator != null {
            animator.color_multiplier = {1, 1, 1, 1};
        }
    }

    ao_update :: method(dt: float) {
        ensure_ambient_loop();

        if navmesh == null {
            navmesh = get_world_lumber_navmesh();
        }

        now := get_time();
        if is_taken_over() {
            update_takeover(dt);
            return;
        } else if controller != null {
            finish_takeover(true);
        }

        if chase_target == null || !#alive(chase_target) || !#alive(chase_target.entity) || now >= chase_until {
            if chase_target != null {
                chase_target = null;
                chase_cooldown_until = now + BACTERIA_CHASE_COOLDOWN_SECONDS;
                choose_next_patrol_target();
            }
        }

        if chase_target == null && now >= chase_cooldown_until {
            best: Player = null;
            best_d2 := BACTERIA_CHASE_TRIGGER_RADIUS * BACTERIA_CHASE_TRIGGER_RADIUS;
            for player: component_iterator(Player) {
                if player == null continue;
                if !#alive(player.entity) continue;
                if player_helicopter_rented(player) || player_tree_monster_rented(player) continue;
                if player_haunts_forest(player) || player_bacteria_takeover_active(player) continue;
                d2 := length_squared(player.entity.world_position - entity.world_position);
                if d2 <= best_d2 {
                    best = player;
                    best_d2 = d2;
                }
            }
            if best != null {
                chase_target = best;
                chase_until = now + BACTERIA_MAX_CHASE_SECONDS;
            }
        }

        target := current_target;
        speed := BACTERIA_PATROL_SPEED;
        if chase_target != null && #alive(chase_target) && #alive(chase_target.entity) {
            target = chase_target.entity.world_position;
            speed = BACTERIA_CHASE_SPEED;
        }

        move_toward_target(target, speed, dt);

        if chase_target != null && #alive(chase_target) && #alive(chase_target.entity) {
            if player_haunts_forest(chase_target) {
                chase_target = null;
                chase_cooldown_until = now + BACTERIA_CHASE_COOLDOWN_SECONDS;
                choose_next_patrol_target();
                return;
            }
            if length(chase_target.entity.world_position - entity.world_position) <= BACTERIA_HIT_RADIUS && now >= hit_cooldown_until {
                hit_cooldown_until = now + 1.0;
                send_player_to_base(chase_target);
                chase_target = null;
                chase_cooldown_until = now + BACTERIA_CHASE_COOLDOWN_SECONDS;
                choose_next_patrol_target();
            }
        } else if length(entity.world_position - current_target) <= BACTERIA_PATROL_POINT_RADIUS {
            choose_next_patrol_target();
        }
    }

    update_takeover :: method(dt: float) {
        if controller == null || !#alive(controller.entity) {
            finish_takeover(false);
            return;
        }

        takeover_pulse += dt;
        controller_pos := controller.entity.world_position;
        delta := controller_pos - last_controller_pos;
        moving := length_squared(delta) > 0.0004;
        if delta.x < -0.02 {
            facing_left = true;
        } else if delta.x > 0.02 {
            facing_left = false;
        }
        last_controller_pos = controller_pos;

        next_pos := closest_navmesh_point(navmesh, controller_pos, ref triangle_hint);
        entity.set_local_position(next_pos);
        sx := abs(entity.local_scale.x);
        if sx <= 0.01 sx = 1.0;
        sy := entity.local_scale.y;
        if sy == 0.0 sy = 1.0;
        if facing_left sx = -sx;
        entity.set_local_scale(v2{sx, sy});
        set_moving_animation(moving);

        if animator != null {
            glow := 1.0 + sin(takeover_pulse * 7.0) * 0.14;
            animator.color_multiplier = {glow, 1.0, glow, 1.0};
        }
    }

    move_toward_target :: method(target: v2, speed: float, dt: float) {
        delta := target - entity.world_position;
        distance := length(delta);
        moving := distance > 0.08;
        if moving {
            dir := delta / max(distance, 0.001);
            step := min(distance, speed * dt);
            next_pos := entity.local_position + dir * step;
            next_pos = closest_navmesh_point(navmesh, next_pos, ref triangle_hint);
            entity.set_local_position(next_pos);
            if dir.x < -0.02 {
                facing_left = true;
            } else if dir.x > 0.02 {
                facing_left = false;
            }
        }

        sx := abs(entity.local_scale.x);
        if sx <= 0.01 sx = 1.0;
        sy := entity.local_scale.y;
        if sy == 0.0 sy = 1.0;
        if facing_left sx = -sx;
        entity.set_local_scale(v2{sx, sy});

        set_moving_animation(moving);
    }

    set_moving_animation :: method(moving: bool) {
        if animator == null return;
        if moving && !using_run_anim {
            animator.set_animation("run", true, 0);
            using_run_anim = true;
        } else if !moving && using_run_anim {
            animator.set_animation("idle", true, 0);
            using_run_anim = false;
        }
    }

    ensure_ambient_loop :: method() {
        if ambient_sound_id != 0 return;

        asset := get_asset(SFX_Asset, BACTERIA_AMBIENT_SFX);
        desc := SFX.default_sfx_desc();
        desc.entity_to_follow = entity.id;
        desc.loop = true;
        desc.volume = 0.42;
        desc.range_multiplier = BACTERIA_AMBIENT_RANGE_MULTIPLIER;
        desc.speed_perturb = 0.015;
        ambient_sound_id = SFX.play(asset, desc);
    }

    stop_ambient_loop :: method() {
        if ambient_sound_id == 0 return;
        SFX.stop(ambient_sound_id);
        ambient_sound_id = 0;
    }

    ao_end :: method() {
        finish_takeover(false);
        stop_ambient_loop();
    }

    choose_next_patrol_target :: method() {
        patrol_index += 1;
        if patrol_index > BACTERIA_PATROL_POINT_COUNT patrol_index = 1;
        current_target = bacteria_patrol_point(patrol_index);
        current_target = closest_navmesh_point(navmesh, current_target, ref triangle_hint);
    }
}

closest_navmesh_point :: proc(navmesh: Navmesh, pos: v2, triangle_hint: ref s64) -> v2 {
    if navmesh == null return pos;
    result := pos;
    if navmesh.try_find_closest_point_on_navmesh(pos, ref result, ref triangle_hint) {
        return result;
    }
    return pos;
}

bacteria_patrol_point :: proc(index: s64) -> v2 {
    switch index {
        case 1: return v2{-32, 32};
        case 2: return v2{32, 32};
        case 3: return v2{32, 26};
        case 4: return v2{73, 26};
        case 5: return v2{79, 10};
        case 6: return v2{32, 10};
        case 7: return v2{32, -6};
        case 8: return v2{77, -6};
        case 9: return v2{74, -22};
        case 10: return v2{32, -22};
        case 11: return v2{32, -32};
        case 12: return v2{-32, -32};
        case 13: return v2{-32, -22};
        case 14: return v2{-83, -22};
        case 15: return v2{-83, -6};
        case 16: return v2{-32, -6};
        case 17: return v2{-32, 10};
        case 18: return v2{-82, 10};
        case 19: return v2{-81, 26};
        case 20: return v2{-32, 26};
        case 21: return v2{-32, 32};
        case 22: return v2{-32, 42};
        case 23: return v2{32, 42};
        case 24: return v2{64, 42};
        case 25: return v2{53, 58};
        case 26: return v2{-48, 58};
        case 27: return v2{-71, 42};
        case 28: return v2{-32, 42};
        case 29: return v2{-32, 32};
        case 30: return v2{32, 32};
        case 31: return v2{32, -38};
        case 32: return v2{68, -38};
        case 33: return v2{60, -54};
        case 34: return v2{-55, -54};
        case 35: return v2{-78, -38};
        case 36: return v2{-32, -38};
        case 37: return v2{-32, -43};
        case 38: return v2{32, -43};
        case 39: return v2{32, -38};
        case 40: return v2{-32, -38};
        default: return v2{-32, -32};
    }
}

draw_bacteria_tag_post_fx :: proc(player: Player) {
    if player == null return;

    remaining := max(0.0, player.bacteria_tag_flash_until - get_time());
    t := clamp(remaining / BACTERIA_TAG_FLASH_SECONDS, 0.0, 1.0);
    amount := t * t;

    config: Post_Processing.Chromatic_Aberration_Config;
    config.channel_offsets = v3{0.026 * amount, -0.020 * amount, 0.014 * amount};
    config.focal_point = v2{0.5, 0.5};
    Post_Processing.chromatic_aberration(config);
}

send_player_to_base :: proc(player: Player) {
    if player == null || !#alive(player.entity) return;
    if player_haunts_forest(player) return;
    player.entity.set_local_position(v2{0, 0});
    player.dialogue_text = "Back to base!";
    player.dialogue_timer = 1.4;
    player.camera_shake = max(player.camera_shake, 0.18);
    player.bacteria_tag_flash_until = get_time() + BACTERIA_TAG_FLASH_SECONDS;
    spawn_float_text_for_player(player, player.entity.world_position + v2{0, 1.45}, "Back!", {0.55, 1.0, 0.35, 1}, true);
    spawn_juice_particles_for_player(player, player.entity.world_position + v2{0, 0.8}, 2, 12, {0.35, 1.0, 0.35, 0.75}, true);
    if player_local_feedback(player) {
        play_bacteria_tag_sfx(player);
        play_backpack_full_dud_sfx(player.entity.world_position);
    }
}

Helicopter_Ride_Effect :: class : Effect_Base {
    helicopter: Rentable_Helicopter;
    visual_entity: Entity;
    visual_animator: Spine_Animator;
    visual_scale: v2;
    bob_timer: float;
    last_player_pos: v2;
    facing_left: bool;
    firing_visual: bool;

    effect_start :: method() {
        if player == null || helicopter == null {
            remove_effect(true);
            return;
        }

        player.add_invisibility_reason(HELICOPTER_INVISIBILITY_REASON);

        visual_entity = Scene.create_entity();
        visual_entity.set_name("Player_Helicopter_Visual");
        visual_entity.set_local_position(player.entity.world_position + HELICOPTER_RIDE_OFFSET);
        visual_scale = helicopter.entity.local_scale;
        if visual_scale.x == 0.0 && visual_scale.y == 0.0 {
            visual_scale = v2{0.55, 0.55};
        }
        visual_entity.set_local_scale(visual_scale);

        visual_animator = visual_entity.add_component(Spine_Animator);
        visual_animator.awaken();
        visual_animator.set_skeleton(heli_spine_asset);
        visual_animator.set_skin("default");
        visual_animator.refresh_skins();
        visual_animator.layer = 8;
        visual_animator.depth_offset = -0.45;
        visual_animator.set_animation("fly_idle", true, 0);
        last_player_pos = player.entity.world_position;
    }

    effect_update :: method(dt: float) {
        if player == null || helicopter == null || !helicopter.is_rented() || helicopter.renter != player {
            remove_effect(false);
            return;
        }

        bob_timer += dt;
        player_pos := player.entity.world_position;
        delta := player_pos - last_player_pos;
        if delta.x < -0.02 {
            facing_left = true;
        } else if delta.x > 0.02 {
            facing_left = false;
        }
        last_player_pos = player_pos;

        if visual_entity != null && #alive(visual_entity) {
            bob := sin(bob_timer * 5.5) * 0.08;
            visual_entity.set_local_position(player_pos + HELICOPTER_RIDE_OFFSET + v2{0, bob});
            visual_entity.set_local_rotation(sin(bob_timer * 3.0) * 2.0);
            sx := abs(visual_scale.x);
            if facing_left sx = -sx;
            visual_entity.set_local_scale(v2{sx, visual_scale.y});
        }

        if visual_animator != null {
            glow := 1.0 + sin(bob_timer * 7.0) * 0.08;
            visual_animator.color_multiplier = {glow, glow, 1.0, 1.0};
            should_fire := helicopter.is_firing();
            if should_fire && !firing_visual {
                visual_animator.set_animation("fire_minigun_aim_IK", true, 0);
                firing_visual = true;
            } else if !should_fire && firing_visual {
                visual_animator.set_animation("fly_idle", true, 0);
                firing_visual = false;
            }
        }
    }

    effect_end :: method(interrupt: bool) {
        if player != null {
            player.remove_invisibility_reason(HELICOPTER_INVISIBILITY_REASON);
        }
        if visual_entity != null && #alive(visual_entity) {
            visual_entity.destroy();
        }
    }
}

start_helicopter_ride_effect :: proc(player: Player, helicopter: Rentable_Helicopter) {
    if player == null || helicopter == null return;
    remove_effect(player.entity, Helicopter_Ride_Effect, true);
    effect := new(Helicopter_Ride_Effect);
    effect.helicopter = helicopter;
    add_passive_effect(player.entity, effect);
}

Rentable_Helicopter :: class : Interactable {
    rent_cost: s64 @ao_serialize;
    rent_seconds: float @ao_serialize;
    clear_radius: float @ao_serialize;
    rented_until: float;
    next_clear_at: float;
    loop_sound_id: u64;
    renter: Player;
    active_pulse: float;
    animator: Spine_Animator;
    pad_position: v2;
    pad_scale: v2;
    pad_rotation: float;
    visual_hidden: bool;
    firing_until: float;
    last_renter_pos: v2;
    facing_left: bool;
    nearby_tree_cache: [..]Lumber_Tree;

    ao_start :: method() {
        this.set_listener(this);
        this.set_text("Rent");
        required_hold_time = 0.25;
        radius = 3.0;
        priority = 35;
        if rent_cost <= 0 rent_cost = HELICOPTER_RENT_COST;
        rent_seconds = HELICOPTER_RENT_SECONDS;
        if clear_radius <= 0 clear_radius = HELICOPTER_CLEAR_RADIUS;
        animator = entity.get_component(Spine_Animator);
        pad_position = entity.local_position;
        pad_scale = entity.local_scale;
        pad_rotation = entity.local_rotation;
    }

    is_rented :: method() -> bool {
        return get_time() < rented_until;
    }

    fuel_progress :: method() -> float {
        if !is_rented() return 0.0;
        return clamp((rented_until - get_time()) / rent_seconds, 0.0, 1.0);
    }

    is_firing :: method() -> bool {
        return get_time() < firing_until;
    }

    can_use :: method(player: Player) -> bool {
        if !player_can_use_helicopter(player) return false;
        return !is_rented();
    }

    on_interact :: method(player: Player) {
        if !player_can_use_helicopter(player) {
            player.dialogue_text = "Requires rebirth 2";
            player.dialogue_timer = 1.4;
            play_backpack_full_dud_sfx(player.entity.world_position);
            return;
        }
        if is_rented() return;
        if !Economy.can_withdraw_currency(player, GOLD_CURRENCY, rent_cost) {
            player.dialogue_text = format_string("Need % gold", {rent_cost});
            player.dialogue_timer = 1.4;
            play_backpack_full_dud_sfx(player.entity.world_position);
            return;
        }

        Economy.withdraw_currency(player, GOLD_CURRENCY, rent_cost);
        renter = player;
        player.helicopter_rental = this;
        player.show_exit_helicopter_confirm = false;
        rented_until = get_time() + rent_seconds;
        next_clear_at = 0.0;
        visual_hidden = true;
        firing_until = 0.0;
        last_renter_pos = player.entity.world_position;
        player.helicopter_auto_fly = false;
        start_helicopter_ride_effect(player, this);
        player.dialogue_text = "Helicopter rented.";
        player.dialogue_timer = 1.4;
        spawn_float_text(entity.world_position + v2{0, 1.4}, "Fuel: 2:00", {0.9, 1.0, 0.32, 1}, true);
        spawn_juice_particles(entity.world_position + v2{0, 0.6}, 5, 22, {1.0, 0.92, 0.24, 0.85}, true);
        play_helicopter_rent_sfx(entity.world_position);
    }

    ao_update :: method(dt: float) {
        if !is_rented() {
            finish_rental(false);
            renter = null;
            stop_rotor_loop();
            return;
        }
        if renter == null || !#alive(renter.entity) {
            finish_rental(false);
            return;
        }
        ensure_rotor_loop();
        renter_pos := renter.entity.world_position;
        delta := renter_pos - last_renter_pos;
        if delta.x < -0.02 {
            facing_left = true;
        } else if delta.x > 0.02 {
            facing_left = false;
        }
        last_renter_pos = renter_pos;
        entity.set_local_position(renter_pos + HELICOPTER_RIDE_OFFSET);
        sx := abs(pad_scale.x);
        if facing_left sx = -sx;
        entity.set_local_scale(v2{sx, pad_scale.y});

        active_pulse += dt;
        if animator == null {
            animator = entity.get_component(Spine_Animator);
        }
        if animator != null {
            glow := 1.0 + sin(active_pulse * 8.0) * 0.12;
            if visual_hidden {
                animator.color_multiplier = {glow, glow, 1.0, 0.0};
            } else {
                animator.color_multiplier = {glow, glow, 1.0, 1.0};
            }
        }

        if get_time() < next_clear_at return;
        next_clear_at = get_time() + HELICOPTER_CLEAR_TICK;
        clear_trees_below();
    }

    clear_trees_below :: method() {
        if renter == null || !#alive(renter.entity) return;
        query_trees_near(renter.entity.world_position, clear_radius, ref nearby_tree_cache);
        chopped_any := false;
        for tree: nearby_tree_cache {
            if tree == null continue;
            if tree.is_cut || tree.is_falling continue;
            if tree.tree_level > 3 continue;
            if !#alive(tree.entity) continue;
            if length_squared(tree_axe_collision_position(tree) - renter.entity.world_position) > clear_radius * clear_radius continue;
            chopped_any = true;
            tree.start_chop_damage(renter, 0.0, tree.max_health());
        }
        if chopped_any {
            firing_until = get_time() + 0.35;
            if animator != null {
                animator.set_animation("fire_minigun_aim_IK", true, 0);
            }
        } else if !is_firing() && animator != null {
            animator.set_animation("fly_idle", true, 0);
        }
    }

    finish_rental :: method(by_player_exit: bool) {
        if renter != null {
            remove_effect(renter.entity, Helicopter_Ride_Effect, false);
            renter.remove_invisibility_reason(HELICOPTER_INVISIBILITY_REASON);
            if renter.helicopter_rental == this renter.helicopter_rental = null;
            renter.show_exit_helicopter_confirm = false;
            renter.helicopter_auto_fly = false;
            if by_player_exit {
                renter.dialogue_text = "Helicopter returned.";
                renter.dialogue_timer = 1.2;
            }
        }
        rented_until = 0.0;
        visual_hidden = false;
        entity.set_local_position(pad_position);
        entity.set_local_scale(pad_scale);
        entity.set_local_rotation(pad_rotation);
        if animator != null {
            animator.color_multiplier = {1, 1, 1, 1};
        }
        stop_rotor_loop();
        renter = null;
    }

    ensure_rotor_loop :: method() {
        if loop_sound_id != 0 return;
        asset := get_asset(SFX_Asset, "sfx/heli-loop.wav");
        desc := SFX.default_sfx_desc();
        desc.entity_to_follow = entity.id;
        desc.loop = true;
        desc.volume = 0.54;
        desc.speed_perturb = 0.02;
        loop_sound_id = SFX.play(asset, desc);
    }

    stop_rotor_loop :: method() {
        if loop_sound_id == 0 return;
        SFX.stop(loop_sound_id);
        loop_sound_id = 0;
    }

    ao_end :: method() {
        stop_rotor_loop();
    }
}

Plank_Seller :: class : Component {
    ao_start :: method() {
    }
