            backpack_bd = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
            backpack_bd.panel.width = UIK.pixels(289);
            backpack_bd.panel.height = UIK.pixels(70);
        }
    }
    backpack_handle = UIK.button("backpack_upgrade_buy", backpack_label, backpack_bd);
    UIK.panel_end();
    UIK.panel_end();

    saw_row := UIK.panel_interior(.INSET);
    saw_row.width = UIK.flex(1);
    saw_row.height = UIK.pixels(126);
    saw_row.padding = v4{8, 10, 8, 10};
    saw_row.gap = 12;
    UIK.panel_begin(saw_row);
    saw_layout := UIK.layout_row(UIK.flex(1), UIK.flex(1), 12);
    UIK.panel_begin(saw_layout);
    saw_icon_box := UIK.layout_centered(UIK.pixels(70), UIK.pixels(70));
    UIK.panel_begin(saw_icon_box);
    UIK.image_fitted(saw_icon, UIK.image_desc(.CONTAIN), {1, 1, 1, 1});
    UIK.panel_end();
    saw_col := UIK.layout_column();
    saw_col.width = UIK.flex(1);
    saw_col.height = UIK.flex(1);
    saw_col.gap = 2;
    UIK.panel_begin(saw_col);
    UIK.text(format_string("Sawmill Tier %", {player.sawmill_tier}), UIK.text_title());
    if player.sawmill_tier < MAX_SAWMILL_TIER {
        UIK.text(format_string("Time % sec -> % sec", {format_float(sawmill_process_time(player.sawmill_tier), decimals=2), format_float(sawmill_process_time(player.sawmill_tier + 1), decimals=2)}), UIK.text_body());
    } else {
        UIK.text(format_string("Time % sec", {format_float(sawmill_process_time(player.sawmill_tier), decimals=2)}), UIK.text_body());
        UIK.text("Maximum tier reached", UIK.text_body());
    }
    UIK.panel_end();
    saw_bd := UIK.widget_desc_button_default(.BUTTON_BASIC_GREEN);
    saw_bd.panel.width = UIK.pixels(289);
    saw_bd.panel.height = UIK.pixels(70);
    saw_label := "Maximum";
    if player.sawmill_tier >= MAX_SAWMILL_TIER {
        saw_bd = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
        saw_bd.panel.width = UIK.pixels(289);
        saw_bd.panel.height = UIK.pixels(70);
    }
    if player.sawmill_tier < MAX_SAWMILL_TIER {
        cost := sawmill_upgrade_cost(player.sawmill_tier);
        saw_label = format_string("Buy % Gold", {cost});
        if gold < cost {
            saw_label = format_string("Need % Gold", {cost});
            saw_bd = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
            saw_bd.panel.width = UIK.pixels(289);
            saw_bd.panel.height = UIK.pixels(70);
        }
    }
    sawmill_handle = UIK.button("sawmill_upgrade_buy", saw_label, saw_bd);
    UIK.panel_end();
    UIK.panel_end();

    UIK.divider(2.0, {1, 1, 1, 0.28});

    auto_row := UIK.panel_interior(.INSET);
    auto_row.width = UIK.flex(1);
    auto_row.height = UIK.pixels(104);
    auto_row.padding = v4{10, 10, 10, 10};
    UIK.panel_begin(auto_row);
    auto_layout := UIK.layout_row(UIK.flex(1), UIK.flex(1), 12);
    UIK.panel_begin(auto_layout);
    auto_icon_box := UIK.layout_centered(UIK.pixels(66), UIK.pixels(66));
    UIK.panel_begin(auto_icon_box);
    UIK.image_fitted(saw_icon, UIK.image_desc(.CONTAIN), {0.75, 1.0, 0.72, 1});
    UIK.panel_end();
    auto_col := UIK.layout_column();
    auto_col.width = UIK.flex(1);
    auto_col.height = UIK.flex(1);
    auto_col.gap = 2;
    UIK.panel_begin(auto_col);
    UIK.text("Automatic Sawmill", UIK.text_title());
    UIK.panel_end();
    auto_bd := UIK.widget_desc_button_default(.BUTTON_BASIC_GREEN);
    auto_bd.panel.width = UIK.pixels(289);
    auto_bd.panel.height = UIK.pixels(70);
    auto_label := "Buy";
    if player_has_auto_sawmill(player) {
        auto_label = "Owned";
        auto_bd = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
        auto_bd.panel.width = UIK.pixels(289);
        auto_bd.panel.height = UIK.pixels(70);
    }
    auto_handle = UIK.button("auto_sawmill_buy", auto_label, auto_bd);
    UIK.panel_end();
    UIK.panel_end();

    bag_row := UIK.panel_interior(.INSET);
    bag_row.width = UIK.flex(1);
    bag_row.height = UIK.pixels(104);
    bag_row.padding = v4{10, 10, 10, 10};
    UIK.panel_begin(bag_row);
    bag_layout := UIK.layout_row(UIK.flex(1), UIK.flex(1), 12);
    UIK.panel_begin(bag_layout);
    bag_icon_box := UIK.layout_centered(UIK.pixels(66), UIK.pixels(66));
    UIK.panel_begin(bag_icon_box);
    UIK.image_fitted(backpack_icon, UIK.image_desc(.CONTAIN), {1.0, 0.88, 0.35, 1});
    UIK.panel_end();
    bag_col := UIK.layout_column();
    bag_col.width = UIK.flex(1);
    bag_col.height = UIK.flex(1);
    bag_col.gap = 2;
    UIK.panel_begin(bag_col);
    UIK.text("Unlimited Backpack", UIK.text_title());
    UIK.panel_end();
    bag_bd := UIK.widget_desc_button_default(.BUTTON_BASIC_GREEN);
    bag_bd.panel.width = UIK.pixels(289);
    bag_bd.panel.height = UIK.pixels(70);
    bag_label := "Buy";
    if player_has_unlimited_backpack(player) {
        bag_label = "Owned";
        bag_bd = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
        bag_bd.panel.width = UIK.pixels(289);
        bag_bd.panel.height = UIK.pixels(70);
    }
    unlimited_backpack_handle = UIK.button("unlimited_backpack_buy", bag_label, bag_bd);
    UIK.panel_end();
    UIK.panel_end();

    speed_row := UIK.panel_interior(.INSET);
    speed_row.width = UIK.flex(1);
    speed_row.height = UIK.pixels(104);
    speed_row.padding = v4{10, 10, 10, 10};
    UIK.panel_begin(speed_row);
    speed_layout := UIK.layout_row(UIK.flex(1), UIK.flex(1), 12);
    UIK.panel_begin(speed_layout);
    speed_icon_box := UIK.layout_centered(UIK.pixels(66), UIK.pixels(66));
    UIK.panel_begin(speed_icon_box);
    UIK.image_fitted(axe_icon, UIK.image_desc(.CONTAIN), {0.58, 0.92, 1.0, 1});
    UIK.panel_end();
    speed_col := UIK.layout_column();
    speed_col.width = UIK.flex(1);
    speed_col.height = UIK.flex(1);
    speed_col.gap = 2;
    UIK.panel_begin(speed_col);
    UIK.text("Unlimited Move Speed", UIK.text_title());
    UIK.panel_end();
    speed_bd := UIK.widget_desc_button_default(.BUTTON_BASIC_GREEN);
    speed_bd.panel.width = UIK.pixels(289);
    speed_bd.panel.height = UIK.pixels(70);
    speed_label := "Buy";
    if player_has_unlimited_move_speed(player) {
        speed_label = "Owned";
        speed_bd = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
        speed_bd.panel.width = UIK.pixels(289);
        speed_bd.panel.height = UIK.pixels(70);
    }
    unlimited_speed_handle = UIK.button("unlimited_speed_buy", speed_label, speed_bd);
    UIK.panel_end();

    UIK.panel_end();
    UIK.list_end();
    UIK.panel_end();
    UIK.end();

    if UIK.clicked(exit_handle) {
        player.show_upgrades_menu = false;
    }
    if UIK.clicked(axe_handle) {
        if player.axe_tier < MAX_AXE_TIER {
            cost := axe_upgrade_cost(player.axe_tier);
            if Economy.can_withdraw_currency(player, GOLD_CURRENCY, cost) {
                Economy.withdraw_currency(player, GOLD_CURRENCY, cost);
                player.axe_tier += 1;
                save_player_progress(player);
                player.dialogue_text = "Axe upgraded.";
                player.dialogue_timer = 1.5;
                player.ui_pop_timer = 0.3;
                spawn_float_text(player.entity.world_position + v2{0, 1.5}, format_string("Axe: %", {player.axe_tier}), axe_tier_color(player.axe_tier), true);
                spawn_juice_particles(player.entity.world_position + v2{0, 0.8}, player.axe_tier, 18, axe_tier_color(player.axe_tier), true);
                play_upgrade_sfx(player, AXE_UPGRADE_SFX);
            } else {
                player.dialogue_text = "Need more gold.";
                player.dialogue_timer = 1.4;
            }
        }
    }
    if UIK.clicked(backpack_handle) {
        if player.backpack_tier < MAX_BACKPACK_TIER {
            cost := backpack_upgrade_cost(player.backpack_tier);
            if Economy.can_withdraw_currency(player, GOLD_CURRENCY, cost) {
                Economy.withdraw_currency(player, GOLD_CURRENCY, cost);
                player.backpack_tier += 1;
                save_player_progress(player);
                player.ui_pop_timer = 0.3;
                player.dialogue_text = format_string("Backpack: % logs", {backpack_capacity(player.backpack_tier)});
                player.dialogue_timer = 1.5;
                spawn_float_text(player.entity.world_position + v2{0, 1.45}, format_string("Backpack: %", {effective_backpack_capacity(player)}), {0.62, 0.88, 1.0, 1}, true);
                spawn_juice_particles(player.entity.world_position + v2{0, 0.8}, player.backpack_tier, 14, {0.62, 0.88, 1.0, 0.75}, true);
                play_upgrade_sfx(player, BACKPACK_UPGRADE_SFX);
            } else {
                player.dialogue_text = "Need more gold.";
                player.dialogue_timer = 1.4;
            }
        }
    }
    if UIK.clicked(sawmill_handle) {
        if player.sawmill_tier < MAX_SAWMILL_TIER {
            cost := sawmill_upgrade_cost(player.sawmill_tier);
            if Economy.can_withdraw_currency(player, GOLD_CURRENCY, cost) {
                Economy.withdraw_currency(player, GOLD_CURRENCY, cost);
                player.sawmill_tier += 1;
                save_player_progress(player);
                player.ui_pop_timer = 0.3;
                player.dialogue_text = "Sawmill upgraded.";
                player.dialogue_timer = 1.5;
                spawn_float_text(player.entity.world_position + v2{0, 1.45}, format_string("Sawmill: %", {player.sawmill_tier}), {1.0, 0.78, 0.22, 1}, true);
                spawn_juice_particles(player.entity.world_position + v2{0, 0.8}, player.sawmill_tier, 16, {1.0, 0.78, 0.22, 0.75}, true);
                play_purchase_item_sfx(player);
            } else {
                player.dialogue_text = "Need more gold.";
                player.dialogue_timer = 1.4;
            }
        }
    }
    if !player_has_auto_sawmill(player) && UIK.clicked(auto_handle) {
        Purchasing.prompt_purchase(player, AUTO_SAWMILL_PRODUCT_ID);
    }
    if !player_has_unlimited_backpack(player) && UIK.clicked(unlimited_backpack_handle) {
        Purchasing.prompt_purchase(player, UNLIMITED_BACKPACK_PRODUCT_ID);
    }
    if !player_has_unlimited_move_speed(player) && UIK.clicked(unlimited_speed_handle) {
        Purchasing.prompt_purchase(player, UNLIMITED_MOVE_SPEED_PRODUCT_ID);
    }
}
