// Game wide systems
ao_before_scene_load :: proc() {
    g_spinning_axe_mode = SPINNING_AXE_MODE_DEFAULT;
    Scene.set_player_inventory_capacity(24);
    Scene.set_auto_save_player_inventory(true);

    log_icon := get_asset(Texture_Asset, "Wood Logs Icon 256_e83b4b.png");
    plank_icon := get_asset(Texture_Asset, "Wood_Plank_a3b582.png");
    alien_plank_icon := get_asset(Texture_Asset, "upperarm_1r_8cf382.png");
    coin_icon := get_asset(Texture_Asset, "$AO/ui/kit/Icons/coin/coin_icon_b.png");
    tree_spine_asset = get_asset(Spine_Asset, "pine_tree_9f0a75/pine_tree.spine");
    tree_monster_spine_asset = get_asset(Spine_Asset, "green_monster_f3be11/green_monster.spine");
    heli_spine_asset = get_asset(Spine_Asset, "CAP99_capy_copter_e30fed/CAP99_capy_copter.spine");
    alien_refiner_flame_spine_asset = get_asset(Spine_Asset, ALIEN_REFINER_FLAME_SPINE);
    chop_keybind = Keybinds.register("Chop", .MOUSE_LEFT);
    wood_chips_texture = get_asset(Texture_Asset, "wood_chips_331308.png");
    wood_logs_texture = get_asset(Texture_Asset, "wood_logs_758caf.png");
    held_axe_texture = get_asset(Texture_Asset, "Axe Icon_2c9119.png");

    log_defn = Items.register_item_definition({LOG_ITEM_ID, "Logs", log_icon, 999, .COMMON});
    plank_defn = Items.register_item_definition({PLANK_ITEM_ID, "Planks", plank_icon, 999, .UNCOMMON});
    alien_plank_defn = Items.register_item_definition({ALIEN_PLANK_ITEM_ID, "Alien Planks", alien_plank_icon, 999, .RARE});
    Economy.register_currency(GOLD_CURRENCY, coin_icon);
    register_tree_level_materials();
    tree_idle_texture = get_asset(Texture_Asset, "baked_tree.png");
}

ao_start :: proc() {
    tree_grid_mark_dirty();
}

ao_update :: proc(dt: float) {
    g_observed_backpack_full_text_scale = 2.0;
    g_observed_backpack_full_dud_sfx_ready = true;
    g_observed_axe_tier_1_hits = axe_hits_to_chop(1);
    g_observed_axe_tier_2_hits = axe_hits_to_chop(2);
    g_observed_axe_tier_3_hits = axe_hits_to_chop(3);
    g_observed_axe_tier_4_hits = axe_hits_to_chop(4);
    g_observed_axe_tier_4_cleave_targets = axe_cleave_targets(4);
    g_observed_axe_tier_4_cleave_damage = axe_cleave_damage(4);
    g_observed_axe_tier_5_cleave_targets = axe_cleave_targets(5);
    maintain_base_tier_tree_supply();
    update_world_space_feedback(dt);
}

ao_late_update :: proc(dt: float) {
}

tree_grid_mark_dirty :: proc() {
    g_tree_grid_dirty = true;
}

tree_grid_flat_index :: proc(x: s64, y: s64) -> s64 {
    return y * TREE_GRID_DIM + x;
}

tree_grid_cell_x :: proc(x: float) -> s64 {
    span := g_tree_grid_max.x - g_tree_grid_min.x;
    if span <= 0.01 return 0;
    cell := (((x - g_tree_grid_min.x) / span) * TREE_GRID_DIM.(float)).(s64);
    return clamp(cell, 0, TREE_GRID_DIM - 1);
}

tree_grid_cell_y :: proc(y: float) -> s64 {
    span := g_tree_grid_max.y - g_tree_grid_min.y;
    if span <= 0.01 return 0;
    cell := (((y - g_tree_grid_min.y) / span) * TREE_GRID_DIM.(float)).(s64);
    return clamp(cell, 0, TREE_GRID_DIM - 1);
}

tree_grid_clear :: proc() {
    for i: 0..TREE_GRID_CELL_COUNT - 1 {
        g_tree_grid[i].trees.clear();
    }
}

tree_axe_collision_position :: proc(tree: Lumber_Tree) -> v2 {
    if tree == null || !#alive(tree.entity) return v2{0, 0};

    pos := tree.entity.world_position;
    if tree.sprite != null && #alive(tree.sprite) && tree.sprite.get_enabled() {
        // In sprite-renderer mode the entity is shifted up to align the baked
        // image visually. Axe collision should stay near the trunk/base.
        pos -= TREE_IDLE_SPRITE_POSITION_OFFSET;
    }
    return pos;
}

tree_grid_rebuild :: proc() {
    tree_grid_clear();
    found := false;
    min_pos := v2{0, 0};
    max_pos := v2{0, 0};

    for tree: component_iterator(Lumber_Tree) {
        if tree == null continue;
        if !#alive(tree.entity) continue;
        pos := tree_axe_collision_position(tree);
        if !found {
            min_pos = pos;
            max_pos = pos;
            found = true;
        } else {
            min_pos.x = min(min_pos.x, pos.x);
            min_pos.y = min(min_pos.y, pos.y);
            max_pos.x = max(max_pos.x, pos.x);
            max_pos.y = max(max_pos.y, pos.y);
        }
    }

    if !found {
        g_tree_grid_ready = false;
        g_tree_grid_dirty = false;
        return;
    }

    g_tree_grid_min = min_pos - v2{1.0, 1.0};
    g_tree_grid_max = max_pos + v2{1.0, 1.0};
    if g_tree_grid_max.x - g_tree_grid_min.x < 1.0 g_tree_grid_max.x = g_tree_grid_min.x + 1.0;
    if g_tree_grid_max.y - g_tree_grid_min.y < 1.0 g_tree_grid_max.y = g_tree_grid_min.y + 1.0;

    for tree: component_iterator(Lumber_Tree) {
        if tree == null continue;
        if !#alive(tree.entity) continue;
        pos := tree_axe_collision_position(tree);
        x := tree_grid_cell_x(pos.x);
        y := tree_grid_cell_y(pos.y);
        g_tree_grid[tree_grid_flat_index(x, y)].trees.append(tree);
    }

    g_tree_grid_ready = true;
    g_tree_grid_dirty = false;
}

tree_grid_ensure :: proc() {
    if g_tree_grid_dirty || !g_tree_grid_ready {
        tree_grid_rebuild();
    }
}

tree_spine_depth_offset_for_scale :: proc(scale: v2) -> float {
    parent_scale := max(abs(scale.x), abs(scale.y));
    if parent_scale <= 0.001 return TREE_IDLE_DEPTH_OFFSET;
    return TREE_IDLE_DEPTH_OFFSET * TREE_IDLE_ENTITY_SCALE / parent_scale;
}

maintain_base_tier_tree_supply :: proc() {
    if !Game.is_server() return;

    now := get_time();
    if now < g_base_tier_tree_supply_check_at return;
    g_base_tier_tree_supply_check_at = now + BASE_TIER_TREE_SUPPLY_CHECK_SECONDS;

    alive_base_trees: s64 = 0;
    for tree: component_iterator(Lumber_Tree) {
        if tree == null continue;
        if tree.tree_level != 1 continue;
        if !tree.is_cut && !tree.is_falling {
            alive_base_trees += 1;
        }
    }

    trees_to_respawn := BASE_TIER_TREE_MIN_ALIVE - alive_base_trees;
    if trees_to_respawn <= 0 return;

    for tree: component_iterator(Lumber_Tree) {
        if trees_to_respawn <= 0 break;
        if tree == null continue;
        if tree.tree_level != 1 continue;
        if tree.is_cut {
            tree.force_respawn();
            trees_to_respawn -= 1;
        }
    }
}

query_trees_near :: proc(pos: v2, radius: float, results: ref [..]Lumber_Tree) {
    results.clear();
    tree_grid_ensure();
    if !g_tree_grid_ready return;

    min_x := tree_grid_cell_x(pos.x - radius);
    max_x := tree_grid_cell_x(pos.x + radius);
    min_y := tree_grid_cell_y(pos.y - radius);
    max_y := tree_grid_cell_y(pos.y + radius);

    for y: min_y..max_y {
        for x: min_x..max_x {
            entry_index := tree_grid_flat_index(x, y);
            for tree: g_tree_grid[entry_index].trees {
                results.append(tree);
            }
        }
    }
}

bool_to_save_int :: proc(value: bool) -> s64 {
    if value return 1;
    return 0;
}

rebirth_cost :: proc(level: s64) -> s64 {
    switch level {
        case 1: return REBIRTH_COST_1;
        case 2: return REBIRTH_COST_2;
        case 3: return REBIRTH_COST_3;
        case 4: return REBIRTH_COST_4;
        default: return 0;
    }
}

rebirth_money_multiplier_for_level :: proc(level: s64) -> float {
    return 1.0 + clamp(level, 0, REBIRTH_MAX_LEVEL).(float) * REBIRTH_MONEY_MULTIPLIER_STEP;
}

rebirth_money_multiplier :: proc(player: Player) -> float {
    return rebirth_money_multiplier_for_level(player_rebirth_level(player));
}

apply_rebirth_money_multiplier :: proc(player: Player, base_amount: s64) -> s64 {
    if base_amount <= 0 return 0;
    multiplier := rebirth_money_multiplier(player);
    payout := (base_amount.(float) * multiplier + 0.5).(s64);
    return max(base_amount, payout);
}

rebirth_unlock_label :: proc(level: s64) -> string {
    switch level {
        case 1: return "Polisher";
        case 2: return "Helicopter";
        case 3: return "Tree Monster";
        case 4: return "Haunt Forest";
        default: return "All unlocked";
    }
}

next_rebirth_level :: proc(player: Player) -> s64 {
    if player == null return 1;
    if player.rebirth_level >= REBIRTH_MAX_LEVEL return 0;
    return player.rebirth_level + 1;
}

next_rebirth_cost :: proc(player: Player) -> s64 {
    return rebirth_cost(next_rebirth_level(player));
}

player_rebirth_level :: proc(player: Player) -> s64 {
    if player == null return 0;
    return clamp(player.rebirth_level, 0, REBIRTH_MAX_LEVEL);
}

player_has_auto_sawmill :: proc(player: Player) -> bool {
    if player == null return false;
    return player.owns_auto_sawmill;
}

player_has_unlimited_backpack :: proc(player: Player) -> bool {
    if player == null || !#alive(player) return false;
    return player.owns_unlimited_backpack_product;
}

player_has_unlimited_move_speed :: proc(player: Player) -> bool {
    if player == null return false;
    return player.owns_unlimited_move_speed_product;
}

player_has_alien_refiner :: proc(player: Player) -> bool {
    if player == null return false;
    return player_rebirth_level(player) >= 1;
}

player_can_use_helicopter :: proc(player: Player) -> bool {
    return player_rebirth_level(player) >= 2;
}

player_can_use_tree_monster :: proc(player: Player) -> bool {
    return player_rebirth_level(player) >= 3;
}

player_haunts_forest :: proc(player: Player) -> bool {
    return player_rebirth_level(player) >= REBIRTH_MAX_LEVEL;
}

save_player_progress :: proc(player: Player) {
    if player == null return;
    Save.set_int(player, "lta_progress_version", SAVE_PROGRESS_VERSION);
    Save.set_int(player, "lta_rebirth_level", clamp(player.rebirth_level, 0, REBIRTH_MAX_LEVEL));
    Save.set_int(player, "lta_axe_tier", clamp(player.axe_tier, 1, MAX_AXE_TIER));
    Save.set_int(player, "lta_backpack_tier", clamp(player.backpack_tier, 1, MAX_BACKPACK_TIER));
    Save.set_int(player, "lta_sawmill_tier", clamp(player.sawmill_tier, 1, MAX_SAWMILL_TIER));
    Save.set_int(player, "lta_has_sold_planks", bool_to_save_int(player.has_sold_planks));
    Save.set_int(player, "lta_onboarding_step", clamp(player.onboarding_step, 0, ONBOARDING_STEP_DONE));
    Save.set_int(player, "lta_tutorial_complete_celebrated", bool_to_save_int(player.tutorial_completion_celebrated));
    Save.set_int(player, "lta_infinite_backpack", bool_to_save_int(player.infinite_backpack));
    Save.set_int(player, "lta_auto_sawmill", bool_to_save_int(player.owns_auto_sawmill));
    Save.set_int(player, "lta_unlimited_backpack", bool_to_save_int(player.owns_unlimited_backpack_product));
    Save.set_int(player, "lta_unlimited_move_speed", bool_to_save_int(player.owns_unlimited_move_speed_product));
}

load_player_progress :: proc(player: Player) {
    if player == null return;

    save_version := Save.get_int(player, "lta_progress_version", 0);
    if save_version < SAVE_PROGRESS_VERSION {
        save_version = SAVE_PROGRESS_VERSION;
    }
    Save.set_int(player, "lta_progress_version", save_version);

    player.rebirth_level = clamp(Save.get_int(player, "lta_rebirth_level", player.rebirth_level), 0, REBIRTH_MAX_LEVEL);
    player.axe_tier = clamp(Save.get_int(player, "lta_axe_tier", max(1, player.axe_tier)), 1, MAX_AXE_TIER);
    player.backpack_tier = clamp(Save.get_int(player, "lta_backpack_tier", max(1, player.backpack_tier)), 1, MAX_BACKPACK_TIER);
    player.sawmill_tier = clamp(Save.get_int(player, "lta_sawmill_tier", max(1, player.sawmill_tier)), 1, MAX_SAWMILL_TIER);
    player.has_sold_planks = Save.get_int(player, "lta_has_sold_planks", bool_to_save_int(player.has_sold_planks)) != 0;
    player.onboarding_step = clamp(Save.get_int(player, "lta_onboarding_step", player.onboarding_step), 0, ONBOARDING_STEP_DONE);
    player.tutorial_completion_celebrated = Save.get_int(player, "lta_tutorial_complete_celebrated", bool_to_save_int(player.tutorial_completion_celebrated)) != 0;
    player.infinite_backpack = Save.get_int(player, "lta_infinite_backpack", bool_to_save_int(player.infinite_backpack)) != 0;
    player.owns_auto_sawmill = Save.get_int(player, "lta_auto_sawmill", 0) != 0;
    player.owns_unlimited_backpack_product = Save.get_int(player, "lta_unlimited_backpack", 0) != 0;
    player.owns_unlimited_move_speed_product = Save.get_int(player, "lta_unlimited_move_speed", 0) != 0;
    player.alien_refiner_unlocked = player_has_alien_refiner(player);

    save_player_progress(player);
}

get_world_lumber_navmesh :: proc() -> Navmesh {
    if g_world_lumber_navmesh != null return g_world_lumber_navmesh;

    world := Scene.get_entity_by_name("WORLD_Lumber_Tycoon");
    if world != null {
        g_world_lumber_navmesh = world.get_component(Navmesh);
    }

    if g_world_lumber_navmesh == null {
        for navmesh: component_iterator(Navmesh) {
            if navmesh.entity.compare_name("WORLD_Lumber_Tycoon") {
                g_world_lumber_navmesh = navmesh;
                break;
            }
            if g_world_lumber_navmesh == null {
                g_world_lumber_navmesh = navmesh;
            }
        }
    }

    if g_world_lumber_navmesh != null && !g_world_lumber_navmesh_rebuild_requested {
        g_world_lumber_navmesh.mark_for_rebuild();
        g_world_lumber_navmesh_rebuild_requested = true;
    }
    return g_world_lumber_navmesh;
}

lock_player_to_world_navmesh :: proc(player: Player) -> bool {
    if player == null || player.agent == null return false;

    navmesh := get_world_lumber_navmesh();
    if navmesh == null return false;

    player.agent.set_navmesh_to_lock_to(navmesh);
    return true;
}

ao_purchase_handler :: proc(player: Player, id: string) -> bool {
    if player == null return false;

    if id == UNLIMITED_BACKPACK_PRODUCT_ID {
        player.owns_unlimited_backpack_product = true;
        player.infinite_backpack = true;
        player.dialogue_text = "Infinite backpack";
        player.dialogue_timer = 1.8;
        spawn_float_text(player.entity.world_position + v2{0, 1.5}, "Infinite backpack", {0.62, 0.88, 1.0, 1}, true);
        spawn_juice_particles(player.entity.world_position + v2{0, 0.8}, 6, 18, {0.62, 0.88, 1.0, 0.8}, true);
        play_purchase_item_sfx(player);
        save_player_progress(player);
        return true;
    }

    if id == UNLIMITED_MOVE_SPEED_PRODUCT_ID {
        player.owns_unlimited_move_speed_product = true;
        if player.agent != null {
            player.agent.movement_speed = PLAYER_DEFAULT_MOVEMENT_SPEED * 1.2;
        }
        player.dialogue_text = "Speed unlocked";
        player.dialogue_timer = 1.8;
        spawn_float_text(player.entity.world_position + v2{0, 1.5}, "Speed unlocked", {0.45, 1.0, 0.45, 1}, true);
        spawn_juice_particles(player.entity.world_position + v2{0, 0.8}, 6, 18, {0.45, 1.0, 0.45, 0.8}, true);
        play_purchase_item_sfx(player);
        save_player_progress(player);
        return true;
    }

    if id == AUTO_SAWMILL_PRODUCT_ID {
        player.owns_auto_sawmill = true;
        player.auto_refine_timer = 0.0;
        player.dialogue_text = "Auto sawmill";
        player.dialogue_timer = 1.8;
        spawn_float_text(player.entity.world_position + v2{0, 1.5}, "Auto sawmill", {1.0, 0.78, 0.22, 1}, true);
        spawn_juice_particles(player.entity.world_position + v2{0, 0.8}, 6, 18, {1.0, 0.78, 0.22, 0.8}, true);
        play_purchase_item_sfx(player);
        save_player_progress(player);
        return true;
    }

    return false;
}

player_inventory_ready :: proc(player: Player) -> bool {
    if player == null return false;
    if !#alive(player) return false;
    if player.default_inventory == null return false;
    if !#alive(player.default_inventory) return false;
    if player.default_inventory.capacity <= 0 return false;
    return true;
}

count_item :: proc(player: Player, defn: Item_Definition) -> s64 {
    total: s64 = 0;
    if defn == null return total;
    if player_inventory_ready(player) {
        inventory := player.default_inventory;
        for i: 0..inventory.capacity - 1 {
            item := inventory.get_item(i);
            if item == null continue;
            if !#alive(item) continue;
            item_defn := item.get_definition();
            if item_defn == defn {
                total += item.quantity;
            }
        }
    }
    return total;
}

give_item :: proc(player: Player, defn: Item_Definition, amount: s64) -> s64 {
    if defn == null || amount <= 0 {
        return 0;
    }
    if !player_inventory_ready(player) {
        return 0;
    }
    item := Items.create_item_instance(defn, amount);
    if item == null return 0;
    destroyed: bool;
    moved := Items.move_as_many_items_as_possible_to_inventory(item, player.default_inventory, ref destroyed);
    if moved < amount && !destroyed && #alive(item) {
        Items.destroy_item_instance(item);
    }
    return moved;
}

backpack_capacity :: proc(tier: s64) -> s64 {
    switch clamp(tier, 1, MAX_BACKPACK_TIER) {
        case 1: return 8;
        case 2: return 17;
        case 3: return 34;
        case 4: return 63;
        case 5: return 112;
        case 6: return 182;
        case 7: return 294;
        case 8: return 462;
        case 9: return 700;
        case 10: return 938;
        case 11: return 1260;
        case 12: return 1680;
        case 13: return 2240;
        case 14: return 3010;
        default: return 4200;
    }
}

effective_backpack_capacity :: proc(player: Player) -> s64 {
    if player_has_unlimited_backpack(player) return INFINITE_BACKPACK_CAPACITY;
    if player != null && #alive(player) && player.infinite_backpack return INFINITE_BACKPACK_CAPACITY;
    if player == null || !#alive(player) return backpack_capacity(1);
    return backpack_capacity(player.backpack_tier);
}

backpack_upgrade_cost :: proc(tier: s64) -> s64 {
    cost := (35 + tier * tier * 55) * 2;
    if tier <= 1 return max(1, cost / 4);
    if tier == 2 return max(1, cost / 2);
    return cost;
}

give_logs_to_backpack :: proc(player: Player, amount: s64) -> s64 {
    if player == null || !#alive(player) || amount <= 0 return 0;
    carried := count_item(player, log_defn);
    room := effective_backpack_capacity(player) - carried;
    if room <= 0 return 0;
    return give_item(player, log_defn, min(amount, room));
}

remove_item_count :: proc(player: Player, defn: Item_Definition, amount: s64) -> s64 {
    if defn == null || amount <= 0 return 0;
    remaining := amount;
    removed: s64 = 0;
    if !player_inventory_ready(player) return 0;
    inventory := player.default_inventory;
    for i: 0..inventory.capacity - 1 {
        if remaining <= 0 break;
        item := inventory.get_item(i);
        if item == null continue;
        if !#alive(item) continue;
        if item.get_definition() != defn continue;
        take := min(item.quantity, remaining);
        Items.destroy_item_instance(item, take);
        remaining -= take;
        removed += take;
    }
    return removed;
}

axe_upgrade_cost :: proc(tier: s64) -> s64 {
    cost := (25 + tier * tier * 35) * 2;
    if tier <= 1 {
        current_cost := ((cost / 2) * 5 + 3) / 4;
        final_cost := max(1, (current_cost * 23 + 19) / 20);
        return max(1, final_cost / 2);
    }
    current_cost := (cost * 5 + 3) / 4;
    final_cost := (current_cost * 23 + 19) / 20;
    if tier == 2 return max(1, final_cost / 2);
    return final_cost;
}

axe_chop_radius :: proc(tier: s64) -> float {
    if tier <= 2 return BASE_CHOP_RADIUS * 1.15;
    return (BASE_CHOP_RADIUS + max(0, tier - 2).(float) * 0.75) * 1.15;
}

axe_damage :: proc(tier: s64) -> s64 {
    if tier <= 1 return 1;
    clamped_tier := clamp(tier, 1, MAX_AXE_TIER);
    max_tree_health := TREE_HEALTH * tree_level_health_multiplier(MAX_TREE_LEVEL);
    max_damage := max(1, max_tree_health / 12);
    damage_scale := (max_damage - 1).(float) * 0.85;
    if clamped_tier >= MAX_AXE_TIER return max(1, (1.0 + damage_scale).(s64));

    t := (clamped_tier - 1).(float) / (MAX_AXE_TIER - 1).(float);
    scaled := 1.0 + pow(t, 2.0) * damage_scale;
    return max(1, scaled.(s64));
}

axe_crit_chance :: proc(tier: s64) -> float {
    t := 0.0;
    if MAX_AXE_TIER > 1 {
        t = clamp((clamp(tier, 1, MAX_AXE_TIER) - 1).(float) / (MAX_AXE_TIER - 1).(float), 0.0, 1.0);
    }
    return lerp(0.05, 0.20, t);
}

roll_axe_crit :: proc(player: Player, tree: Lumber_Tree) -> bool {
    if player == null || tree == null return false;
    rng := rng_root_seed() + player.entity.id * 977 + tree.entity.id * 131 + player.processed_chop_request.(u64) * 3571;
    return rng_range_float(ref rng, 0.0, 1.0) <= axe_crit_chance(player.axe_tier);
}

axe_cleave_targets :: proc(tier: s64) -> s64 {
    return max(0, tier - 3);
}

axe_cleave_damage :: proc(tier: s64) -> s64 {
    if tier < 4 return 0;
    return max(1, axe_damage(tier) / 2);
}

axe_hits_to_chop :: proc(tier: s64) -> s64 {
    dmg := axe_damage(tier);
    if dmg <= 0 return TREE_HEALTH;
    return max(1, (TREE_HEALTH + dmg - 1) / dmg);
}

axe_cooldown :: proc(tier: s64) -> float {
    return max(0.28, 0.95 - tier.(float) * 0.08);
}

axe_screen_shake :: proc(tier: s64) -> float {
    min_shake := MAX_AXE_SCREEN_SHAKE * 0.2;
    t := 0.0;
    if MAX_AXE_TIER > 1 {
        t = clamp((max(1, tier) - 1).(float) / (MAX_AXE_TIER - 1).(float), 0.0, 1.0);
    }
    return lerp(min_shake, MAX_AXE_SCREEN_SHAKE, t);
}

spinning_axe_mode_enabled :: proc() -> bool {
    return g_spinning_axe_mode;
}

spinning_axe_tier_t :: proc(tier: s64) -> float {
    if MAX_AXE_TIER <= 1 return 0.0;
    return clamp((clamp(tier, 1, MAX_AXE_TIER) - 1).(float) / (MAX_AXE_TIER - 1).(float), 0.0, 1.0);
}

spinning_axe_visual_scale :: proc(tier: s64) -> float {
    return lerp(0.58, 1.95, spinning_axe_tier_t(tier));
}

spinning_axe_orbit_radius :: proc(tier: s64) -> float {
    return lerp(SPINNING_AXE_BASE_ORBIT_RADIUS, SPINNING_AXE_MAX_ORBIT_RADIUS, spinning_axe_tier_t(tier));
}

spinning_axe_contact_radius :: proc(tier: s64) -> float {
    return 0.34 + spinning_axe_visual_scale(tier) * 0.32;
}

spinning_axe_hit_cooldown :: proc(tier: s64) -> float {
    return max(0.34, min(SPINNING_AXE_TREE_HIT_COOLDOWN, axe_cooldown(tier) * 0.90));
}

spinning_axe_tree_collision_radius :: proc(tree: Lumber_Tree) -> float {
    if tree == null return 0.45;
    scale := max(abs(tree.entity.local_scale.x), abs(tree.entity.local_scale.y));
    return 0.45 + scale * 0.26;
}

axe_visual_opacity :: proc(player: Player) -> float {
    if player != null && player.is_local() return 1.0;
    return 0.1;
}

tree_regrow_seconds_for_axe :: proc(axe_tier: s64, rng: ref u64) -> float {
    t := 0.0;
    if MAX_AXE_TIER > 1 {
        t = clamp((clamp(axe_tier, 1, MAX_AXE_TIER) - 1).(float) / (MAX_AXE_TIER - 1).(float), 0.0, 1.0);
    }
    min_seconds := lerp(TREE_REGROW_LOW_TIER_MIN_SECONDS, TREE_REGROW_HIGH_TIER_MIN_SECONDS, t);
    max_seconds := lerp(TREE_REGROW_LOW_TIER_MAX_SECONDS, TREE_REGROW_HIGH_TIER_MAX_SECONDS, t);
    return rng_range_float(ref rng, min_seconds, max_seconds);
}

sawmill_upgrade_cost :: proc(tier: s64) -> s64 {
    cost := (45 + tier * tier * 45) * 2;
    if tier <= 1 return max(1, cost / 2);
    return cost;
}

can_afford_any_upgrade :: proc(player: Player) -> bool {
    if player == null return false;
    gold := Economy.get_balance(player, GOLD_CURRENCY);
    if player.axe_tier < MAX_AXE_TIER && gold >= axe_upgrade_cost(player.axe_tier) return true;
    if player.backpack_tier < MAX_BACKPACK_TIER && gold >= backpack_upgrade_cost(player.backpack_tier) return true;
    if player.sawmill_tier < MAX_SAWMILL_TIER && gold >= sawmill_upgrade_cost(player.sawmill_tier) return true;
    return false;
}

cheapest_next_upgrade_cost :: proc(player: Player) -> s64 {
    if player == null return 0;
    best: s64 = 0;
    if player.axe_tier < MAX_AXE_TIER {
        best = axe_upgrade_cost(player.axe_tier);
    }
    if player.backpack_tier < MAX_BACKPACK_TIER {
        cost := backpack_upgrade_cost(player.backpack_tier);
        if best == 0 || cost < best best = cost;
    }
    if player.sawmill_tier < MAX_SAWMILL_TIER {
        cost := sawmill_upgrade_cost(player.sawmill_tier);
        if best == 0 || cost < best best = cost;
    }
    return best;
}

sawmill_process_time :: proc(tier: s64) -> float {
    tier_t := 0.0;
    if MAX_SAWMILL_TIER > 1 {
        tier_t = clamp((clamp(tier, 1, MAX_SAWMILL_TIER) - 1).(float) / (MAX_SAWMILL_TIER - 1).(float), 0.0, 1.0);
    }
    return (lerp(1.45, 0.0375, tier_t) * 2.0) / 1.69;
}

sawmill_auto_process_time :: proc(tier: s64) -> float {
    return sawmill_process_time(tier) * 1.25;
}

polishing_process_time :: proc(tier: s64) -> float {
    return sawmill_process_time(tier) * 4.0;
}

axe_tier_color :: proc(tier: s64) -> v4 {
    switch tier {
        case 1: return {0.82, 0.62, 0.38, 1};
        case 2: return {0.80, 0.85, 0.92, 1};
        case 3: return {0.35, 0.95, 0.48, 1};
        case 4: return {0.28, 0.62, 1.0, 1};
        case 5: return {0.82, 0.35, 1.0, 1};
        default: return {1.0, 0.88, 0.18, 1};
    }
}

axe_tier_name :: proc(tier: s64) -> string {
    switch tier {
        case 1: return "Bronze";
        case 2: return "Iron";
        case 3: return "Emerald";
        case 4: return "Sapphire";
        case 5: return "Mythic";
        default: return "Golden";
    }
}

spawn_float_text :: proc(pos: v2, text: string, color: v4, big: bool) {
    spawn_float_text_scaled_feedback(pos, text, color, big, 1.0);
}

spawn_float_text_scaled_feedback :: proc(pos: v2, text: string, color: v4, big: bool, text_scale: float) {
    spawn_float_text_scaled_feedback_for_player(null, pos, text, color, big, text_scale);
}

spawn_float_text_for_player :: proc(owner: Player, pos: v2, text: string, color: v4, big: bool) {
    spawn_float_text_scaled_feedback_for_player(owner, pos, text, color, big, 1.0);
}

spawn_float_text_scaled_feedback_for_player :: proc(owner: Player, pos: v2, text: string, color: v4, big: bool, text_scale: float) {
    if g_floating_feedback.count >= 80 {
        g_floating_feedback.unordered_remove_by_index(0);
    }
    f: Floating_Feedback;
    f.owner = owner;
    f.text = text;
    f.color = color;
    f.duration = 1.05;
    f.big = big;
    f.text_scale = max(0.1, text_scale);
    f.start_pos = pos;
    rng := rng_root_seed() + get_frame_number() + g_floating_feedback.count.(u64);
    f.drift_x = rng_range_float(ref rng, -0.8, 0.8);
    g_floating_feedback.append(f);
}

spawn_chip :: proc(pos: v2, tier: s64) {
    spawn_chip_for_player(null, pos, tier);
}

spawn_chip_for_player :: proc(owner: Player, pos: v2, tier: s64) {
    for i: 0..2 + tier {
        if g_chip_vfx.count >= 120 {
            g_chip_vfx.unordered_remove_by_index(0);
        }
        c: Chip_VFX;
        c.owner = owner;
        c.pos = pos;
        c.prev_pos = c.pos;
        rng := rng_root_seed() + get_frame_number() + g_chip_vfx.count.(u64) + i.(u64);
        c.velocity = v2{rng_range_float(ref rng, -2.4, 2.4), rng_range_float(ref rng, 1.2, 3.3)};
        c.spin = rng_range_float(ref rng, -280.0, 280.0);
        c.duration = rng_range_float(ref rng, 0.45, 0.75);
        c.scale = rng_range_float(ref rng, 0.25, 0.5) + tier.(float) * 0.03;
        g_chip_vfx.append(c);
    }
}

spawn_juice_particles :: proc(pos: v2, tier: s64, count: s64, color: v4, sparkle: bool) {
    spawn_juice_particles_for_player(null, pos, tier, count, color, sparkle);
}

spawn_juice_particles_for_player :: proc(owner: Player, pos: v2, tier: s64, count: s64, color: v4, sparkle: bool) {
    for i: 0..count - 1 {
        if g_juice_particle_vfx.count >= 180 {
            g_juice_particle_vfx.unordered_remove_by_index(0);
        }
        j: Juice_Particle_VFX;
        j.owner = owner;
        rng := rng_root_seed() + get_frame_number() + g_juice_particle_vfx.count.(u64) + i.(u64);
        j.pos = pos + v2{rng_range_float(ref rng, -0.28, 0.28), rng_range_float(ref rng, -0.12, 0.25)};
        j.prev_pos = j.pos;
        j.velocity = v2{rng_range_float(ref rng, -1.8, 1.8), rng_range_float(ref rng, 0.35, 2.6)};
        j.spin = rng_range_float(ref rng, -220.0, 220.0);
        j.duration = rng_range_float(ref rng, 0.45, 0.95);
        j.start_color = color;
        j.gravity = rng_range_float(ref rng, 0.8, 2.7);
        j.scale = rng_range_float(ref rng, 0.08, 0.18) + tier.(float) * 0.015;
        if sparkle j.scale *= 0.65;
        g_juice_particle_vfx.append(j);
    }
}

should_draw_feedback_owner :: proc(owner: Player) -> bool {
    if owner == null return true;
    if !#alive(owner) return false;
    if !#alive(owner.entity) return false;
    return owner.is_local();
}

play_positional_sfx :: proc(asset_path: string, pos: v2, volume: float, perturb: float) {
    asset := get_asset(SFX_Asset, asset_path);
    desc := SFX.default_sfx_desc();
    desc.set_position(pos);
    desc.volume = volume;
    desc.speed_perturb = perturb;
    SFX.play(asset, desc);
}

play_positional_sfx_speed :: proc(asset_path: string, pos: v2, volume: float, speed: float, perturb: float) {
    asset := get_asset(SFX_Asset, asset_path);
    desc := SFX.default_sfx_desc();
    desc.set_position(pos);
    desc.volume = volume;
    desc.speed = speed;
    desc.speed_perturb = perturb;
    SFX.play(asset, desc);
}

player_local_feedback :: proc(player: Player) -> bool {
    if player == null return false;
    if !#alive(player) return false;
    if !#alive(player.entity) return false;
    return player.is_local();
}

player_ready_for_ui :: proc(player: Player) -> bool {
    if player == null return false;
    if !#alive(player) return false;
    if !#alive(player.entity) return false;
    return true;
}

player_helicopter_rented :: proc(player: Player) -> bool {
    if !player_ready_for_ui(player) return false;
    if player.helicopter_rental == null return false;
    if !#alive(player.helicopter_rental) return false;
    return player.helicopter_rental.is_rented();
}

player_tree_monster_rented :: proc(player: Player) -> bool {
    if !player_ready_for_ui(player) return false;
    if player.tree_monster_rental == null return false;
    if !#alive(player.tree_monster_rental) return false;
    return player.tree_monster_rental.is_rented();
}

player_bacteria_takeover_active :: proc(player: Player) -> bool {
    if !player_ready_for_ui(player) return false;
    if player.bacteria_takeover == null return false;
    if !#alive(player.bacteria_takeover) return false;
    return player.bacteria_takeover.is_taken_over_by(player);
}

finish_player_bacteria_takeover :: proc(player: Player, by_timeout: bool) {
    if !player_ready_for_ui(player) return;
    if player.bacteria_takeover == null return;
    if !#alive(player.bacteria_takeover) {
        player.bacteria_takeover = null;
        player.remove_invisibility_reason(BACTERIA_TAKEOVER_INVISIBILITY_REASON);
        return;
    }
    player.bacteria_takeover.finish_takeover(by_timeout);
}

play_sawmill_start_sfx :: proc(pos: v2) {
    play_positional_sfx("saw_loop_606dff.wav", pos, 0.11, 0.025);
}

play_sawmill_log_queue_sfx :: proc(pos: v2) {
    play_positional_sfx("cm_released_a2fcaa.wav", pos, 0.35, 0.02);
}

play_sawmill_plank_sfx :: proc(pos: v2) {
    play_positional_sfx("cm_chopped_board_894334.wav", pos, 0.15, 0.04);
}

play_polishing_start_sfx :: proc(pos: v2) {
    play_positional_sfx("$AO/sfx/FUI Holo Mechanism Activate.wav", pos, 0.24, 0.04);
}

play_polishing_finish_sfx :: proc(pos: v2) {
