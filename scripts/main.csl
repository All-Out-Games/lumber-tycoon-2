draw_lumber_inventory :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    if player.default_inventory == null return;
    options := Inventory_Draw_Options.default();
    options.hotbar_item_count = 4;
    options.enable_selection = true;
    options.scroll_item_selection = true;
    options.keyboard_item_selection = true;
    Items.draw_hotbar(player, player.default_inventory, options);
}

stats_hud_rect :: proc() -> Rect {
    return UI.get_safe_screen_rect().bottom_left_rect().grow_top(102).grow_right(589).offset(12, 12);
}

rebirth_hud_button_rect :: proc() -> Rect {
    return UI.get_safe_screen_rect().bottom_left_rect().grow_top(96).grow_right(220).offset(12, 122);
}

draw_lumber_topbar :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    UIK.begin(UIK.window(stats_hud_rect()));
    shell := UIK.panel_modal(.BROWN, 8, v4{12, 8, 12, 8});
    shell.gap = 8;
    UIK.panel_begin(shell);

    row := UIK.layout_row(UIK.flex(1), UIK.fit(), 12);
    UIK.panel_begin(row);

    coin_icon := get_asset(Texture_Asset, "$AO/ui/kit/Icons/coin/coin_icon_b.png");
    money_box := UIK.panel_interior(.INSET);
    money_box.width = UIK.flex(1);
    money_box.height = UIK.pixels(64);
    money_box.padding = v4{6, 8, 6, 8};
    UIK.panel_begin(money_box);
    money_text := UIK.text_title();
    money_text.set_size_mult(0.82);
    UIK.currency(coin_icon, Economy.get_balance(player, GOLD_CURRENCY), money_text);
    UIK.panel_end();

    backpack_full := count_item(player, log_defn) >= effective_backpack_capacity(player);
    near_home := length(player.entity.local_position) <= 10.0;

    home_bd := UIK.widget_desc_button_default(.BUTTON_BASIC_YELLOW);
    if backpack_full && !near_home {
        home_bd = UIK.widget_desc_button_auto_default(.BUTTON_BASIC_WHITE);
        home_pulse := sin(get_time() * 4.8) * 0.5 + 0.5;
        home_green := lerp(0.68, 1.0, home_pulse);
        home_blue := lerp(0.05, 0.45, home_pulse);
        home_bd.panel.tint = {1.0, home_green, home_blue, 1.0};
    }
    home_bd.panel.width = UIK.pixels(120);
    home_bd.panel.height = UIK.pixels(56);
    home_handle := UIK.button("go_home", "Home", home_bd);

    bd := UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
    upgrade_label := "Upgrades";
    if can_afford_any_upgrade(player) {
        bd = UIK.widget_desc_button_auto_default(.BUTTON_BASIC_WHITE);
        pulse := sin(get_time() * 3.2) * 0.5 + 0.5;
        red := lerp(0.46, 1.0, pulse);
        green := lerp(0.86, 1.0, pulse);
        blue := lerp(0.04, 1.0, pulse);
        bd.panel.tint = {red, green, blue, 1.0};
    }
    bd.panel.width = UIK.pixels(190);
    bd.panel.height = UIK.pixels(56);
    upgrades_handle := UIK.button("open_sawmill_upgrades", upgrade_label, bd);

    UIK.panel_end();
    UIK.panel_end();
    UIK.end();

    if UIK.clicked(upgrades_handle) {
        was_open := player.show_upgrades_menu;
        player.show_upgrades_menu = true;
        if !was_open play_upgrade_menu_open_sfx(player);
    }

    if UIK.clicked(home_handle) {
        player.entity.set_local_position(v2{0, 0});
        player.dialogue_text = "Home";
        player.dialogue_timer = 0.8;
        if player.is_local() {
            play_ui_sfx("click_6d65ee.wav", 0.14, 0.02);
        }
    }
}

draw_rebirth_hud_button :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    next_level := next_rebirth_level(player);

    UIK.begin(UIK.window(rebirth_hud_button_rect()));

    coin_icon := get_asset(Texture_Asset, "$AO/ui/kit/Icons/coin/coin_icon_b.png");
    bd := UIK.widget_desc_button_default(.BUTTON_BASIC_SKEW_PURPLE);
    if next_level > 0 && Economy.can_withdraw_currency(player, GOLD_CURRENCY, rebirth_cost(next_level)) {
        bd = UIK.widget_desc_button_auto_default(.BUTTON_BASIC_SKEW_WHITE);
        pulse := sin(get_time() * 4.0) * 0.5 + 0.5;
        bd.panel.tint = {lerp(0.72, 1.0, pulse), 1.0, lerp(0.84, 1.0, pulse), 1.0};
    } else if next_level <= 0 {
        bd = UIK.widget_desc_button_default(.BUTTON_BASIC_SKEW_GREEN);
    }
    bd.panel.width = UIK.flex(1);
    bd.panel.height = UIK.flex(1);
    rebirth_handle := UIK.icon_button_label("rebirth_buy", coin_icon, "Rebirth", bd);

    UIK.end();

    if UIK.clicked(rebirth_handle) {
        player.show_rebirth_confirm = true;
        if player.is_local() play_ui_sfx("click_6d65ee.wav", 0.16, 0.02);
    }
}

draw_global_top_message :: proc(player: Player) {
    if !player_ready_for_ui(player) return;

    message := Save.get_game_string(GLOBAL_TOP_MESSAGE_SAVE_KEY, "");
    if message.count <= 0 return;

    UIK.begin(UIK.window(UIK.rect_topbar()));
    shell := UIK.panel_modal(.BLACK, 8, v4{12, 12, 12, 12});
    shell.gap = 0;
    UIK.panel_begin(shell);

    row := UIK.layout_row(UIK.flex(1), UIK.flex(1), 8);
    UIK.panel_begin(row);
    UIK.spacer(UIK.flex(1), UIK.pixels(1));
    UIK.text(message, UIK.text_title());
    UIK.spacer(UIK.flex(1), UIK.pixels(1));
    UIK.panel_end();

    UIK.panel_end();
    UIK.end();
}

world_screen_interpolation_offset :: proc(camera: Camera, current_world: v2, previous_world: v2) -> v2 {
    camera_delta := camera.position - camera.position_last_frame;
    return world_to_screen(current_world) - world_to_screen(previous_world + camera_delta);
}

entity_previous_world_pos :: proc(anchor: Entity, current_world: v2) -> v2 {
    if anchor == null || !#alive(anchor) return current_world;
    return current_world - anchor.calculate_interpolation_offset();
}

draw_entity_world_progress_bar :: proc(anchor: Entity, position: v2, progress: float, options: World_Progress_Bar.World_Progress_Bar_Options) {
    if anchor == null || !#alive(anchor) return;

    UI.begin_world_space_ui(anchor);
    defer UI.end_world_space_ui();

    UI.push_z(position.y);
    defer UI.pop_z();

    hw := options.width * 0.5 * options.scale;
    hh := options.height * 0.5 * options.scale;
    position.y += options.y_bias;
    bg_rect := Rect{position, position}.grow(hh, hw, hh, hw);
    fill_rect := bg_rect.inset(0.02).subrect(0, 0, progress, 1);

    UI.quad(bg_rect, core_globals.white_sprite, {0.0, 0.0, 0.0, 1});
    fill_color := lerp(v4{1, 0.1, 0.1, 1}, {0.1, 1, 0.1, 1}, progress);
    UI.quad(fill_rect, core_globals.white_sprite, fill_color);
}

draw_lumber_world_overlays :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    draw_sawmill_progress_bar(player);
    draw_polishing_progress_bar(player);
    draw_helicopter_fuel_bars(player);
    draw_tree_monster_timer_bars(player);
    draw_vendor_world_labels(player);
    draw_recent_tree_health_bars(player);

    target, has_tutorial_target := draw_onboarding_tutorial(player);
    draw_world_space_feedback(player.camera);

    if has_tutorial_target && player.swing_timer > 0 {
        dir := normalize(target - player.entity.world_position);
        if length_squared(dir) < 0.1 dir = v2{1, 0};
        start := player.entity.world_position + v2{0, 0.4};
        end := start + dir * (1.1 + player.axe_tier.(float) * 0.18);
        UI.begin_world_space_ui(player.entity);
        UI.wire_box(end - v2{0.25, 0.25}, end + v2{0.25, 0.25}, 0.06, {1.0, 0.86, 0.22, min(1.0, player.swing_timer * 4.0)});
        UI.end_world_space_ui();
    }
}

draw_tutorial_world_arrow :: proc(player: Player, target: v2) {
    options := Tutorial_Arrow.default_options();
    options.alpha = 0.92;
    options.far = true;
    options.near = true;
    options.bob_scale = 0.5;
    options.bob_bias = 1.35;
    Tutorial_Arrow.draw(player, target, options);
}

upgrades_hud_button_hint_rect :: proc() -> Rect {
    hud := stats_hud_rect();
    center_y := hud.center().y;
    return Rect{
        min=v2{hud.max.x - 214.0, center_y - 35.0},
        max=v2{hud.max.x - 12.0, center_y + 35.0}
    };
}

draw_upgrades_button_tutorial_arrow :: proc() {
    UI.push_screen_draw_context();
    defer UI.pop_draw_context();

    button_rect := upgrades_hud_button_hint_rect();
    pulse := sin(get_time() * 5.5) * 0.5 + 0.5;
    alpha := lerp(0.55, 1.0, pulse);
    UI.wire_box(button_rect.min, button_rect.max, 4.0, {1.0, 0.92, 0.18, alpha});

    arrow_center := button_rect.top_center() + v2{0, 84.0 + sin(get_time() * 4.0) * 7.0};
    arrow_rect := Rect{min=arrow_center - v2{50.0, 50.0}, max=arrow_center + v2{50.0, 50.0}}.fit_aspect(core_globals.tutorial_arrow.get_aspect());
    UI.push_matrix(Matrix4.rotate_about_point(arrow_rect.center(), 270));
    UI.quad(arrow_rect, core_globals.tutorial_arrow, {1.0, 1.0, 1.0, alpha});
    UI.pop_matrix();
}

draw_onboarding_banner :: proc(text: string) {
    if text.count <= 0 return;

    UI.push_screen_draw_context();
    defer UI.pop_draw_context();

    safe := UI.get_safe_screen_rect();
    half_width := min(390.0, max(265.0, safe.width() * 0.46));
    center := safe.top_center() + v2{0, -74.0};
    rect := Rect{min=center - v2{half_width, 36.0}, max=center + v2{half_width, 36.0}};
    pulse := sin(get_time() * 3.0) * 0.5 + 0.5;

    UI.quad(rect.grow(5.0), core_globals.white_sprite, {0.03, 0.02, 0.0, 0.72});
    UI.quad(rect, core_globals.white_sprite, {0.26, 0.15, 0.06, 0.91});
    UI.wire_box(rect.min, rect.max, 3.0, {1.0, lerp(0.72, 0.95, pulse), 0.22, 0.9});

    ts := UI.default_text_settings();
    ts.size = 32;
    if safe.width() < 720.0 {
        ts.size = 27;
    }
    ts.color = {1.0, 0.96, 0.82, 1.0};
    ts.outline_thickness = 2.0;
    ts.outline_color = {0.05, 0.025, 0.0, 1.0};
    UI.text(rect.inset(6.0), ts, text);
}

draw_onboarding_tutorial :: proc(player: Player) -> v2, bool {
    if player == null return v2{0, 0}, false;
    if player.onboarding_step >= ONBOARDING_STEP_DONE return v2{0, 0}, false;

    draw_onboarding_banner(tutorial_text_for_step(player.onboarding_step));

    switch player.onboarding_step {
        case ONBOARDING_STEP_CUT_TREES: {
            if player.tutorial_tree_target == null return v2{0, 0}, false;
            if !#alive(player.tutorial_tree_target.entity) return v2{0, 0}, false;
            if player.tutorial_tree_target.is_cut return v2{0, 0}, false;

            target := tree_axe_collision_position(player.tutorial_tree_target) + v2{0, 0.35};
            draw_tutorial_world_arrow(player, target);
            return target, true;
        }
        case ONBOARDING_STEP_REFINE_LOGS: {
            target, found := find_closest_sawmill_position(player.entity.world_position);
            if !found return v2{0, 0}, false;
            target += v2{0, 0.45};
            draw_tutorial_world_arrow(player, target);
            return target, true;
        }
        case ONBOARDING_STEP_SELL_PLANKS: {
            target, found := find_closest_seller_position(player.entity.world_position);
            if !found return v2{0, 0}, false;
            target += v2{0, 0.55};
            draw_tutorial_world_arrow(player, target);
            return target, true;
        }
        case ONBOARDING_STEP_UPGRADE_AXE: {
            draw_upgrades_button_tutorial_arrow();
            return v2{0, 0}, false;
        }
        default: return v2{0, 0}, false;
    }
}

draw_recent_tree_health_bars :: proc(player: Player) {
    if !player_ready_for_ui(player) return;

    now := get_time();
    query_trees_near(player.entity.world_position, 9.0, ref player.nearby_tree_cache);
    for tree: player.nearby_tree_cache {
        if tree == null continue;
        if tree.health_bar_until <= now continue;
        if tree.is_cut continue;
        if tree.will_fall && tree.health <= 0 continue;
        if tree.health_bar_player != null {
            if !#alive(tree.health_bar_player) continue;
        }
        if length(tree.entity.world_position - player.entity.world_position) > 9.0 continue;

        tree_health := max(1, tree.max_health());
        progress := clamp(tree.health.(float) / tree_health.(float), 0.0, 1.0);
        bar_world := tree.entity.world_position + v2{0, 1.65};
        bar_pos := world_to_screen(bar_world);
        width := 76.0 + tree.tree_level.(float) * 8.0;
        height := 10.0;
        half := v2{width * 0.5, height * 0.5};
        bg_rect := Rect{min=bar_pos - half, max=bar_pos + half};
        fill_width := max(2.0, width * progress);
        fill_rect := Rect{min=bg_rect.min + v2{2, 2}, max=bg_rect.min + v2{fill_width - 2.0, height - 2.0}};
        UI.push_interpolation_offset(world_screen_interpolation_offset(player.camera, bar_world, entity_previous_world_pos(tree.entity, bar_world)));
        UI.quad(bg_rect.grow(3), core_globals.white_sprite, {0.04, 0.02, 0.0, 0.74});
        if now < tree.health_bar_flash_until {
            UI.quad(bg_rect, core_globals.white_sprite, {1.0, 1.0, 1.0, 0.96});
            UI.quad(fill_rect, core_globals.white_sprite, {1.0, 1.0, 1.0, 1.0});
        } else {
            UI.quad(bg_rect, core_globals.white_sprite, {0.22, 0.05, 0.02, 0.92});
            UI.quad(fill_rect, core_globals.white_sprite, {0.28, 1.0, 0.24, 0.96});
        }
        UI.pop_interpolation_offset();
    }
}

draw_helicopter_fuel_bars :: proc(player: Player) {
    for heli: component_iterator(Rentable_Helicopter) {
        if !heli.is_rented() {
            if !player_can_use_helicopter(player) {
                draw_entity_text_world_scaled(player.camera, heli.entity, v2{0, 1.6}, "Requires rebirth 2", {1.0, 0.55, 0.25, 1}, 0.92);
            } else {
                draw_entity_text_world_scaled(player.camera, heli.entity, v2{0, 1.6}, format_string("Rent %", {heli.rent_cost}), {1.0, 0.90, 0.25, 1}, 1.15);
            }
            continue;
        }

        progress := heli.fuel_progress();
        options := World_Progress_Bar.default_options();
        options.y_bias = 1.0;
        options.width = 1.85;
        options.height = 0.18;
        options.scale = 1.0;
        draw_entity_world_progress_bar(heli.entity, heli.entity.world_position + v2{0, 1.75}, progress, options);
        remaining := max(0, (heli.rented_until - get_time()).(s64));
        minutes := remaining / 60;
        seconds := remaining - minutes * 60;
        draw_entity_text_world_scaled(player.camera, heli.entity, v2{0, 2.05}, format_string("Fuel %:%", {minutes, format_int(seconds, leading_zeroes=2)}), {0.9, 1.0, 0.32, 1}, 0.95);
    }
}

draw_tree_monster_timer_bars :: proc(player: Player) {
    for monster: component_iterator(Rentable_Tree_Monster) {
        if !monster.is_rented() {
            if !player_can_use_tree_monster(player) {
                draw_entity_text_world_scaled(player.camera, monster.entity, v2{0, 1.75}, "Requires rebirth 3", {1.0, 0.55, 0.25, 1}, 0.92);
            } else {
                draw_entity_text_world_scaled(player.camera, monster.entity, v2{0, 1.75}, format_string("Rent %", {monster.rent_cost}), {0.55, 1.0, 0.32, 1}, 1.12);
            }
            continue;
        }

        progress := monster.fuel_progress();
        options := World_Progress_Bar.default_options();
        options.y_bias = 1.0;
        options.width = 1.85;
        options.height = 0.18;
        options.scale = 1.0;
        draw_entity_world_progress_bar(monster.entity, monster.entity.world_position + v2{0, 1.95}, progress, options);
        remaining := max(0, (monster.rented_until - get_time()).(s64));
        draw_entity_text_world_scaled(player.camera, monster.entity, v2{0, 2.25}, format_string("Monster %", {remaining}), {0.55, 1.0, 0.32, 1}, 0.95);
    }
}

draw_exit_helicopter_confirm :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    if !player_helicopter_rented(player) {
        player.show_exit_helicopter_confirm = false;
        return;
    }

    UIK.begin(UIK.modal(UIK.rect_window_small(), 25));

    shell := UIK.panel_modal(.BROWN, 10, v4{16, 16, 16, 16});
    shell.gap = 12;
    UIK.panel_begin(shell);

    title_desc := UIK.title_area_desc("Exit Heli?");
    title_desc.style = .NONE;
    exit_handle := UIK.title_area(title_desc);

    UIK.spacer(UIK.pixels(1), UIK.flex(0.25));
    UIK.text("End the rental now?", UIK.text_title());
    UIK.text("No refund.", UIK.text_body());
    UIK.spacer(UIK.pixels(1), UIK.flex(1));

    row := UIK.layout_row(UIK.flex(1), UIK.fit(), 16);
    UIK.panel_begin(row);

    cancel_desc := UIK.widget_desc_button_default(.BUTTON_BASIC_GREEN);
    cancel_desc.panel.width = UIK.flex(1);
    cancel_desc.panel.height = UIK.pixels(82);
    cancel_btn := UIK.button("heli_exit_cancel", "Keep", cancel_desc);

    confirm_desc := UIK.widget_desc_button_default(.BUTTON_BASIC_RED);
    confirm_desc.panel.width = UIK.flex(1);
    confirm_desc.panel.height = UIK.pixels(82);
    confirm_btn := UIK.button("heli_exit_confirm", "Exit", confirm_desc);

    UIK.panel_end();
    UIK.panel_end();
    UIK.end();

    if UIK.clicked(exit_handle) || UIK.clicked(cancel_btn) {
        player.show_exit_helicopter_confirm = false;
        if player.is_local() play_ui_sfx("click_6d65ee.wav", 0.16, 0.02);
    }
    if UIK.clicked(confirm_btn) {
        heli := player.helicopter_rental;
        if heli != null && #alive(heli) {
            heli.finish_rental(true);
        } else {
            player.show_exit_helicopter_confirm = false;
        }
        if player.is_local() play_ui_sfx("click_6d65ee.wav", 0.18, 0.02);
    }
}

draw_rebirth_confirm :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    next_level := next_rebirth_level(player);
    gold := Economy.get_balance(player, GOLD_CURRENCY);
    cost := rebirth_cost(next_level);
    can_rebirth := next_level > 0 && Economy.can_withdraw_currency(player, GOLD_CURRENCY, cost);

    UIK.begin(UIK.modal(UIK.rect_window_small(), 25));

    shell := UIK.panel_modal(.BROWN, 10, v4{14, 14, 14, 14});
    shell.gap = 8;
    UIK.panel_begin(shell);

    title := "Rebirth";
    if next_level > 0 {
        title = format_string("Rebirth %", {next_level});
    } else {
        title = "Max Rebirth";
    }
    title_desc := UIK.title_area_desc(title);
    title_desc.style = .NONE;
    exit_handle := UIK.title_area(title_desc);

    body := UIK.layout_column();
    body.width = UIK.flex(1);
    body.height = UIK.fit();
    body.gap = 10;
    body.padding = v4{2, 2, 2, 2};
    UIK.panel_begin(body);

    current_mult := format_float(rebirth_money_multiplier(player), decimals=2);
    if next_level > 0 {
        next_mult := format_float(rebirth_money_multiplier_for_level(next_level), decimals=2);

        progress := clamp(gold.(float) / max(1, cost).(float), 0.0, 1.0);
        cost_card := UIK.panel_interior(.INSET);
        cost_card.width = UIK.flex(1);
        cost_card.height = UIK.pixels(100);
        cost_card.padding = v4{12, 8, 12, 8};
        cost_card.gap = 5;
        UIK.panel_begin(cost_card);
        UIK.text(format_string("% / % Gold", {gold, cost}), UIK.text_title());
        UIK.progress_bar(UIK.panel_progress_bar(.PROGRESS_BAR_STYLE_1, progress, {1.0, 0.86, 0.18, 1}, UIK.flex(1), UIK.pixels(16)));
        if !can_rebirth {
            missing := max(0, cost - gold);
            UIK.text(format_string("% Gold short", {missing}), UIK.text_body());
        } else {
            UIK.text("Progress resets", UIK.text_body());
        }
        UIK.panel_end();

        rewards := UIK.layout_row(UIK.flex(1), UIK.pixels(84), 8);
        UIK.panel_begin(rewards);

        access_card := UIK.panel_interior(.INSET);
        access_card.width = UIK.flex(1);
        access_card.height = UIK.flex(1);
        access_card.padding = v4{10, 7, 10, 7};
        access_card.gap = 3;
        UIK.panel_begin(access_card);
        UIK.text("Unlock", UIK.text_body());
        UIK.text(rebirth_unlock_label(next_level), UIK.text_body());
        UIK.panel_end();

        mult_card := UIK.panel_interior(.INSET);
        mult_card.width = UIK.flex(1);
        mult_card.height = UIK.flex(1);
        mult_card.padding = v4{10, 7, 10, 7};
        mult_card.gap = 3;
        UIK.panel_begin(mult_card);
        UIK.text("Gold", UIK.text_body());
        UIK.text(format_string("x% -> x%", {current_mult, next_mult}), UIK.text_body());
        UIK.panel_end();
        UIK.panel_end();
    } else {
        complete_card := UIK.panel_interior(.INSET);
        complete_card.width = UIK.flex(1);
        complete_card.height = UIK.pixels(148);
        complete_card.padding = v4{12, 10, 12, 10};
        complete_card.gap = 6;
        UIK.panel_begin(complete_card);
        UIK.text("All access unlocked", UIK.text_title());
        UIK.text(format_string("Gold multiplier x%", {current_mult}), UIK.text_title());
        UIK.text("Polisher, helicopter, monster, haunt.", UIK.text_body());
        UIK.panel_end();
    }

    UIK.panel_end();

    row := UIK.layout_row(UIK.flex(1), UIK.fit(), 14);
    UIK.panel_begin(row);

    cancel_desc := UIK.widget_desc_button_default(.BUTTON_BASIC_GREEN);
    cancel_desc.panel.width = UIK.flex(1);
    cancel_desc.panel.height = UIK.pixels(64);
    cancel_btn := UIK.button("rebirth_cancel", "Close", cancel_desc);

    confirm_desc := UIK.widget_desc_button_default(.BUTTON_BASIC_RED);
    confirm_label := "Rebirth";
    if !can_rebirth {
        confirm_desc = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
        if next_level <= 0 {
            confirm_label = "Complete";
        } else {
            confirm_label = "Not Ready";
        }
    }
    confirm_desc.panel.width = UIK.flex(1);
    confirm_desc.panel.height = UIK.pixels(64);
    confirm_btn := UIK.button("rebirth_confirm", confirm_label, confirm_desc);

    UIK.panel_end();
    UIK.panel_end();
    UIK.end();

    if UIK.clicked(exit_handle) || UIK.clicked(cancel_btn) {
        player.show_rebirth_confirm = false;
        if player.is_local() play_ui_sfx("click_6d65ee.wav", 0.16, 0.02);
    }
    confirm_clicked := UIK.clicked(confirm_btn);
    if confirm_clicked && can_rebirth {
        perform_rebirth(player);
        player.show_rebirth_confirm = false;
        if player.is_local() play_ui_sfx("click_6d65ee.wav", 0.18, 0.02);
    } else if confirm_clicked && next_level > 0 {
        player.dialogue_text = "Need more gold.";
        player.dialogue_timer = 1.4;
        play_backpack_full_dud_sfx(player.entity.world_position);
    }
}

draw_vendor_world_labels :: proc(player: Player) {
    for sawmill: component_iterator(Lumber_Sawmill) {
        draw_entity_text_world_scaled(player.camera, sawmill.entity, v2{0, 1.575}, "Refine", {0.95, 0.82, 0.36, 1}, 1.32);
    }

    for polisher: component_iterator(Polishing_Machine) {
        if player_has_alien_refiner(player) {
            draw_entity_text_world_scaled(player.camera, polisher.entity, v2{0, 1.575}, "Polish", {0.78, 0.25, 1.0, 1}, 1.32);
        } else {
            draw_entity_text_world_scaled(player.camera, polisher.entity, v2{0, 1.575}, "Requires rebirth 1", {1.0, 0.55, 0.25, 1}, 0.92);
        }
    }

    for seller: component_iterator(Plank_Seller) {
        draw_entity_text_world_scaled(player.camera, seller.entity, v2{0, 1.85}, "Sell", {1.0, 0.92, 0.25, 1}, 1.32);
    }

    for shop: component_iterator(Axe_Shop_NPC) {
        draw_entity_text_world_scaled(player.camera, shop.entity, v2{0, 1.85}, "Upgrade", {0.55, 1.0, 0.45, 1}, 1.52);
    }
}

draw_sawmill_progress_bar :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    progress := 0.0;
    should_draw := false;
    if player.refining {
        progress = clamp(player.refine_timer / sawmill_process_time(player.sawmill_tier), 0.0, 1.0);
        should_draw = true;
    } else if player_has_auto_sawmill(player) && count_item(player, log_defn) > 0 {
        progress = clamp(player.auto_refine_timer / sawmill_auto_process_time(player.sawmill_tier), 0.0, 1.0);
        should_draw = progress > 0.02;
    }
    if !should_draw return;

    for sawmill: component_iterator(Lumber_Sawmill) {
        options := World_Progress_Bar.default_options();
        options.y_bias = 1.0;
        options.width = 1.65;
        options.height = 0.16;
        options.scale = 1.0;
        draw_entity_world_progress_bar(sawmill.entity, sawmill.entity.world_position + v2{0, 1.85}, progress, options);
        if player.refining && player.refine_logs_total > 0 {
            processed := clamp(player.refine_logs_total - player.refine_logs_remaining, 0, player.refine_logs_total);
            draw_entity_text_world_scaled(player.camera, sawmill.entity, v2{0, 2.12}, format_string("%/%", {processed, player.refine_logs_total}), {0.95, 0.82, 0.36, 1}, 1.08);
        }
    }
}

draw_polishing_progress_bar :: proc(player: Player) {
    if !player_ready_for_ui(player) return;
    if !player.polishing return;

    progress := clamp(player.polish_timer / polishing_process_time(player.sawmill_tier), 0.0, 1.0);
    for polisher: component_iterator(Polishing_Machine) {
        options := World_Progress_Bar.default_options();
        options.y_bias = 1.0;
        options.width = 1.65;
        options.height = 0.16;
        options.scale = 1.0;
        draw_entity_world_progress_bar(polisher.entity, polisher.entity.world_position + v2{0, 1.85}, progress, options);
        if player.polish_planks_total > 0 {
            processed := clamp(player.polish_planks_total - player.polish_planks_remaining, 0, player.polish_planks_total);
            draw_entity_text_world_scaled(player.camera, polisher.entity, v2{0, 2.12}, format_string("%/%", {processed, player.polish_planks_total}), {0.42, 1.0, 0.88, 1}, 1.08);
        }
    }
}

spawn_text_world :: proc(pos: v2, text: string, color: v4) {
    spawn_text_world_scaled(pos, text, color, 1.0);
}

spawn_text_world_scaled :: proc(pos: v2, text: string, color: v4, scale: float) {
    draw_text_world_scaled_at_screen_pos(world_to_screen(pos), text, color, scale);
}

draw_text_world_scaled_at_screen_pos :: proc(screen: v2, text: string, color: v4, scale: float) {
    rect := Rect{min=screen + v2{-130.0 * scale, -24.0 * scale}, max=screen + v2{130.0 * scale, 24.0 * scale}};
    ts := UI.default_text_settings();
    ts.size = 26.0 * scale;
    ts.color = color;
    ts.outline_thickness = 2.0 * scale;
    ts.outline_color = {0.08, 0.04, 0.0, 0.9};
    ts.halign = .CENTER;
    ts.valign = .CENTER;
    UI.text(rect, ts, text);
}

draw_text_world_scaled_interpolated :: proc(camera: Camera, pos: v2, prev_pos: v2, text: string, color: v4, scale: float) {
    screen := world_to_screen(pos);
    UI.push_interpolation_offset(world_screen_interpolation_offset(camera, pos, prev_pos));
    draw_text_world_scaled_at_screen_pos(screen, text, color, scale);
    UI.pop_interpolation_offset();
}

draw_entity_text_world_scaled :: proc(camera: Camera, anchor: Entity, offset: v2, text: string, color: v4, scale: float) {
    if anchor == null || !#alive(anchor) return;
    pos := anchor.world_position + offset;
    draw_text_world_scaled_interpolated(camera, pos, entity_previous_world_pos(anchor, pos), text, color, scale);
}

draw_floating_feedback :: proc(f: Floating_Feedback, camera: Camera) {
    t := min(1.0, f.age / f.duration);
    pos := f.start_pos + v2{f.drift_x * t, t * 1.2 + sin(t * PI) * 0.4};
    screen := world_to_screen(pos);
    scale := lerp(1.15, 0.75, t) + max(0.0, 1.0 - t / 0.2) * 0.35;
    if f.big scale += 0.18;
    if f.text_scale > 0.0 scale *= f.text_scale;
    rect := Rect{min=screen + v2{-110.0 * scale, -30.0 * scale}, max=screen + v2{110.0 * scale, 30.0 * scale}};
    ts := UI.default_text_settings();
    ts.size = 32.0 * scale;
    ts.color = v4{f.color.x, f.color.y, f.color.z, 1.0 - max(0.0, (t - 0.65) / 0.35)};
    ts.outline_thickness = 2.0;
    ts.outline_color = {0, 0, 0, ts.color.w};
    ts.halign = .CENTER;
    ts.valign = .CENTER;
    // The text position only advances at sim rate; hand the renderer this frame's
    // screen-space movement (text motion + camera motion) so it can interpolate
    // between sim frames instead of stepping at 32hz.
    prev_t := min(1.0, f.prev_age / f.duration);
    prev_pos := f.start_pos + v2{f.drift_x * prev_t, prev_t * 1.2 + sin(prev_t * PI) * 0.4};
    UI.push_interpolation_offset(world_screen_interpolation_offset(camera, pos, prev_pos));
    UI.text(rect, ts, f.text);
    UI.pop_interpolation_offset();
}

draw_world_ui_quad :: proc(camera: Camera, pos: v2, prev_pos: v2, texture: Texture_Asset, size: float, rotation: float, color: v4) {
    screen := world_to_screen(pos);
    half := v2{size * 0.5, size * 0.5};
    rect := Rect{min=screen - half, max=screen + half};
    UI.push_interpolation_offset(world_screen_interpolation_offset(camera, pos, prev_pos));
    UI.push_matrix(Matrix4.rotate_about_point(rect.center(), rotation));
    UI.quad(rect, texture, color);
    UI.pop_matrix();
    UI.pop_interpolation_offset();
}

draw_world_space_feedback :: proc(camera: Camera) {
    frame := get_frame_number();
    if g_world_feedback_draw_frame == frame return;
    g_world_feedback_draw_frame = frame;

    if g_chip_vfx.count > 0 {
        for i: 0..g_chip_vfx.count - 1 {
            c := g_chip_vfx[i];
            if !should_draw_feedback_owner(c.owner) continue;
            t := min(1.0, c.age / c.duration);
            alpha := 1.0 - max(0.0, (t - 0.62) / 0.38);
            draw_world_ui_quad(camera, c.pos, c.prev_pos, wood_chips_texture, 120.0 * c.scale, c.rotation, {1, 1, 1, alpha});
        }
    }

    if g_juice_particle_vfx.count > 0 {
        for i: 0..g_juice_particle_vfx.count - 1 {
            j := g_juice_particle_vfx[i];
            if !should_draw_feedback_owner(j.owner) continue;
            t := min(1.0, j.age / j.duration);
            shrink := max(0.05, 1.0 - t * 0.55);
            color := v4{j.start_color.x, j.start_color.y, j.start_color.z, j.start_color.w * (1.0 - t)};
            draw_world_ui_quad(camera, j.pos, j.prev_pos, wood_chips_texture, 120.0 * j.scale * shrink, j.rotation, color);
        }
    }

    if g_log_pickup_lerps.count > 0 {
        for i: 0..g_log_pickup_lerps.count - 1 {
            p := g_log_pickup_lerps[i];
            if p.owner == null || !#alive(p.owner) || !#alive(p.owner.entity) continue;
            if !should_draw_feedback_owner(p.owner) continue;
            t := 0.0;
            if p.age >= p.delay {
                t = min(1.0, (p.age - p.delay) / p.duration);
            }
            pop := 1.0 + sin(t * PI) * 0.35;
            pos := log_pickup_lerp_position(p);
            owner_prev_pos := p.owner.entity.world_position - p.owner.entity.calculate_interpolation_offset();
            prev_pos := log_pickup_lerp_position_at_age(p, p.prev_age, owner_prev_pos);
            draw_world_ui_quad(camera, pos, prev_pos, wood_logs_texture, 86.0 * p.base_scale * pop, 0, {1, 1, 1, 1});
        }
    }

    if g_floating_feedback.count > 0 {
        for i: 0..g_floating_feedback.count - 1 {
            f := g_floating_feedback[i];
            if !should_draw_feedback_owner(f.owner) continue;
            draw_floating_feedback(f, camera);
        }
    }
}

draw_axe_upgrade_shop :: proc(player: Player) {
    UIK.begin(UIK.modal(UIK.rect_window(), 15));
    shell := UIK.panel_modal(.BROWN, 10, v4{16, 16, 16, 16});
    UIK.panel_begin(shell);
    exit_handle := UIK.title_area(UIK.title_area_desc("Axe Upgrades"));

    icon := get_asset(Texture_Asset, "icon_axe_006f01.png");
    row := UIK.layout_row(UIK.flex(1), UIK.fit(), 14);
    UIK.panel_begin(row);
    box := UIK.layout_centered(UIK.pixels(130), UIK.pixels(130));
    UIK.panel_begin(box);
    UIK.image_fitted(icon, UIK.image_desc(.CONTAIN), axe_tier_color(player.axe_tier));
    UIK.panel_end();

    col := UIK.layout_column();
    col.width = UIK.flex(1);
    col.height = UIK.fit();
    col.gap = 8;
    UIK.panel_begin(col);
    UIK.text(format_string("Tier: %", {player.axe_tier}), UIK.text_title());
    UIK.text(format_string("Axe: %", {axe_tier_name(player.axe_tier)}), UIK.text_body());
    UIK.text(format_string("Damage: %", {axe_damage(player.axe_tier)}), UIK.text_body());
    UIK.text(format_string("Hits per tree: %", {axe_hits_to_chop(player.axe_tier)}), UIK.text_body());
    UIK.text(format_string("Radius: %", {format_float(axe_chop_radius(player.axe_tier), decimals=1)}), UIK.text_body());
    if player.axe_tier > 1 {
        UIK.text(format_string("Previous: % damage, % hits, radius %", {axe_damage(player.axe_tier - 1), axe_hits_to_chop(player.axe_tier - 1), format_float(axe_chop_radius(player.axe_tier - 1), decimals=1)}), UIK.text_body());
    }
    if player.axe_tier < MAX_AXE_TIER {
        UIK.text(format_string("Next: % damage, % hits, radius %", {axe_damage(player.axe_tier + 1), axe_hits_to_chop(player.axe_tier + 1), format_float(axe_chop_radius(player.axe_tier + 1), decimals=1)}), UIK.text_body());
    }
    UIK.panel_end();
    UIK.panel_end();

    buy_handle: Interact_Result;
    can_buy := false;
    if player.axe_tier < MAX_AXE_TIER {
        cost := axe_upgrade_cost(player.axe_tier);
        can_buy = Economy.can_withdraw_currency(player, GOLD_CURRENCY, cost);
        UIK.text(format_string("Cost: % Gold", {cost}), UIK.text_title());
        bd := UIK.widget_desc_button_default(.BUTTON_BASIC_GREEN);
        bd.panel.width = UIK.flex(1);
        bd.panel.height = UIK.pixels(90);
        label := "Upgrade";
        if !can_buy {
            label = format_string("Need % Gold", {cost});
            bd = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
            bd.panel.width = UIK.flex(1);
            bd.panel.height = UIK.pixels(90);
        }
        buy_handle = UIK.button("axe_upgrade_buy", label, bd);
    } else {
        UIK.text("Maximum tier reached", UIK.text_title());
    }

    UIK.panel_end();
    UIK.end();

    if UIK.clicked(exit_handle) {
        player.show_upgrade_shop = false;
    }
    if player.axe_tier < MAX_AXE_TIER && UIK.clicked(buy_handle) {
        cost := axe_upgrade_cost(player.axe_tier);
        if Economy.can_withdraw_currency(player, GOLD_CURRENCY, cost) {
            Economy.withdraw_currency(player, GOLD_CURRENCY, cost);
            player.axe_tier += 1;
            save_player_progress(player);
            player.dialogue_text = "Sharper. Wider. Faster.";
            player.dialogue_timer = 2.0;
            player.ui_pop_timer = 0.3;
            spawn_float_text(player.entity.world_position + v2{0, 1.5}, format_string("Tier: %", {player.axe_tier}), axe_tier_color(player.axe_tier), true);
            spawn_juice_particles(player.entity.world_position + v2{0, 0.8}, player.axe_tier, 18, axe_tier_color(player.axe_tier), true);
            play_upgrade_sfx(player, AXE_UPGRADE_SFX);
        } else {
            player.dialogue_text = "Bring more gold.";
            player.dialogue_timer = 1.8;
        }
    }
}

draw_upgrades_menu :: proc(player: Player) {
    UIK.begin(UIK.modal(UIK.rect_window(), 15));
    shell := UIK.panel_modal(.BROWN, 10, v4{16, 16, 16, 16});
    shell.gap = 8;
    UIK.panel_begin(shell);
    exit_handle := UIK.title_area(UIK.title_area_desc("Upgrades"));

    backpack_handle: Interact_Result;
    axe_handle: Interact_Result;
    sawmill_handle: Interact_Result;
    auto_handle: Interact_Result;
    unlimited_backpack_handle: Interact_Result;
    unlimited_speed_handle: Interact_Result;

    backpack_icon := get_asset(Texture_Asset, "$AO/ui/kit/Icons/backpacks/backpack_closed_med.png");
    axe_icon := get_asset(Texture_Asset, "icon_axe_006f01.png");
    saw_icon := get_asset(Texture_Asset, "Sawmill_cc8b36.png");
    gold := Economy.get_balance(player, GOLD_CURRENCY);

    content := UIK.layout_column();
    content.width = UIK.flex(1);
    content.height = UIK.flex(1);
    content.gap = 8;
    UIK.list_begin("upgrades_scroll", content);

    axe_row := UIK.panel_interior(.INSET);
    axe_row.width = UIK.flex(1);
    axe_row.height = UIK.pixels(126);
    axe_row.padding = v4{8, 10, 8, 10};
    axe_row.gap = 12;
