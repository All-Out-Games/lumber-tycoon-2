    col := UIK.layout_column();
    col.width = UIK.flex(1);
    col.height = UIK.flex(1);
    col.gap = 2;
    UIK.panel_begin(col);
    UIK.text(format_string("Backpack Tier %", {player.backpack_tier}), UIK.text_title());
    if player.infinite_backpack || player_has_unlimited_backpack(player) {
        UIK.text("Capacity Infinite", UIK.text_body());
    } else if player.backpack_tier < MAX_BACKPACK_TIER {
        UIK.text(format_string("Capacity % -> %", {backpack_capacity(player.backpack_tier), backpack_capacity(player.backpack_tier + 1)}), UIK.text_body());
    } else {
        UIK.text(format_string("Capacity %", {backpack_capacity(player.backpack_tier)}), UIK.text_body());
        UIK.text("Maximum tier reached", UIK.text_body());
    }
    UIK.panel_end();
    backpack_bd := UIK.widget_desc_button_default(.BUTTON_BASIC_GREEN);
    backpack_bd.panel.width = UIK.pixels(289);
    backpack_bd.panel.height = UIK.pixels(70);
    backpack_label := "Maximum";
    if player.backpack_tier >= MAX_BACKPACK_TIER {
        backpack_bd = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
        backpack_bd.panel.width = UIK.pixels(289);
        backpack_bd.panel.height = UIK.pixels(70);
    }
    if player.backpack_tier < MAX_BACKPACK_TIER {
        cost := backpack_upgrade_cost(player.backpack_tier);
