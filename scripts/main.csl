    UIK.panel_begin(axe_layout);
    axe_icon_box := UIK.layout_centered(UIK.pixels(70), UIK.pixels(70));
    UIK.panel_begin(axe_icon_box);
    UIK.image_fitted(axe_icon, UIK.image_desc(.CONTAIN), axe_tier_color(player.axe_tier));
    UIK.panel_end();
    axe_col := UIK.layout_column();
    axe_col.width = UIK.flex(1);
    axe_col.height = UIK.flex(1);
    axe_col.gap = 2;
    UIK.panel_begin(axe_col);
    UIK.text(format_string("Axe Tier %", {player.axe_tier}), UIK.text_title());
    if player.axe_tier < MAX_AXE_TIER {
        UIK.text(format_string("Damage % -> %", {axe_damage(player.axe_tier), axe_damage(player.axe_tier + 1)}), UIK.text_body());
    } else {
        UIK.text(format_string("Damage %", {axe_damage(player.axe_tier)}), UIK.text_body());
        UIK.text("Maximum tier reached", UIK.text_body());
    }
    UIK.panel_end();
    axe_bd := UIK.widget_desc_button_default(.BUTTON_BASIC_GREEN);
    axe_bd.panel.width = UIK.pixels(289);
    axe_bd.panel.height = UIK.pixels(70);
    axe_label := "Maximum";
    if player.axe_tier >= MAX_AXE_TIER {
        axe_bd = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
        axe_bd.panel.width = UIK.pixels(289);
        axe_bd.panel.height = UIK.pixels(70);
    }
    if player.axe_tier < MAX_AXE_TIER {
        cost := axe_upgrade_cost(player.axe_tier);
        axe_label = format_string("Buy % Gold", {cost});
        if gold < cost {
            axe_label = format_string("Need % Gold", {cost});
            axe_bd = UIK.widget_desc_button_default(.BUTTON_BASIC_GREY);
            axe_bd.panel.width = UIK.pixels(289);
            axe_bd.panel.height = UIK.pixels(70);
        }
    }
    axe_handle = UIK.button("axe_upgrade_buy_menu", axe_label, axe_bd);
    UIK.panel_end();
    UIK.panel_end();

    backpack_row := UIK.panel_interior(.INSET);
    backpack_row.width = UIK.flex(1);
    backpack_row.height = UIK.pixels(126);
    backpack_row.padding = v4{8, 10, 8, 10};
    backpack_row.gap = 12;
    UIK.panel_begin(backpack_row);
    row := UIK.layout_row(UIK.flex(1), UIK.flex(1), 12);
    UIK.panel_begin(row);
    icon_box := UIK.layout_centered(UIK.pixels(70), UIK.pixels(70));
    UIK.panel_begin(icon_box);
    UIK.image_fitted(backpack_icon, UIK.image_desc(.CONTAIN), {1, 1, 1, 1});
